<?xml version="1.0" encoding="UTF-8"?>
<phpunit xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" backupGlobals="false" colors="true"
  processIsolation="false" stopOnFailure="false" beStrictAboutChangesToGlobalState="true"
  bootstrap="tests/Pest.php"
  xsi:noNamespaceSchemaLocation="https://schema.phpunit.de/12.5/phpunit.xsd"
  cacheDirectory=".phpunit-live.cache" backupStaticProperties="false">
  <source>
    <include>
      <directory suffix=".php">src</directory>
    </include>
    <exclude>
      <directory suffix=".php">src/vendor</directory>
      <directory suffix=".php">src/data</directory>
    </exclude>
  </source>
  <testsuites>
    <testsuite name="Live Tests">
      <directory>tests/Modules</directory>
    </testsuite>
  </testsuites>
  <php>
    <ini name="display_errors" value="On" />
    <ini name="display_startup_errors" value="On" />
  </php>
</phpunit>
