<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8">
        <meta name="viewport" content="width=device-width, initial-scale=1">
        <link href="./assets/css/pico.min.css" rel="stylesheet">
        <script src="./assets/js/modal.js"></script>
        <title>FOSSBilling Installation</title>
        <base href="{{ constant('URL_INSTALL') }}"/>
        <style type="text/css">
            :root {
                --fb-brand: #1c7ed6;
                --fb-brand-dark: #1864ab;
                --fb-surface: #ffffff;
                --fb-border: #dbe3ec;
                --fb-muted: #5f6c7b;
                --fb-success: #2f9e44;
                --fb-danger: #d9480f;
                --fb-warning: #f08c00;
            }
            body {
                background: #f6f8fb;
            }
            body > main.container {
                max-width: 980px;
                padding-top: 2rem;
                padding-bottom: 2rem;
            }
            body > footer.container {
                max-width: 980px;
                padding-top: 0;
                padding-bottom: 2rem;
                color: var(--fb-muted);
            }
            nav.installer-nav {
                align-items: center;
                border-bottom: 1px solid var(--fb-border);
                margin-bottom: 2rem;
                padding-bottom: 1rem;
            }
            nav.installer-nav img {
                height: 48px;
                width: auto;
            }
            .installer-panel {
                background: var(--fb-surface);
                border: 1px solid var(--fb-border);
                border-radius: 8px;
                box-shadow: 0 16px 40px rgba(20, 33, 61, 0.08);
                padding: clamp(1rem, 3vw, 2rem);
            }
            .installer-intro {
                color: var(--fb-muted);
                margin-bottom: 1.25rem;
            }
            .green {
                color: var(--fb-success);
                font-weight: bold;
            }
            .red {
                color: var(--fb-danger);
                font-weight: bold;
            }
            .orange {
                color: var(--fb-warning);
                font-weight: bold;
            }
            #overall-progress {
                height: 0.75rem;
                margin-bottom: 1.5rem;
            }
            details {
                background: #fbfcfe;
                border: 1px solid var(--fb-border);
                border-radius: 8px;
                margin-bottom: 1rem;
                padding: 0;
            }
            details[open] {
                background: var(--fb-surface);
                border-color: #b9c8d8;
            }
            details summary {
                border-radius: 8px;
                font-weight: 700;
                padding: 1rem 1.25rem;
            }
            details[open] summary {
                border-bottom: 1px solid var(--fb-border);
                margin-bottom: 1rem;
            }
            details > :not(summary) {
                margin-left: 1.25rem;
                margin-right: 1.25rem;
            }
            details > :last-child {
                margin-bottom: 1.25rem;
            }
            fieldset {
                margin-bottom: 0;
            }
            input:not([type="checkbox"]):not([type="radio"]) {
                background-color: #fff;
            }
            .choice-row {
                align-items: flex-start;
                display: flex;
                gap: 0.75rem;
                margin-bottom: 0.5rem;
            }
            .choice-row input[type="checkbox"] {
                flex: 0 0 auto;
                margin-top: 0.15rem;
            }
            .choice-row label {
                cursor: pointer;
                margin-bottom: 0;
            }
            .choice-help {
                color: var(--fb-muted);
                display: block;
                margin-left: calc(1.75rem + 0.75rem);
            }
            .requirements-table-wrapper {
                max-width: calc(100% - 2.5rem);
                overflow-x: auto;
            }
            table {
                font-size: 0.95rem;
            }
            .installer-actions {
                align-items: center;
                display: flex;
                gap: 0.75rem;
                justify-content: flex-end;
                margin-top: 1.5rem;
            }
            .installer-actions button {
                margin-bottom: 0;
                min-width: 8rem;
                width: auto;
            }
            .installer-actions .secondary {
                margin-right: auto;
            }
            .installer-note {
                color: var(--fb-muted);
                margin: 0.75rem 0 0;
                text-align: right;
            }
            .result-actions {
                display: grid;
                gap: 1rem;
                grid-template-columns: repeat(auto-fit, minmax(12rem, 1fr));
                margin-top: 1.5rem;
            }
            .result-actions a {
                width: 100%;
            }
            .success-list {
                counter-reset: success-step;
                list-style: none;
                padding-left: 0;
            }
            .success-list > li {
                border-top: 1px solid var(--fb-border);
                counter-increment: success-step;
                padding: 1.25rem 0;
            }
            .success-list > li::before {
                color: var(--fb-brand);
                content: counter(success-step) ". ";
                font-weight: 700;
            }
            .success-list h3 {
                display: inline;
            }
            .success-list pre {
                margin-top: 0.75rem;
            }
            @media (max-width: 640px) {
                body > main.container {
                    padding-top: 1rem;
                }
                .installer-panel {
                    border-radius: 0;
                    margin-left: calc(var(--block-spacing-horizontal) * -1);
                    margin-right: calc(var(--block-spacing-horizontal) * -1);
                }
                nav.installer-nav {
                    align-items: flex-start;
                }
                .installer-actions {
                    align-items: stretch;
                    flex-direction: column;
                }
                .installer-actions .secondary {
                    margin-right: 0;
                }
                .installer-actions button {
                    width: 100%;
                }
                .installer-note {
                    text-align: left;
                }
            }
            hr {
                margin-bottom: 2rem;
            }
        </style>
    </head>
    <body>
        <main class="container">
            <nav class="installer-nav">
                <ul>
                    <li>
                    <a href="{{ constant('URL_INSTALL') }}" title="FOSSBilling">
                        <picture>
                            <!-- User prefers light mode: -->
                            <source srcset="../public/branding/logo.svg" media="(prefers-color-scheme: light)" alt="FOSSBilling logo" height="50px" width="238"/>

                            <!-- User prefers dark mode: -->
                            <source srcset="../public/branding/logo-dark.svg"  media="(prefers-color-scheme: dark)" alt="FOSSBilling logo" height="50px" width="238"/>

                            <!-- Fallback / no preference -->
                            <img src="../public/branding/logo.svg" alt="FOSSBilling logo" height="50px" width="238"/>
                        </picture>
                    </a></li>
                </ul>
                <ul>
                    <li><a href="https://docs.fossbilling.org/" target="_blank" data-tooltip="Opens in a new window.">Documentation</a></li>
                    <li><a href="https://github.com/FOSSBilling/FOSSBilling/issues" target="_blank" data-tooltip="Opens in a new window.">Bug Reports</a></li>
                </ul>
            </nav>
            <section class="installer-panel">
                {% block page %}{% endblock %}
            </section>
        </main>
        <footer class="container">
            <small>
                <span>&copy; Copyright {{ now|date('Y') }}. All rights reserved. Powered by <a href="https://fossbilling.org" title="FOSSBilling" target="_blank" data-tooltip="Opens in a new tab.">FOSSBilling {{version}}</a></span>
            </small>
        </footer>
        {% block javascript %}{% endblock %}
    </body>
</html>
