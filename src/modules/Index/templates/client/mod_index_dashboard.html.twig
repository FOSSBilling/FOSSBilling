{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}
{% set active_menu = 'dashboard' %}

{% block meta_title %}{{ 'Client Area'|trans }}{% endblock %}
{% block page_header %}{{ 'Dashboard'|trans }}{% endblock %}

{% block body_class %}dashboard{% endblock %}
{% block breadcrumbs %}
    {% if not settings.hide_dashboard_breadcrumb %}
        <ul class="breadcrumb">
            <li><a href="{{ '/'|url }}">{{ 'Home'|trans }}</a> <span class="dropdown-divider">/</span></li>
            <li class="active">{{ 'Dashboard'|trans }}</li>
        </ul>
    {% endif %}
{% endblock %}

{% import "macro_functions.html.twig" as mf %}
{% import _self as tn %}

{% macro badge(status, type) %}
    {% set s = status|lower %}
    {% if type == 'order' %}
        {% if s == 'active' or s == 'pending_registrar' %}
            {% set variant, label = 'success', 'Active' %}
        {% elseif s == 'pending_setup' %}
            {% set variant, label = 'warning', 'Pending' %}
        {% elseif s in ['suspended', 'failed_setup', 'failed_renew'] %}
            {% set variant, label = 'danger', 'Action needed' %}
        {% elseif s == 'canceled' %}
            {% set variant, label = 'neutral', 'Canceled' %}
        {% else %}
            {% set variant, label = 'neutral', status|title %}
        {% endif %}
    {% else %}
        {% if s == 'paid' %}
            {% set variant, label = 'success', 'Paid' %}
        {% elseif s == 'unpaid' %}
            {% set variant, label = 'warning', 'Unpaid' %}
        {% elseif s == 'refunded' %}
            {% set variant, label = 'info', 'Refunded' %}
        {% else %}
            {% set variant, label = 'neutral', status|title %}
        {% endif %}
    {% endif %}
    <span class="tn-badge tn-badge--{{ variant }}">{{ label|trans }}</span>
{% endmacro %}

{% block content %}
    {{ render_widgets('client.index.dashboard.content.before') }}

    {% if settings.showcase_enabled %}
        <div class="alert alert-info" role="alert">
            <p>{{ (settings.showcase_text ?? '')|markdown_to_html }}</p>

            {% if (settings.showcase_button_url) and (settings.showcase_button_title) %}
                <a class="btn btn-sm btn-primary btn-large"
                   href="{{ settings.showcase_button_url }}">{{ settings.showcase_button_title }}</a>
            {% endif %}
        </div>
    {% endif %}

    {% if client %}
        {% set dashboard = client.index_get_dashboard %}
        {% set profile = dashboard.profile %}

        {{ render_widgets('client.index.dashboard.client.before', { 'dashboard': dashboard, 'profile': profile }) }}

        {% if dashboard.tickets.on_hold > 0 %}
            <div class="row">
                <div class="col-md-12">
                    {% for ticket in dashboard.recent_tickets %}
                        {% if ticket.status == 'on_hold' %}
                            <div class="alert alert-info d-flex justify-content-between" role="alert">
                                <span>Ticket <strong>#{{ ticket.id }}</strong> was replied to {{ ticket.updated_at|timeago }} {{ 'ago'|trans }}.</span>
                                <a href='{{ "support/ticket/#{ticket.id}"|url }}'
                                   class="alert-link">{{ 'Reply'|trans }}</a>
                            </div>
                        {% endif %}
                    {% endfor %}
                </div>
            </div>
        {% endif %}

        {# Real client-owned data, fetched directly from the client API for the
           pieces the shared dashboard payload doesn't already cover (unpaid
           invoice totals, expiring orders, active services list). #}
        {% set unpaid_invoices = client.invoice_get_list({ 'status': 'unpaid', 'per_page': 100 }) %}
        {% set expiring_orders = client.order_get_list({ 'expiring': true, 'per_page': 10 }) %}
        {% set active_services = client.order_get_list({ 'status': 'active', 'per_page': 50 }) %}
        {% set recent_invoices = client.invoice_get_list({ 'per_page': 3 }) %}

        {% set amount_due = 0 %}
        {% set soonest_days = null %}
        {% set soonest_title = null %}
        {% set soonest_expires = null %}
        {% set hosting_count = 0 %}
        {% set domain_count = 0 %}
        {% set other_count = 0 %}
        {% for invoice in unpaid_invoices.list %}
            {% set amount_due = amount_due + invoice.total %}
        {% endfor %}
        {% for order in active_services.list %}
            {% if order.service_type == 'hosting' %}
                {% set hosting_count = hosting_count + 1 %}
            {% elseif order.service_type == 'domain' %}
                {% set domain_count = domain_count + 1 %}
            {% else %}
                {% set other_count = other_count + 1 %}
            {% endif %}
            {% if order.expires_at %}
                {% set days_left = ((order.expires_at|date('U')) - ('now'|date('U'))) // 86400 %}
                {% if days_left >= 0 and (soonest_days is null or days_left < soonest_days) %}
                    {% set soonest_days = days_left %}
                    {% set soonest_title = order.title %}
                    {% set soonest_expires = order.expires_at %}
                {% endif %}
            {% endif %}
        {% endfor %}

        {% set services_parts = [] %}
        {% if hosting_count > 0 %}{% set services_parts = services_parts|merge([hosting_count ~ ' hosting']) %}{% endif %}
        {% if domain_count > 0 %}{% set services_parts = services_parts|merge([domain_count ~ ' domain' ~ (domain_count > 1 ? 's' : '')]) %}{% endif %}
        {% if other_count > 0 %}{% set services_parts = services_parts|merge([other_count ~ ' other']) %}{% endif %}

        {% set unpaid_count = unpaid_invoices.list|length %}
        {% set expiring_count = expiring_orders.list|length %}
        {% set attention_count = unpaid_count + expiring_count %}

        {% set soonest_due = null %}
        {% for invoice in unpaid_invoices.list %}
            {% if invoice.due_at and (soonest_due is null or invoice.due_at < soonest_due) %}
                {% set soonest_due = invoice.due_at %}
            {% endif %}
        {% endfor %}

        {# ---------------------------------------------------------------
           Header
        --------------------------------------------------------------- #}
        <div class="tn-dashboard-header">
            <div>
                <h1 class="tn-dashboard-header__title">{{ 'Good morning, %first_name%'|trans({'%first_name%': profile.first_name}) }}</h1>
                <p class="tn-dashboard-header__sub">
                    {% if attention_count == 0 %}
                        {{ 'Everything is running smoothly.'|trans }}
                    {% elseif attention_count == 1 %}
                        {{ 'One thing needs your attention this week — everything else is running.'|trans }}
                    {% else %}
                        {{ '%count% things need your attention this week — everything else is running.'|trans({'%count%': attention_count}) }}
                    {% endif %}
                </p>
            </div>
            <div class="tn-dashboard-header__actions">
                <a class="tn-btn tn-btn--ghost tn-btn--sm" href="{{ 'support'|url(query: { 'ticket': 1 }) }}">
                    <svg class="icon"><use href="#lifebuoy" /></svg>{{ 'New ticket'|trans }}
                </a>
                <a class="tn-btn tn-btn--secondary tn-btn--sm" href="{{ 'client/balance'|url }}">
                    <svg class="icon"><use href="#wallet" /></svg>{{ 'Add funds'|trans }}
                </a>
                <a class="tn-btn tn-btn--primary tn-btn--sm" href="{{ 'order'|url }}">
                    <svg class="icon"><use href="#plus" /></svg>{{ 'Add a service'|trans }}
                </a>
            </div>
        </div>

        {# ---------------------------------------------------------------
           KPI strip
        --------------------------------------------------------------- #}
        <div class="tn-kpi-grid">
            <div class="tn-stat">
                <span class="tn-stat__label">{{ 'Active services'|trans }}</span>
                <span class="tn-stat__value">{{ dashboard.orders.active }}</span>
                {% if services_parts %}
                    <span class="tn-stat__sub">{{ services_parts|join(' · ') }}</span>
                {% endif %}
            </div>

            <div class="tn-stat">
                <span class="tn-stat__label">{{ 'Amount due'|trans }}</span>
                {% if unpaid_count > 0 %}
                    <span class="tn-stat__value tn-stat__value--accent">{{ amount_due|format_currency(profile.currency ?? '') }}</span>
                    <span class="tn-stat__sub">
                        {{ unpaid_count }} {{ 'unpaid invoice(s)'|trans }}{% if soonest_due %} · {{ 'due'|trans }} {{ soonest_due|format_date }}{% endif %}
                    </span>
                {% else %}
                    <span class="tn-stat__value tn-stat__value--accent">{{ 0|format_currency(profile.currency ?? '') }}</span>
                {% endif %}
            </div>

            <div class="tn-stat">
                <span class="tn-stat__label">{{ 'Next renewal'|trans }}</span>
                {% if soonest_days is null %}
                    <span class="tn-stat__value">&mdash;</span>
                {% elseif soonest_days == 0 %}
                    <span class="tn-stat__value">{{ 'Today'|trans }}</span>
                {% else %}
                    <span class="tn-stat__value">{{ soonest_days }} {{ 'days'|trans }}</span>
                    <span class="tn-stat__sub">{{ soonest_title|truncate(28) }} · {{ soonest_expires|format_date }}</span>
                {% endif %}
            </div>

            <div class="tn-stat">
                <span class="tn-stat__label">{{ 'Account balance'|trans }}</span>
                {% if profile.currency is not null %}
                    <span class="tn-stat__value">{{ profile.balance|format_currency(profile.currency) }}</span>
                    <span class="tn-stat__sub">{{ 'Auto-applies at checkout'|trans }}</span>
                {% else %}
                    <span class="tn-stat__value">&mdash;</span>
                {% endif %}
            </div>
        </div>

        <div class="tn-dashboard-body">
            <div class="tn-dashboard-body__main">
                {# -----------------------------------------------------------
                   Needs attention
                ----------------------------------------------------------- #}
                {% if attention_count > 0 %}
                    <div class="tn-card tn-card--compact mb-4">
                        <div class="tn-card__header">
                            <span class="tn-card__title">{{ 'Needs attention'|trans }}</span>
                            <span class="tn-badge tn-badge--warning">{{ attention_count }}</span>
                        </div>
                        <div>
                            {% for invoice in unpaid_invoices.list|slice(0, 5) %}
                                <div class="tn-attention-row">
                                    <span class="tn-attention-row__icon tn-attention-row__icon--warning">
                                        <svg class="icon"><use href="#receipt" /></svg>
                                    </span>
                                    <div class="tn-attention-row__body">
                                        <span class="tn-attention-row__title">{{ 'Invoice'|trans }} #{{ invoice.serie_nr ?? invoice.nr }}</span>
                                        <span class="tn-attention-row__sub">
                                            {{ invoice.total|format_currency(invoice.currency) }}
                                            {% if invoice.due_at %} · {{ 'due'|trans }} {{ invoice.due_at|format_date }}{% endif %}
                                        </span>
                                    </div>
                                    <a class="tn-btn tn-btn--secondary tn-btn--sm" href='{{ "invoice/#{invoice.hash}"|url }}'>{{ 'Pay now'|trans }}</a>
                                </div>
                            {% endfor %}

                            {% for order in expiring_orders.list|slice(0, 5) %}
                                <div class="tn-attention-row">
                                    <span class="tn-attention-row__icon tn-attention-row__icon--danger">
                                        <svg class="icon"><use href="#alert-triangle" /></svg>
                                    </span>
                                    <div class="tn-attention-row__body">
                                        <span class="tn-attention-row__title">{{ order.title|truncate(45) }}</span>
                                        <span class="tn-attention-row__sub">
                                            {% if order.expires_at %}
                                                {{ 'Expires'|trans }} {{ order.expires_at|format_date }}
                                            {% else %}
                                                {{ 'Expires soon'|trans }}
                                            {% endif %}
                                        </span>
                                    </div>
                                    <a class="tn-btn tn-btn--secondary tn-btn--sm" href='{{ "order/service/manage/#{order.id}"|url }}'>
                                        {{ 'Renew'|trans }} · {{ (order.renewal_price ?? order.total)|format_currency(order.currency) }}
                                    </a>
                                </div>
                            {% endfor %}
                        </div>
                    </div>
                {% else %}
                    <div class="tn-card tn-card--compact mb-4">
                        <div class="d-flex align-items-center gap-2">
                            <svg class="icon text-success"><use href="#circle-check" /></svg>
                            <span>{{ 'You\'re all caught up - no unpaid invoices or services expiring soon.'|trans }}</span>
                        </div>
                    </div>
                {% endif %}

                {# -----------------------------------------------------------
                   Your services
                ----------------------------------------------------------- #}
                <div class="tn-card tn-card--compact mb-4">
                    <div class="tn-card__header">
                        <span class="tn-card__title">{{ 'Your services'|trans }}</span>
                        <a class="tn-btn tn-btn--ghost tn-btn--sm" href="{{ 'order/service'|url }}">
                            {{ 'All services'|trans }}<svg class="icon"><use href="#arrow-right" /></svg>
                        </a>
                    </div>
                    <div>
                        {% if active_services.list %}
                            {% for order in active_services.list|slice(0, 5) %}
                                {% set is_expiring = order.expires_at and ((order.expires_at|date('U')) - ('now'|date('U'))) // 86400 <= 7 %}
                                <a href='{{ "order/service/manage/#{order.id}"|url }}' class="tn-row-hover tn-service-row">
                                    <span class="tn-service-row__icon">
                                        {% if order.service_type == 'domain' %}
                                            <svg class="icon"><use href="#globe" /></svg>
                                        {% elseif order.service_type == 'hosting' %}
                                            <svg class="icon"><use href="#server" /></svg>
                                        {% else %}
                                            <svg class="icon"><use href="#briefcase" /></svg>
                                        {% endif %}
                                    </span>
                                    <div class="tn-service-row__body">
                                        <span class="tn-service-row__name">{{ order.title|truncate(50) }}</span>
                                        <span class="tn-service-row__detail">{{ order.service_type|title }}</span>
                                    </div>
                                    <span class="tn-service-row__meta">
                                        <span class="tn-service-row__meta-top">
                                            {% if order.expires_at %}
                                                <span class="tn-service-row__date{% if is_expiring %} tn-service-row__date--danger{% endif %}">{{ order.expires_at|format_date }}</span>
                                            {% endif %}
                                            <span class="tn-service-row__status">{{ tn.badge(order.status, 'order') }}</span>
                                            {% if order.status == 'pending_registrar' %}
                                                <svg class="icon tn-service-row__pending-icon" title="{{ 'Waiting on registrar confirmation'|trans }}"><use href="#clock" /></svg>
                                            {% endif %}
                                        </span>
                                        <span class="tn-service-row__price">{{ (order.renewal_price ?? order.total)|format_currency(order.currency) }}</span>
                                    </span>
                                    <svg class="icon tn-service-row__chevron"><use href="#chevron-right" /></svg>
                                </a>
                            {% endfor %}
                        {% else %}
                            <div class="d-flex justify-content-center my-2 p-4">
                                <span class="m-0 text-secondary">{{ 'No active services yet'|trans }}</span>
                            </div>
                        {% endif %}
                    </div>
                </div>
            </div>

            <div class="tn-dashboard-body__rail">
                {# -----------------------------------------------------------
                   Recent invoices
                ----------------------------------------------------------- #}
                <div class="tn-card tn-card--compact mb-4">
                    <div class="tn-card__header">
                        <span class="tn-card__title">{{ 'Recent invoices'|trans }}</span>
                        <a class="tn-btn tn-btn--ghost tn-btn--sm" href="{{ 'invoice'|url }}">
                            {{ 'All'|trans }}<svg class="icon"><use href="#arrow-right" /></svg>
                        </a>
                    </div>
                    <div>
                        {% if recent_invoices.list %}
                            {% for invoice in recent_invoices.list %}
                                <a href='{{ "invoice/#{invoice.hash}"|url }}'
                                   class="tn-row-hover d-flex justify-content-between align-items-center px-3 py-2 text-decoration-none text-reset">
                                    <div class="min-width-0">
                                        <div class="fw-bold" style="font-family: var(--font-mono);">#{{ invoice.serie_nr ?? invoice.nr }}</div>
                                        <span class="text-secondary small">
                                            {% if invoice.status == 'paid' %}
                                                {{ 'Paid'|trans }} {{ invoice.paid_at ? invoice.paid_at|format_date : invoice.updated_at|format_date }}
                                            {% elseif invoice.due_at %}
                                                {{ 'Due'|trans }} {{ invoice.due_at|format_date }}
                                            {% else %}
                                                {{ invoice.created_at|format_date }}
                                            {% endif %}
                                        </span>
                                    </div>
                                    <div class="text-end flex-shrink-0 ms-2">
                                        <div>{{ invoice.total|format_currency(invoice.currency) }}</div>
                                        {{ tn.badge(invoice.status, 'invoice') }}
                                    </div>
                                </a>
                            {% endfor %}
                        {% else %}
                            <div class="d-flex justify-content-center my-2 p-4">
                                <span class="m-0 text-secondary">{{ 'No invoices yet'|trans }}</span>
                            </div>
                        {% endif %}
                    </div>
                </div>

                {# -----------------------------------------------------------
                   Support snapshot
                ----------------------------------------------------------- #}
                {% set open_ticket = null %}
                {% for ticket in dashboard.recent_tickets %}
                    {% if open_ticket is null and ticket.status == 'open' %}
                        {% set open_ticket = ticket %}
                    {% endif %}
                {% endfor %}

                <div class="tn-card tn-card--compact mb-4">
                    <div class="tn-card__header">
                        <span class="tn-card__title">{{ 'Support'|trans }}</span>
                    </div>
                    {% if open_ticket %}
                        <div class="d-flex align-items-start gap-2">
                            <span class="tn-dot tn-dot--info mt-1"></span>
                            <div class="flex-grow-1 min-width-0">
                                <div class="fw-bold small text-truncate">{{ open_ticket.subject|truncate(40) }}</div>
                                <span class="text-secondary small">#{{ open_ticket.id }} · {{ 'replied'|trans }} {{ open_ticket.updated_at|timeago }} {{ 'ago'|trans }}</span>
                            </div>
                            <span class="tn-badge tn-badge--info">{{ 'Open'|trans }}</span>
                        </div>
                    {% else %}
                        <span class="text-secondary small">{{ 'No open tickets'|trans }}</span>
                    {% endif %}
                </div>
            </div>
        </div>

        {{ render_widgets('client.index.dashboard.client.after', { 'dashboard': dashboard, 'profile': profile }) }}
    {% else %}
        {{ render_widgets('client.index.dashboard.guest.before') }}

        {# ---------------------------------------------------------------
           Logged-out home: a front door, not a card grid. Welcome + one
           clear sign-in path (with optional Microsoft SSO), plus three
           purposeful quick paths and the latest announcements inline.
        --------------------------------------------------------------- #}
        {% set news_on = guest.extension_is_on({"mod":"news"}) %}
        {% set kb_on = guest.support_kb_enabled() %}
        {% set latest_news = news_on ? guest.news_get_list({ 'per_page': 2 }).list : [] %}

        {# Domain quick-search: reuses the same guest TLD list and
           servicedomain/check API as the standalone domain-checker embed,
           and hands off to the real order flow via the domain product id
           (same pattern mod_orderbutton_choose_product.html.twig uses to
           find its "domain" category). UAE-first ordering since .ae/.com
           are the primary market here, not .co.za. #}
        {% set all_tlds = guest.servicedomain_tlds %}
        {% set priority_tlds = [] %}
        {% set other_tlds = [] %}
        {% for t in all_tlds %}
            {% if t.tld in ['.ae', '.com'] %}
                {% set priority_tlds = priority_tlds|merge([t]) %}
            {% else %}
                {% set other_tlds = other_tlds|merge([t]) %}
            {% endif %}
        {% endfor %}
        {% set ordered_tlds = (priority_tlds|sort((a, b) => a.tld == '.ae' ? -1 : 1))|merge(other_tlds) %}
        {% set domain_categories = guest.product_category_get_list.list %}
        {% set domain_category = null %}
        {% for cat in domain_categories %}
            {% for p in cat.products %}
                {% if p.type == 'domain' and domain_category is null %}{% set domain_category = cat %}{% endif %}
            {% endfor %}
        {% endfor %}
        {% set domain_product_id = domain_category and domain_category.products|first ? domain_category.products|first.id : null %}

        <div class="tn-home tn-home--photo">
            <div class="tn-home__bg" aria-hidden="true">
                <img src="https://images.unsplash.com/photo-1512632578888-169bbbc64f33?q=80&amp;w=1920&amp;auto=format&amp;fit=crop" alt="" loading="eager">
                <div class="tn-home__bg-grade"></div>
                <div class="tn-home__bg-grain"></div>
            </div>

            <div class="tn-home__grid">
                {# left — welcome + quick paths #}
                <div class="tn-home__intro">
                    <div class="tn-home__hero">
                        <span class="tn-eyebrow">{{ 'Client portal'|trans }}</span>
                        <h1 class="tn-home__title">{{ 'Run your domains and hosting from one login.'|trans }}</h1>
                        <div class="tn-home__typer" aria-hidden="true">
                            <span id="tn-home-typer"></span><span class="tn-home__typer-caret"></span>
                        </div>
                        <p class="tn-home__lede">
                            {{ 'Track every domain, invoice and hosting plan in one place, with renewal reminders before anything lapses.'|trans }}
                        </p>
                    </div>

                    {% if domain_product_id %}
                        <div class="tn-domainsearch" id="tn-domainsearch">
                            <div class="tn-domainsearch__row">
                                <input type="text" id="tn-domainsearch-sld" class="tn-domainsearch__input" placeholder="{{ 'yourbusiness'|trans }}" autocomplete="off">
                                <select id="tn-domainsearch-tld" class="tn-domainsearch__tld">
                                    {% for t in ordered_tlds %}
                                        <option value="{{ t.tld }}">{{ t.tld }}</option>
                                    {% endfor %}
                                </select>
                                <button type="button" id="tn-domainsearch-submit" class="tn-domainsearch__btn">{{ 'Search'|trans }}</button>
                            </div>
                            <div id="tn-domainsearch-result" class="tn-domainsearch__result"></div>
                        </div>
                    {% endif %}

                    <div class="tn-home__cards">
                        <a class="tn-card-link" href="{{ 'order'|url }}">
                            <span class="tn-card-link__icon"><svg class="icon"><use href="#shopping-bag" /></svg></span>
                            <span class="tn-card-link__title">{{ 'Browse the store'|trans }}</span>
                            <span class="tn-card-link__sub">{{ 'Domains, hosting plans and Microsoft 365 seats.'|trans }}</span>
                            <span class="tn-card-link__cta">{{ 'Go to store'|trans }}<svg class="icon"><use href="#arrow-right" /></svg></span>
                        </a>
                        {% if kb_on %}
                            <a class="tn-card-link" href="{{ 'support/kb'|url }}">
                                <span class="tn-card-link__icon"><svg class="icon"><use href="#book" /></svg></span>
                                <span class="tn-card-link__title">{{ 'Knowledge base'|trans }}</span>
                                <span class="tn-card-link__sub">{{ 'Setup guides, DNS how-tos and billing answers.'|trans }}</span>
                                <span class="tn-card-link__cta">{{ 'Find answers'|trans }}<svg class="icon"><use href="#arrow-right" /></svg></span>
                            </a>
                        {% endif %}
                        {% if news_on %}
                            <a class="tn-card-link" href="{{ 'news'|url }}">
                                <span class="tn-card-link__icon"><svg class="icon"><use href="#news" /></svg></span>
                                <span class="tn-card-link__title">{{ 'Announcements'|trans }}</span>
                                <span class="tn-card-link__sub">{{ 'Maintenance windows and product updates.'|trans }}</span>
                                <span class="tn-card-link__cta">{{ 'Latest news'|trans }}<svg class="icon"><use href="#arrow-right" /></svg></span>
                            </a>
                        {% endif %}
                    </div>

                    {% if latest_news %}
                        <div class="tn-home__news">
                            {% for post in latest_news %}
                                <a class="tn-rowhover tn-home__news-row" href='{{ "news/#{post.slug}"|url }}'>
                                    <span class="tn-home__news-date">{{ post.created_at|date('d M') }}</span>
                                    <span class="tn-home__news-title">{{ post.title|truncate(72) }}</span>
                                    <svg class="icon"><use href="#chevron-right" /></svg>
                                </a>
                            {% endfor %}
                        </div>
                    {% endif %}
                </div>

                {# right — sign in card #}
                <div class="tn-home__aside">
                    <div class="tn-signin">
                        <div class="tn-signin__head">
                            <h2 class="tn-signin__title">{{ 'Sign in'|trans }}</h2>
                            <p class="tn-signin__sub">{{ 'Manage services, invoices and support tickets.'|trans }}</p>
                        </div>
                        <form method="post" action="{{ 'client/login'|api_url(role: 'guest') }}" class="auth tn-signin__form" {{ fb_api_form({redirect: '/'|url(query: {'welcome': 1, '_': 'now'|date('U')})}) }}>
                            <div class="tn-field">
                                <label class="tn-field__label" for="tn-home-email">{{ 'Email'|trans }}</label>
                                <input class="tn-input" id="tn-home-email" type="email" name="email" placeholder="you@company.com" value="{{ request.email }}" required="required">
                            </div>
                            <div class="tn-field">
                                <label class="tn-field__label" for="tn-home-password">{{ 'Password'|trans }}</label>
                                <input class="tn-input" id="tn-home-password" type="password" name="password" placeholder="••••••••••" required="required">
                            </div>
                            <div class="tn-signin__meta">
                                {% if settings.show_password_reset_link %}
                                    <a class="tn-signin__forgot" href="{{ 'password-reset'|url }}">{{ 'Forgot password?'|trans }}</a>
                                {% endif %}
                            </div>
                            <button type="submit" class="tn-btn tn-btn--primary tn-btn--lg tn-btn--block">{{ 'Sign in'|trans }}</button>
                        </form>

                        {% if settings.microsoft_sso_url|default('') %}
                            <div class="tn-signin__divider"><span>{{ 'or'|trans }}</span></div>
                            <a class="tn-btn tn-btn--secondary tn-btn--block" href="{{ settings.microsoft_sso_url }}">
                                <svg class="icon"><use href="#layout-grid" /></svg>{{ 'Continue with Microsoft'|trans }}
                            </a>
                        {% endif %}

                        {% if settings.show_signup_link %}
                            <p class="tn-signin__signup">
                                {{ 'New here?'|trans }}
                                <a href="{{ 'signup'|url }}">{{ 'Create an account'|trans }}</a>, {{ 'it takes a minute.'|trans }}
                            </p>
                        {% endif %}
                    </div>
                </div>
            </div>
        </div>

        {% if domain_product_id %}
            {% autoescape "js" %}
            <script>
                (function () {
                    var words = ['dubaiventures.ae', 'gulftrading.com', 'yourstartup.ae', 'emiratesbrand.com', 'nextbigidea.ae'];
                    var el = document.getElementById('tn-home-typer');
                    var reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
                    if (el) {
                        if (reduce) {
                            el.textContent = words[0];
                        } else {
                            var wi = 0, ci = 0, deleting = false;
                            (function tick() {
                                var word = words[wi];
                                if (!deleting) {
                                    ci++;
                                    el.textContent = word.slice(0, ci);
                                    if (ci === word.length) { deleting = true; setTimeout(tick, 1600); return; }
                                    setTimeout(tick, 70);
                                } else {
                                    ci--;
                                    el.textContent = word.slice(0, ci);
                                    if (ci === 0) { deleting = false; wi = (wi + 1) % words.length; setTimeout(tick, 300); return; }
                                    setTimeout(tick, 35);
                                }
                            })();
                        }
                    }

                    var sld = document.getElementById('tn-domainsearch-sld');
                    var tld = document.getElementById('tn-domainsearch-tld');
                    var btn = document.getElementById('tn-domainsearch-submit');
                    var result = document.getElementById('tn-domainsearch-result');
                    if (!sld || !btn) return;

                    function runCheck() {
                        var value = sld.value.trim();
                        if (!value) return;
                        result.className = 'tn-domainsearch__result tn-domainsearch__result--loading';
                        result.textContent = '{{ 'Checking...'|trans }}';

                        var params = new URLSearchParams();
                        params.append('sld', value);
                        params.append('tld', tld.value);

                        fetch('{{ 'servicedomain/check'|api_url(role: 'guest') }}', {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                            body: params.toString()
                        })
                        .then(function (r) { return r.json().then(function (json) { return { ok: r.ok, json: json }; }); })
                        .then(function (res) {
                            if (res.ok && res.json.result === true) {
                                result.className = 'tn-domainsearch__result tn-domainsearch__result--available';
                                result.innerHTML = value + tld.value + ' {{ 'is available.'|trans }} <a href="{{ 'order'|url(query: {'product': domain_product_id}) }}">{{ 'Register it'|trans }} &rarr;</a>';
                            } else {
                                var msg = (res.json.error && res.json.error.message) || (value + tld.value + ' {{ 'is already taken.'|trans }}');
                                result.className = 'tn-domainsearch__result tn-domainsearch__result--taken';
                                result.textContent = msg;
                            }
                        })
                        .catch(function () {
                            result.className = 'tn-domainsearch__result tn-domainsearch__result--taken';
                            result.textContent = '{{ 'Could not check that domain right now.'|trans }}';
                        });
                    }

                    btn.addEventListener('click', runCheck);
                    sld.addEventListener('keydown', function (e) { if (e.key === 'Enter') { e.preventDefault(); runCheck(); } });
                })();
            </script>
            {% endautoescape %}
        {% endif %}

        {{ render_widgets('client.index.dashboard.guest.after') }}
    {% endif %}

    {{ render_widgets('client.index.dashboard.content.after') }}
{% endblock %}
