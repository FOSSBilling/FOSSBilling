{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}

{% import "macro_functions.html.twig" as mf %}

{% block meta_title %}{{ 'Notifications Center'|trans }}{% endblock %}

{% set active_menu = 'activity' %}

{% block content %}
<div class="card">
    <div class="card-header">
        <div>
            <h3 class="card-title">{{ 'Notifications Center'|trans }}</h3>
            <p class="card-subtitle">{{ 'Review system notifications and create internal notes or reminders for staff.'|trans }}</p>
        </div>
    </div>
    <div class="card-body pt-3 pb-0 px-0">
        <div class="card border-0 shadow-none rounded-0">
            <div class="card-header bg-transparent px-3 pt-0 pb-3 border-0">
                <ul class="nav nav-pills card-header-pills" role="tablist">
                    <li class="nav-item" role="presentation">
                        <a class="nav-link active" href="#tab-index" data-bs-toggle="tab" role="tab">{{ 'Notifications'|trans }}</a>
                    </li>
                    <li class="nav-item" role="presentation">
                        <a class="nav-link" href="#tab-new-note" data-bs-toggle="tab" role="tab">
                            <svg class="icon me-2">
                                <use xlink:href="#plus" />
                            </svg>
                            {{ 'New note'|trans }}
                        </a>
                    </li>
                </ul>
            </div>
    <div class="tab-content border-top">
        <div class="tab-pane fade show active" id="tab-index" role="tabpanel">
            {{ include('partial_search.html.twig') }}
            <div class="table-responsive">
                <table class="table card-table table-vcenter table-striped text-nowrap">
                    <thead>
                        <tr>
                            <th>{{ 'Message'|trans }}</th>
                            <th>{{ 'Date'|trans }}</th>
                            <th class="w-1"></th>
                        </tr>
                    </thead>
                    <tbody>
                    {% set events = admin.notification_get_list({ "per_page": 10, "page": request.page }|merge(request)) %}
                    {% for i, event in events.list %}
                        <tr>
                            <td>{{ event.meta_value|raw }}</td>
                            <td>{{ event.created_at|date('Y-m-d H:i') }}</td>
                            <td>
                                <a class="btn btn-icon" href="{{ 'notification/delete'|api_url(query: { 'id': event.id }) }}"
                                    {{ fb_api_link({modal: {type: 'confirm', title: 'Are you sure?'|trans}, redirect: 'notification'|url}) }}>
                                    <svg class="icon">
                                        <use xlink:href="#delete" />
                                    </svg>
                                </a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td class="text-muted" colspan="7">{{ 'The list is empty'|trans }}</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </div>
            {{ include('partial_pagination.html.twig', { 'list': events, 'url':'notification' }) }}

            <div class="card-footer d-flex align-items-center justify-content-between">
                <a class="btn btn-danger" href="{{ 'notification/delete_all'|api_url }}"
                    {{ fb_api_link({modal: {type: 'confirm', title: 'Are you sure?'|trans}, reload: true}) }}>
                    <svg class="icon">
                        <use xlink:href="#delete"></use>
                    </svg>
                    {{ 'Delete all'|trans }}
                </a>
            </div>
        </div>


        <div class="tab-pane fade" id="tab-new-note" role="tabpanel">
            <div class="card-body">
                <form method="post" action="{{ 'notification/add'|api_url }}" {{ fb_api_form({reload: true}) }}>
                    <div class="mb-3 row">
                        <label class="form-label col-3 col-form-label">{{ 'Note'|trans }}:</label>
                        <div class="col">
                            <textarea class="form-control" name="message" rows="5" rows="10" placeholder="{{ 'Add note or todo task'|trans }}" required></textarea>
                        </div>
                    </div>
                    <input type="submit" value="{{ 'Add note'|trans }}" class="btn btn-primary">
                </form>
            </div>
        </div>
    </div>
        </div>
    </div>
</div>
{% endblock %}
