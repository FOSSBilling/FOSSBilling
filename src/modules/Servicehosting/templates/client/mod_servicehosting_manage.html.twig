{% if order.status == 'active' %}
{% set server = service.server %}
{% set hp = service.hosting_plan %}
<div class="tn-card mb-4">
    <div class="d-flex justify-content-between align-items-start flex-wrap mb-3" style="gap: var(--space-3);">
        <div>
            <div class="d-flex align-items-center flex-wrap" style="gap: var(--space-2);">
                <h1 class="mb-0 font-mono" style="font-size: var(--fs-h3);">{{ service.domain }}</h1>
                {{ mf.status_badge(order.status, 'order') }}
            </div>
            <span class="small text-muted">
                {{ hp.name }}
                {% if server.hostname %} &middot; {{ server.hostname }}{% endif %}
                {% if order.expires_at %} &middot; {{ 'renews'|trans }} {{ order.expires_at|format_date }} {{ 'at'|trans }} {{ order.total|format_currency(order.currency ?? default_currency) }}{% endif %}
            </span>
        </div>
        <div class="d-flex align-items-center flex-shrink-0" style="gap: var(--space-2);">
            <a class="tn-btn tn-btn--ghost tn-btn--sm" target="_blank" href="http://{{ service.domain }}">
                {{ 'Open site'|trans }}
                <svg class="icon"><use href="#arrow-up-right" /></svg>
            </a>
            <a class="tn-btn tn-btn--secondary tn-btn--sm" href="{{ 'servicehosting/get_login_url'|api_url(query: { 'order_id': order.id }) }}" {{ fb_api_link({callback: 'onAfterLoginLinkCreated'}) }}>
                <svg class="icon"><use href="#key-round" /></svg>
                {{ 'Control panel login'|trans }}
            </a>
            {% if upgradables %}
                <button class="tn-btn tn-btn--primary tn-btn--sm" type="button" data-bs-toggle="modal" data-bs-target="#upgrade-request-modal">
                    <svg class="icon"><use href="#arrow-up" /></svg>
                    {{ 'Upgrade plan'|trans }}
                </button>
            {% endif %}
        </div>
    </div>

    {# Real, navigable sections only: hosting's Client API only exposes
       login/username/domain/password changes - no mailbox, backup, DNS or
       usage-stat endpoints exist on this install, so those tabs from the
       design spec are omitted rather than faked. #}
    <div class="tn-tabs mb-3">
        <div class="tn-tabs__nav">
            <button type="button" class="tn-tabs__tab tn-tabs__tab--active" data-tn-tab="#overview">{{ 'Overview'|trans }}</button>
            <button type="button" class="tn-tabs__tab" data-tn-tab="#password">{{ 'Password'|trans }}</button>
            <button type="button" class="tn-tabs__tab" data-tn-tab="#domain">{{ 'Domain'|trans }}</button>
            <button type="button" class="tn-tabs__tab" data-tn-tab="#username">{{ 'Username'|trans }}</button>
        </div>
    </div>

    <div class="tn-tab-panes">
        <div class="tn-tab-pane" id="overview" style="display:block;">
            <div class="d-flex flex-wrap" style="gap: var(--space-4);">
                <div style="flex: 1 1 420px; min-width: 0;">
                    {# No usage-stats endpoint exists on Servicehosting's Client API in this install
                       (only username/domain/password change, hp_get_pairs, and control-panel login) -
                       so no storage/bandwidth/mailbox usage bars are shown here; fabricating numbers
                       would be worse than omitting the card. #}
                    <div class="tn-card tn-card--compact mb-3">
                        <div class="tn-card__header">
                            <span class="tn-card__title">{{ 'Quick actions'|trans }}</span>
                        </div>
                        <div class="tn-manage-grid">
                            <a class="tn-manage-action" href="{{ 'servicehosting/get_login_url'|api_url(query: { 'order_id': order.id }) }}" {{ fb_api_link({callback: 'onAfterLoginLinkCreated'}) }}>
                                <span class="tn-manage-action__icon"><svg class="icon"><use href="#terminal" /></svg></span>
                                <span class="tn-manage-action__title">{{ 'Control panel'|trans }}</span>
                                <span class="tn-manage-action__desc">{{ 'Log in to your hosting control panel.'|trans }}</span>
                            </a>
                            <button type="button" class="tn-manage-action" style="text-align:left; border:var(--bw-hair) solid var(--border); width:100%;" data-tn-tab="#password">
                                <span class="tn-manage-action__icon"><svg class="icon"><use href="#key-round" /></svg></span>
                                <span class="tn-manage-action__title">{{ 'Password'|trans }}</span>
                                <span class="tn-manage-action__desc">{{ 'Change your control panel / FTP / SSH password.'|trans }}</span>
                            </button>
                            <button type="button" class="tn-manage-action" style="text-align:left; border:var(--bw-hair) solid var(--border); width:100%;" data-tn-tab="#domain">
                                <span class="tn-manage-action__icon"><svg class="icon"><use href="#globe" /></svg></span>
                                <span class="tn-manage-action__title">{{ 'Domain'|trans }}</span>
                                <span class="tn-manage-action__desc">{{ 'Point this hosting account to a different domain.'|trans }}</span>
                            </button>
                            <button type="button" class="tn-manage-action" style="text-align:left; border:var(--bw-hair) solid var(--border); width:100%;" data-tn-tab="#username">
                                <span class="tn-manage-action__icon"><svg class="icon"><use href="#user" /></svg></span>
                                <span class="tn-manage-action__title">{{ 'Username'|trans }}</span>
                                <span class="tn-manage-action__desc">{{ 'Change your control panel username.'|trans }}</span>
                            </button>
                        </div>
                    </div>
                </div>
                <div style="flex: 0 0 330px; width: 330px; max-width: 100%;">
                    <div class="tn-card tn-card--compact mb-3">
                        <div class="tn-card__header">
                            <span class="tn-card__title">{{ 'Plan & renewal'|trans }}</span>
                        </div>
                        <div class="tn-kv-row">
                            <span class="tn-kv-row__key">{{ 'Plan'|trans }}</span>
                            <span class="tn-kv-row__value">{{ hp.name }}</span>
                        </div>
                        {% if order.expires_at %}
                        <div class="tn-kv-row">
                            <span class="tn-kv-row__key">{{ 'Renews'|trans }}</span>
                            <span class="tn-kv-row__value">{{ order.expires_at|format_date }}</span>
                        </div>
                        {% endif %}
                        <div class="tn-kv-row">
                            <span class="tn-kv-row__key">{{ 'Renewal price'|trans }}</span>
                            <span class="tn-kv-row__value">{{ order.total|format_currency(order.currency ?? default_currency) }}</span>
                        </div>
                        {# No auto-renew field exists on Model_ServiceHosting / the order - row omitted rather than faked. #}
                        <div class="d-flex flex-column mt-3" style="gap: var(--space-2);">
                            {% if upgradables %}
                                <button class="tn-btn tn-btn--secondary tn-btn--block" type="button" data-bs-toggle="modal" data-bs-target="#upgrade-request-modal">{{ 'Change plan'|trans }}</button>
                            {% endif %}
                            <button class="tn-btn tn-btn--ghost tn-btn--block" type="button" data-bs-toggle="modal" data-bs-target="#cancel-request-modal">{{ 'Cancel…'|trans }}</button>
                        </div>
                    </div>

                    {% if server.ip or server.hostname %}
                    <div class="tn-card tn-card--compact mb-3">
                        <div class="tn-card__header">
                            <span class="tn-card__title">{{ 'Server'|trans }}</span>
                        </div>
                        {% if server.hostname %}
                        <div class="tn-kv-row">
                            <span class="tn-kv-row__key">{{ 'Hostname'|trans }}</span>
                            <span class="tn-kv-row__value">{{ server.hostname }}</span>
                        </div>
                        {% endif %}
                        {% if server.ip %}
                        <div class="tn-kv-row">
                            <span class="tn-kv-row__key">{{ 'IP'|trans }}</span>
                            <span class="tn-kv-row__value">{{ server.ip }}</span>
                        </div>
                        {% endif %}
                        <div class="tn-kv-row">
                            <span class="tn-kv-row__key">{{ 'Username'|trans }}</span>
                            <span class="tn-kv-row__value">{{ service.username }}</span>
                        </div>
                        {% if service.domain_order_id %}
                            <a class="tn-btn tn-btn--secondary tn-btn--block mt-2" href='{{ "order/service/manage/#{service.domain_order_id}"|url }}'>{{ 'Manage domain'|trans }}</a>
                        {% endif %}
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Hosting password #}
        <div class="tn-tab-pane" id="password" style="display:none;">
            <div class="tn-card tn-card--compact" style="max-width: 480px;">
                <h3 class="h5">{{ 'Change Your Control Panel/FTP/SSH Password'|trans }}</h3>
                <form action="{{ 'servicehosting/change_password'|api_url }}" method="post" {{ fb_api_form({message: 'Password Changed'|trans}) }}>
                    <div class="mb-3">
                        <label class="form-label">{{ 'Password'|trans }}</label>
                        <input class="tn-input" type="password" name="password" value="{{ request.password }}" required="required">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">{{ 'Password Confirm'|trans }}</label>
                        <input class="tn-input" type="password" name="password_confirm" value="{{ request.password_confirm }}" required="required">
                    </div>
                    <input type="hidden" name="order_id" value="{{ order.id }}">
                    <button class="tn-btn tn-btn--primary" type="submit">{{ 'Change Password'|trans }}</button>
                </form>
            </div>
        </div>

        {# Hosting domain #}
        <div class="tn-tab-pane" id="domain" style="display:none;">
            <div class="tn-card tn-card--compact" style="max-width: 480px;">
                <h3 class="h5">{{ 'Change Domain'|trans }}</h3>
                <form action="{{ 'servicehosting/change_domain'|api_url }}" method="post" {{ fb_api_form({message: 'Domain Name Changed'|trans}) }}>
                    <div class="mb-3 d-flex" style="gap: var(--space-2);">
                        <input class="tn-input" style="flex: 2;" type="text" name="sld" value="{{ request.domain|default(service.sld) }}" required="required">
                        <input class="tn-input" style="flex: 1;" type="text" name="tld" value="{{ request.domain|default(service.tld) }}" required="required">
                    </div>
                    <input type="hidden" name="order_id" value="{{ order.id }}">
                    <button class="tn-btn tn-btn--primary" type="submit">{{ 'Change Domain'|trans }}</button>
                </form>
            </div>
        </div>

        {# Hosting username #}
        <div class="tn-tab-pane" id="username" style="display:none;">
            <div class="tn-card tn-card--compact" style="max-width: 480px;">
                <h3 class="h5">{{ 'Change Username'|trans }}</h3>
                <form method="post" action="{{ 'servicehosting/change_username'|api_url }}" {{ fb_api_form({message: 'Username Changed'|trans}) }}>
                    <div class="mb-3">
                        <label class="form-label">{{ 'Username'|trans }}</label>
                        <input class="tn-input" type="text" name="username" value="{{ request.username|default(service.username) }}" required="required">
                    </div>
                    <input type="hidden" name="order_id" value="{{ order.id }}">
                    <button class="tn-btn tn-btn--primary" type="submit">{{ 'Change Username'|trans }}</button>
                </form>
            </div>
        </div>
    </div>
</div>

{% block js %}
<script>
    function onAfterLoginLinkCreated(url){
        window.open(url, "_blank");
    }

    document.addEventListener("DOMContentLoaded", function () {
        document.querySelectorAll('[data-tn-tab]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var target = btn.getAttribute('data-tn-tab');
                var pane = document.querySelector(target);
                if (!pane) return;
                document.querySelectorAll('.tn-tabs__tab').forEach(function (t) { t.classList.remove('tn-tabs__tab--active'); });
                document.querySelectorAll('.tn-tab-pane').forEach(function (p) { p.style.display = 'none'; });
                var navBtn = document.querySelector('.tn-tabs__tab[data-tn-tab="' + target + '"]');
                if (navBtn) navBtn.classList.add('tn-tabs__tab--active');
                pane.style.display = 'block';
                pane.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
            });
        });
    });
</script>
{% endblock %}
{% endif %}
