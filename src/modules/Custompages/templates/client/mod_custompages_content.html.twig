{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}

{% block meta_title %}{{ page.title }}{% endblock %}
{% block meta_description %}{{ page.description }}{% endblock %}
{% block meta_keywords %}{{ page.keywords }}{% endblock %}
{% block breadcrumb %}<li class="breadcrumb-item active" aria-current="page">{{ page.title }}</li>{% endblock %}

{% block body_class %}custom-page{% endblock %}

{% block content %}
    <div class="tn-card">
        <div class="tn-card__header">
            <span class="tn-card__title">{{ page.title }}</span>
        </div>
        <div class="tn-prose">{{ (page.content ?? '')|markdown_to_html }}</div>
    </div>
{% endblock %}
