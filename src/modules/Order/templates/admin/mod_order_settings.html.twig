{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}

{% block meta_title %}{{ 'Orders Settings'|trans }}{% endblock %}

{% set active_menu = 'system' %}

{% block breadcrumbs %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="{{ '/'|url }}">
                <svg class="icon">
                    <use xlink:href="#home" />
                </svg>
            </a>
        </li>
        <li class="breadcrumb-item">
            <a href="{{ 'system'|url }}">{{ 'Settings'|trans }}</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">{{ 'Orders Settings'|trans }}</li>
    </ol>
{% endblock %}

{% block content %}
    {% set params = admin.extension_config_get({ 'ext': 'mod_order' }) %}
    <div class="card">
        <div class="card-header">
            <div>
                <h3 class="card-title">{{ 'Orders Settings'|trans }}</h3>
                <p class="card-subtitle">{{ 'Control renewal-date logic, addon visibility, suspension reasons, and automated cancellation behavior.'|trans }}</p>
            </div>
        </div>
        <form method="post" action="{{ 'extension/config_save'|api_url }}" {{ fb_api_form({message: 'Settings Updated'|trans}) }}>
            <div class="card-body">
                <div class="alert alert-info" role="alert">
                    <strong class="me-1">{{ 'Information:'|trans }}</strong>{{ 'These settings affect renewal timing, how addon orders appear in lists, and how suspended orders are automatically cleaned up.'|trans }}
                </div>

                <h4 class="card-title mb-2">{{ 'Renewal Logic'|trans }}</h4>
                <p class="text-secondary mb-3">{{ 'Choose how the next service expiration date is calculated after a renewal payment is received.'|trans }}</p>
                <div class="d-flex flex-column gap-2">
                    <div class="form-check">
                        <input class="form-check-input" id="radioFromExpirationDay" type="radio" name="order_renewal_logic" value="from_expiration_date" {% if params.order_renewal_logic|default('from_expiration_date') == 'from_expiration_date' %}checked{% endif %}>
                        <label class="form-check-label" for="radioFromExpirationDay">{{ 'Next date is counted from last order expiration date'|trans }}</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" id="radioFromToday" type="radio" name="order_renewal_logic" value="from_today" {% if params.order_renewal_logic|default('') == 'from_today' %}checked{% endif %}>
                        <label class="form-check-label" for="radioFromToday">{{ 'Next date is counted from renewal (payment) date'|trans }}</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" id="radioFromGreater" type="radio" name="order_renewal_logic" value="from_greater" {% if params.order_renewal_logic|default('') == 'from_greater' %}checked{% endif %}>
                        <label class="form-check-label" for="radioFromGreater">{{ 'Next date is counted from last expiration date or renewal date whichever is greater'|trans }}</label>
                    </div>
                </div>
            </div>
            <div class="card-body border-top">
                <h4 class="card-title mb-2">{{ 'Order Visibility'|trans }}</h4>
                <p class="text-secondary mb-3">{{ 'Control whether addon orders are shown directly in the main orders list.'|trans }}</p>
                <label class="form-check form-switch form-switch-2">
                    <input class="form-check-input" type="checkbox" name="show_addons" value="1" {% if params.show_addons|default(false) %}checked{% endif %}>
                    <span class="form-check-label">{{ 'Show Addon Orders in Orders List'|trans }}</span>
                </label>
                <small class="form-hint">{{ 'If disabled, addon orders remain available in the main order view under the Addons tab.'|trans }}</small>
            </div>
            <div class="card-body border-top">
                <h4 class="card-title mb-2">{{ 'Suspension and Cancellation'|trans }}</h4>
                <p class="text-secondary mb-3">{{ 'Set default reasons used by automated suspension and define when suspended orders should be cancelled.'|trans }}</p>
                <div class="row g-3">
                    <div class="col-lg-6">
                        <label class="form-label" for="batch_suspend_reason">{{ 'Auto Suspend Reason'|trans }}</label>
                        <input class="form-control" id="batch_suspend_reason" type="text" name="batch_suspend_reason" value="{{ params.batch_suspend_reason|default('') }}">
                    </div>
                    <div class="col-lg-6">
                        <label class="form-label" for="batch_cancel_suspended">{{ 'Auto Cancellation Policy'|trans }}</label>
                        <select class="form-select" id="batch_cancel_suspended" name="batch_cancel_suspended">
                            <option value="1" {{ params.batch_cancel_suspended|default('1') ? 'selected' : '' }}>{{ 'Cancel Suspended Orders'|trans }}</option>
                            <option value="0" {{ params.batch_cancel_suspended|default('1') ? '' : 'selected' }}>{{ 'Do Not Cancel Suspended Orders'|trans }}</option>
                        </select>
                    </div>
                    <div class="col-lg-4">
                        <label class="form-label" for="batch_cancel_suspended_after_days">{{ 'Cancel After Suspension'|trans }}</label>
                        <div class="input-group">
                            <input class="form-control" id="batch_cancel_suspended_after_days" type="number" min="0" name="batch_cancel_suspended_after_days" value="{{ params.batch_cancel_suspended_after_days|default('') }}" placeholder="7">
                            <span class="input-group-text">{{ 'days'|trans }}</span>
                        </div>
                    </div>
                    <div class="col-lg-8">
                        <label class="form-label" for="batch_cancel_suspended_reason">{{ 'Required Suspension Reason'|trans }}</label>
                        <input class="form-control" id="batch_cancel_suspended_reason" type="text" name="batch_cancel_suspended_reason" value="{{ params.batch_cancel_suspended_reason|default('') }}">
                    </div>
                    <div class="col-12">
                        <label class="form-label" for="suspend_reason_list">{{ 'Suspension Reasons'|trans }}</label>
                        <textarea class="form-control" id="suspend_reason_list" name="suspend_reason_list" rows="3">{{ params.suspend_reason_list|default('') }}</textarea>
                    </div>
                </div>
            </div>
            <div class="card-footer text-end">
                <input type="hidden" name="ext" value="mod_order">
                <button class="btn btn-primary" type="submit">{{ 'Update'|trans }}</button>
            </div>
        </form>
    </div>
{% endblock %}
