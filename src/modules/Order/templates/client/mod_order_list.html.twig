{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}
{% set active_menu = 'services' %}

{% import "macro_functions.html.twig" as mf %}

{% block meta_title %}{{ 'My Products & Services'|trans }}{% endblock %}

{% block body_class %}order-list{% endblock %}
{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'Services'|trans }}</li>
{% endblock %}

{% block content %}
    {% set active_type = request.type|default('') %}
    {# PaginationOptions::MAX_PER_PAGE is 500 — 1000 throws an InformationException #}
    {% set all_orders = client.order_get_list({ 'per_page': 500, 'hide_addons': 1 }) %}
    {% set counts = { 'hosting': 0, 'domain': 0, 'microsoft365': 0 } %}
    {% for i, o in all_orders.list %}
        {% if o.service_type and counts[o.service_type] is defined %}
            {% set counts = counts|merge({ (o.service_type): counts[o.service_type] + 1 }) %}
        {% endif %}
    {% endfor %}

    {% set orders = client.order_get_list({ 'per_page': 100, 'page': request.page, 'hide_addons': 1, 'type': active_type ?: null }) %}

    <div class="row">
        <div class="col-md-12">
            <div class="d-flex justify-content-between align-items-start mb-4 flex-wrap" style="gap: var(--space-3);">
                <div>
                    <h1 class="mb-1">{{ 'Services'|trans }}</h1>
                    <span class="small text-muted">{{ 'Everything you run with us — hosting, domains and licenses.'|trans }}</span>
                </div>
                <a class="tn-btn tn-btn--primary tn-btn--md" href="{{ 'order'|url }}">
                    <svg class="icon"><use href="#plus" /></svg>
                    {{ 'Add a service'|trans }}
                </a>
            </div>

            <div class="d-flex align-items-center flex-wrap mb-3" style="gap: var(--space-2);">
                <a class="tn-tabchip" data-active="{{ active_type == '' ? 'true' : 'false' }}" href="{{ 'order/service'|url }}">
                    {{ 'All'|trans }} <span class="tn-tabchip__count">{{ all_orders.list|length }}</span>
                </a>
                <a class="tn-tabchip" data-active="{{ active_type == 'hosting' ? 'true' : 'false' }}" href="{{ 'order/service'|url(query: {'type': 'hosting'}) }}">
                    {{ 'Hosting'|trans }} <span class="tn-tabchip__count">{{ counts.hosting }}</span>
                </a>
                <a class="tn-tabchip" data-active="{{ active_type == 'domain' ? 'true' : 'false' }}" href="{{ 'order/service'|url(query: {'type': 'domain'}) }}">
                    {{ 'Domains'|trans }} <span class="tn-tabchip__count">{{ counts.domain }}</span>
                </a>
                {% if counts.microsoft365 > 0 %}
                <a class="tn-tabchip" data-active="{{ active_type == 'microsoft365' ? 'true' : 'false' }}" href="{{ 'order/service'|url(query: {'type': 'microsoft365'}) }}">
                    {{ 'Microsoft 365'|trans }} <span class="tn-tabchip__count">{{ counts.microsoft365 }}</span>
                </a>
                {% endif %}
                <div class="flex-grow-1"></div>
                <div class="tn-input-wrap" style="width: 240px; --_pl: 36px;">
                    <span class="tn-input__prefix"><svg class="icon" width="15" height="15"><use href="#search" /></svg></span>
                    <input type="search" class="tn-input" id="tn-service-search" placeholder="{{ 'Search services'|trans }}">
                </div>
            </div>

            <div class="tn-card tn-card--compact mb-3">
                {% if orders.list %}
                    <div class="d-flex flex-column" id="tn-service-list">
                        {% for i, order in orders.list %}
                            {% set type_icon = order.service_type == 'domain' ? 'globe' : (order.service_type == 'hosting' ? 'server' : 'briefcase') %}
                            <a href='{{ "order/service/manage/#{order.id}"|url }}' class="tn-servicerow tn-row-hover" data-tn-service-name="{{ order.title|lower }}">
                                <span class="tn-servicerow__icon"><svg class="icon"><use href="#{{ type_icon }}" /></svg></span>
                                <span class="tn-servicerow__body">
                                    <span class="tn-servicerow__name">{{ order.title }}</span>
                                    <span class="tn-servicerow__sub">
                                        #{{ order.id }}{% if order.period %} &middot; {{ order.period|period_title }}{% endif %}
                                    </span>
                                </span>
                                <span class="tn-servicerow__meta">
                                    <span class="tn-servicerow__meta-top">
                                        <span class="tn-servicerow__meta-label">{{ 'Renews'|trans }} {% if order.expires_at %}{{ order.expires_at|format_date }}{% else %}&mdash;{% endif %}</span>
                                        <span class="tn-servicerow__status">{{ mf.status_badge(order.status, 'order') }}</span>
                                    </span>
                                    <span class="tn-servicerow__meta-value">{{ (order.renewal_price ?? order.total)|format_currency(order.currency ?? default_currency) }}</span>
                                </span>
                                <span class="tn-servicerow__chevron"><svg class="icon"><use href="#chevron-right" /></svg></span>
                            </a>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="d-flex justify-content-center my-2 py-4">
                        <span class="m-0">{{ 'No services yet'|trans }}</span>
                    </div>
                {% endif %}
            </div>

            {{ include('partial_pagination.html.twig', { 'list': orders, 'url': 'order/service' }) }}

            <div class="tn-transfer-row">
                <span class="tn-transfer-row__icon"><svg class="icon"><use href="#arrow-right-left" /></svg></span>
                <span class="tn-transfer-row__text">{{ 'Hosting or domains elsewhere? Transfer them in and manage everything from one place.'|trans }}</span>
                {# No dedicated "transfer domain" list route exists in this codebase — transfer vs.
                   register is chosen as an action inside the domain product's own order form, so this
                   links to the general order page rather than a fabricated route. #}
                <a class="tn-transfer-row__link" href="{{ 'order'|url }}">{{ 'Start transfer'|trans }}</a>
            </div>
        </div>
    </div>
{% endblock %}

{% block js %}
{% autoescape "js" %}
<script>
    document.addEventListener('DOMContentLoaded', function () {
        const searchInput = document.getElementById('tn-service-search');
        const list = document.getElementById('tn-service-list');
        if (!searchInput || !list) return;
        searchInput.addEventListener('input', function () {
            const q = searchInput.value.trim().toLowerCase();
            list.querySelectorAll('[data-tn-service-name]').forEach(function (row) {
                row.style.display = row.getAttribute('data-tn-service-name').includes(q) ? '' : 'none';
            });
        });
    });
</script>
{% endautoescape %}
{% endblock %}
