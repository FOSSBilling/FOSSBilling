{% set status_label = invoice.status|capitalize %}
{% set status_class = invoice.status == 'paid' ? 'Paid' : (invoice.status == 'refunded' ? 'Refunded' : 'Unpaid') %}

{% set address_lines = [] %}
{% for line in [footer.address_1, footer.address_2, footer.address_3] %}
	{% if line|length > 0 %}
		{% set address_lines = address_lines|merge([line]) %}
	{% endif %}
{% endfor %}
{% set address = address_lines|join(', ') %}

{% set buyer_name = buyer.Company is defined and buyer.Company|trim ? buyer.Company : (buyer.Name is defined ? buyer.Name : '') %}
{% set buyer_address = buyer.Address is defined ? buyer.Address : '' %}

<!DOCTYPE html>
<html>
	<head>
		<meta http-equiv='Content-Type' content='text/html; charset=utf-8'/>
		<title>{{ invoice.serie_nr }}</title>
		<style>
			{{ css|raw }}
		</style>
	</head>
	<body>
		<table class="HeaderTable">
			<tr>
				<td class="HeaderBrand">
					{% if logo_source is not empty %}
						<img src='{{ logo_source }}' height='24' class='CompanyLogo'>
					{% else %}
						<div class='BrandWordmark'>Tenant<span>Ninja</span></div>
					{% endif %}
					<div class="SellerContact">
						{% if address %}<div>{{ address }}</div>{% endif %}
						<div>{{ footer.email }}{% if footer.phone|default('') %} &middot; {{ footer.phone }}{% endif %}{% if footer.www %} &middot; {{ footer.www }}{% endif %}</div>
					</div>
				</td>
				<td class="HeaderMeta">
					<div class="InvoiceTitle">{{ 'Invoice'|trans }}</div>
					<div class="InvoiceNumber">#{{ invoice.serie_nr }}</div>
					<span class="StatusBadge Status-{{ status_class }}">{{ status_label|trans }}</span>
				</td>
			</tr>
		</table>

		<table class="MetaStrip">
			<tr>
				<td class="MetaCell MetaCell-wide">
					<div class="MetaLabel">{{ 'Billed To'|trans }}</div>
					<div class="MetaValueStrong">{{ buyer_name }}</div>
					{% if buyer_address %}<div class="MetaValueSub">{{ buyer_address }}</div>{% endif %}
				</td>
				<td class="MetaCell">
					<div class="MetaLabel">{{ 'Issue Date'|trans }}</div>
					<div class="MetaValueMono">{{ invoice.created_at|format_date }}</div>
				</td>
				<td class="MetaCell">
					<div class="MetaLabel">{{ 'Due Date'|trans }}</div>
					<div class="MetaValueMono">{{ invoice.due_at ? invoice.due_at|format_date : '—' }}</div>
				</td>
				<td class="MetaCell MetaCell-last">
					<div class="MetaLabel">{{ 'Amount Due'|trans }}</div>
					<div class="MetaValueMono MetaValueTotal">{{ invoice.total|format_currency(currency_code) }}</div>
				</td>
			</tr>
		</table>

		<table class="LineItems">
			<thead>
				<tr>
					<th class="ColDescription">{{ 'Description'|trans }}</th>
					<th class="ColQty">{{ 'Qty'|trans }}</th>
					<th class="ColPrice">{{ 'Price'|trans }}</th>
					<th class="ColTotal">{{ 'Total'|trans }}</th>
				</tr>
			</thead>
			<tbody>
				{% for item in invoice.lines %}
					<tr>
						<td class="ColDescription">{{ item.title }}</td>
						<td class="ColQty">{{ item.quantity }}</td>
						<td class="ColPrice">{{ item.price|format_currency(currency_code) }}</td>
						<td class="ColTotal">{{ item.total|format_currency(currency_code) }}</td>
					</tr>
				{% endfor %}
			</tbody>
		</table>

		<table class="Totals">
			<tr>
				<td class="TotalsSpacer"></td>
				<td class="TotalsBox">
					<table class="TotalsInner">
						<tr class="SubtotalRow">
							<td class="TotalsLabel">{{ 'Subtotal'|trans }}</td>
							<td class="TotalsValue">{{ invoice.subtotal|format_currency(currency_code) }}</td>
						</tr>
						{% if invoice.tax > 0 %}
							<tr class="SubtotalRow">
								<td class="TotalsLabel">{{ invoice.taxname }} {{ invoice.taxrate }}%</td>
								<td class="TotalsValue">{{ invoice.tax|format_currency(currency_code) }}</td>
							</tr>
						{% endif %}
						{% if invoice.discount|default(0) > 0 %}
							<tr class="SubtotalRow">
								<td class="TotalsLabel">{{ 'Discount'|trans }}</td>
								<td class="TotalsValue">-{{ invoice.discount|format_currency(currency_code) }}</td>
							</tr>
						{% endif %}
						<tr class="GrandTotalRow">
							<td class="TotalsLabel">{{ 'Total due'|trans }}</td>
							<td class="TotalsValue TotalsValueBig">{{ invoice.total|format_currency(currency_code) }}</td>
						</tr>
					</table>
				</td>
			</tr>
		</table>

		{% if invoice.status == 'unpaid' %}
			<div class="PayNote">
				{{ 'Pay online at'|trans }} <b>{{ footer.www }}/invoice/{{ invoice.serie_nr }}</b>
			</div>
		{% endif %}

		{% if invoice.text_1 %}
			<div class="InvoiceText">{{ (invoice.text_1 ?? '')|markdown_to_html }}</div>
		{% endif %}
		{% if invoice.text_2 %}
			<div class="InvoiceText">{{ (invoice.text_2 ?? '')|markdown_to_html }}</div>
		{% endif %}

		<div class='InvoiceFooter'>
			{% if footer.display_bank_info|default(false) == 1 %}
				<div class="FooterBank"><b>{{ 'Payment Details'|trans }}:</b> {{ 'Account Owner'|trans }}: {{ footer.company_name|default('') }} &middot; {{ 'Bank'|trans }}: {{ footer.bank_name|default('') }} &middot; {{ 'BIC / SWIFT Code'|trans }}: {{ footer.bic|default('') }} &middot; {{ 'Account Number'|trans }}: {{ footer.account_number|default('') }}</div>
			{% endif %}
			<table class="FooterRow"><tr>
				<td class="FooterLeft">{{ footer.company_name }}{{ footer.signature ? ' — ' ~ footer.signature : '' }}</td>
				<td class="FooterRight">{{ invoice.serie_nr }}</td>
			</tr></table>
		</div>
	</body>
</html>
