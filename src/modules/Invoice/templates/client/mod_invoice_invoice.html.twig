{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}
{% set active_menu = 'invoices' %}

{% import "macro_functions.html.twig" as mf %}

{% set nr = invoice.serie ~ "%05s"|format(invoice.nr) %}

{% block meta_title %}{{ 'Invoice'|trans }} #{{ nr }}{% endblock %}

{% block body_class %}invoice-invoice{% endblock %}

{% block breadcrumb %}
    <li class="breadcrumb-item"><a href="{{ 'invoice'|url }}">{{ 'Invoices'|trans }}</a></li>
    <li class="breadcrumb-item active" aria-current="page">#{{ nr }}</li>
{% endblock %}

{% block content %}
{% set seller = invoice.seller %}
{% set buyer = invoice.buyer %}

    <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
        <div>
            <h1 class="mb-1 font-monospace d-flex align-items-center gap-2">
                #{{ nr }}
                {{ mf.status_badge(invoice.status, 'invoice') }}
            </h1>
            <span class="text-muted">
                {{ 'Issued'|trans }} {{ invoice.created_at|format_date }}
                &middot; {{ 'due'|trans }} {{ invoice.due_at ? invoice.due_at|format_date : '—' }}
                {% if buyer.company|trim %}
                    &middot; {{ buyer.company }}{% if buyer.company_vat|trim %} ({{ buyer.company_vat }}){% endif %}
                {% endif %}
            </span>
        </div>
        <div class="d-flex gap-2">
            <a href='{{ "invoice/pdf/#{invoice.hash}"|url }}' target="_blank" class="tn-btn tn-btn--ghost tn-btn--sm">
                <svg class="icon"><use href="#download" /></svg>
                {{ 'PDF'|trans }}
            </a>
            <a href='{{ "invoice/print/#{invoice.hash}"|url }}' target="_blank" class="tn-btn tn-btn--ghost tn-btn--sm">
                <svg class="icon"><use href="#printer" /></svg>
                {{ 'Print'|trans }}
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="tn-card tn-card--compact mb-3">
                <div class="tn-card__header">
                    <span class="tn-card__title">{{ 'Line items'|trans }}</span>
                </div>

                {% for item in invoice.lines %}
                    <div class="tn-kv-row">
                        <span class="tn-kv-row__key">
                            <span class="d-block">
                                {% if item.order_id %}
                                    <a href='{{ "order/service/manage/#{item.order_id}"|url }}' class="text-reset">{{ item.title }}</a>
                                {% else %}
                                    {{ item.title }}
                                {% endif %}
                                {% if item.quantity > 1 %} x {{ item.quantity }} {{ item.unit }}{% endif %}
                            </span>
                            {% if item.period %}
                                <span class="d-block small text-muted">{{ item.period }}</span>
                            {% endif %}
                        </span>
                        <span class="tn-kv-row__value">{{ item.total|format_currency(invoice.currency ?? default_currency) }}</span>
                    </div>
                {% endfor %}

                <div class="tn-kv-row">
                    <span class="tn-kv-row__key">{{ 'Subtotal'|trans }}</span>
                    <span class="tn-kv-row__value">{{ invoice.subtotal|format_currency(invoice.currency ?? default_currency) }}</span>
                </div>
                {% if invoice.tax > 0 %}
                    <div class="tn-kv-row">
                        <span class="tn-kv-row__key">{{ invoice.taxname }} {{ invoice.taxrate }}%</span>
                        <span class="tn-kv-row__value">{{ invoice.tax|format_currency(invoice.currency ?? default_currency) }}</span>
                    </div>
                {% endif %}
                {% if invoice.discount|default(0) > 0 %}
                    <div class="tn-kv-row">
                        <span class="tn-kv-row__key">{{ 'Discount'|trans }}</span>
                        <span class="tn-kv-row__value">{{ invoice.discount|format_currency(invoice.currency ?? default_currency) }}</span>
                    </div>
                {% endif %}
                <div class="tn-kv-row tn-kv-row--total">
                    <span class="tn-kv-row__key">{{ 'Total due'|trans }}</span>
                    <span class="tn-kv-row__value">{{ invoice.total|format_currency(invoice.currency ?? default_currency) }}</span>
                </div>

                {% if invoice.text_1 %}
                    <div class="small text-muted border-top pt-3 mt-3">
                        {{ (invoice.text_1 ?? '')|markdown_to_html }}
                    </div>
                {% endif %}
                {% if invoice.text_2 %}
                    <div class="small text-muted border-top pt-3 mt-3">
                        {{ (invoice.text_2 ?? '')|markdown_to_html }}
                    </div>
                {% endif %}
            </div>
        </div>

        <div class="col-lg-4">
            {% if invoice.status == 'unpaid' %}
                <div class="tn-card tn-card--compact mb-3">
                    <div class="tn-card__header">
                        <span class="tn-card__title">{{ 'Pay this invoice'|trans }}</span>
                    </div>

                    <div class="tn-kv-row tn-kv-row--total">
                        <span class="tn-kv-row__key">{{ 'Amount'|trans }}</span>
                        <span class="tn-kv-row__value">{{ invoice.total|format_currency(invoice.currency ?? default_currency) }}</span>
                    </div>

                    {# This page is served through the guest API (unauthenticated hash-based
                       pay-link view - see Controller/Client.php get_invoice()); there is no
                       authenticated client session/balance available here, so we go straight
                       to the real existing payment-gateway selection UI. #}
                    <form method="post" action="{{ 'invoice/payment'|api_url(role: 'guest') }}"
                        {{ fb_api_form({ redirect: ("invoice/#{invoice.hash}")|url(query: { 'auto_redirect': 1 }) }) }}>
                        <input type="hidden" name="hash" value="{{ invoice.hash }}"/>
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            {% for gtw in guest.invoice_gateways %}
                                {% if invoice.currency in gtw.accepted_currencies and (gtw.allow_single or (invoice.subscribable and gtw.allow_recurrent)) %}
                                    <div class="invoice-gateway rounded-2 p-2">
                                        <input type="radio" class="btn-check border-0" name="gateway_id" gateway_id="{{ gtw.id }}" id="{{ gtw.id }}" autocomplete="off">
                                        <label class="btn" for="{{ gtw.id }}"
                                            style="background: transparent url('{{gtw.logo.logo}}') no-repeat center center; background-size: contain; height:{{gtw.logo.height}}; width:{{gtw.logo.width}};"
                                            onclick="paymentPrompt('{{ gtw.id }}', {{ gtw.allow_recurrent ? 'true' : 'false' }}, {{ gtw.allow_single ? 'true' : 'false' }}, `{{ gtw.title }}`)"
                                            data-bs-toggle="tooltip" data-bs-title="{{ gtw.title }}"></label>
                                    </div>
                                {% endif %}
                            {% endfor %}
                        </div>
                        <input type="hidden" name="gateway_id" id="gateway_id">
                    </form>
                </div>
            {% endif %}

            {% if seller.account_number|trim or seller.bank_name|default('')|trim or seller.bic|default('')|trim %}
                <div class="tn-card tn-card--compact">
                    <div class="tn-card__header">
                        <span class="tn-card__title">{{ 'Bank transfer'|trans }}</span>
                    </div>
                    {% if seller.bank_name|default('')|trim %}
                        <div class="tn-kv-row">
                            <span class="tn-kv-row__key">{{ 'Bank'|trans }}</span>
                            <span class="tn-kv-row__value">{{ seller.bank_name }}</span>
                        </div>
                    {% endif %}
                    {% if seller.account_number|trim %}
                        <div class="tn-kv-row">
                            <span class="tn-kv-row__key">{{ 'Account / IBAN'|trans }}</span>
                            <span class="tn-kv-row__value font-monospace">{{ seller.account_number }}</span>
                        </div>
                    {% endif %}
                    {% if seller.bic|default('')|trim %}
                        <div class="tn-kv-row">
                            <span class="tn-kv-row__key">{{ 'BIC / SWIFT'|trans }}</span>
                            <span class="tn-kv-row__value font-monospace">{{ seller.bic }}</span>
                        </div>
                    {% endif %}
                </div>
            {% endif %}
        </div>
    </div>

        <div class="modal modal-lg fade" id="paymentPrompt" tabindex="-1" aria-labelledby="paymentPromptLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h4 class="modal-title" id="paymentPromptLabel"></h4>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="{{ 'Close'|trans }}"></button>
                    </div>
                    <div class="modal-body">
                        <p id="bodyText"></p>
                        <a href="#" class="btn btn-primary" id="single">{{ "Pay Now with a One-Time Payment"|trans }}</a>
                        <a href="#" class="btn btn-primary" id="subscription" hidden="true">{{ "Pay Now and Create a Subscription"|trans }}</a>
                        <a href="#" class="btn btn-primary" id="pay-nondescript" hidden="true">{{ "Pay Now"|trans }}</a>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-primary" data-bs-dismiss="modal">{{ 'Cancel'|trans }}</button>
                    </div>
                </div>
            </div>
        </div>
{% endblock %}
{% block js %}
<script>
    document.addEventListener("DOMContentLoaded", function() {
        document.querySelectorAll('.hover-popover').forEach(element => {
            const tooltip = new bootstrap.Tooltip(element, {
                placement: 'top'
            });
        });
    });

    function paymentPrompt(id, supportsSubscription, supportsOneTime, title){
        invoiceHash = "{{ invoice.hash }}";
        backLink = "{{ 'invoice/banklink'|url }}";
        paymentLink = new URL(backLink.concat('/', invoiceHash, '/', id));
        invoiceSubscribable = {{ invoice.subscribable ? 'true' : 'false' }};

        {% set anyGatewayDoesSubscriptions = false %}
        {% set anyGatewayDoesOneTime = false %}
        {% for gtw in guest.invoice_gateways %}
            {% if gtw.allow_recurrent %}
                {% set anyGatewayDoesSubscriptions = true %}
            {% endif %}
            {% if gtw.allow_single %}
                {% set anyGatewayDoesOneTime = true %}
            {% endif %}
        {% endfor %}

        canAnyGatewayDoSubs = {{ anyGatewayDoesSubscriptions ? 'true' : 'false' }};
        canAnyGatewayDoOneTime = {{ anyGatewayDoesOneTime ? 'true' : 'false' }};

        const singleBtn = document.getElementById('single');
        const subscriptionBtn = document.getElementById('subscription');
        const genericBtn = document.getElementById('pay-nondescript');
        singleBtn.hidden = true;
        subscriptionBtn.hidden = true;
        genericBtn.hidden = true;

        {% if settings.prompt_subscription|default('0') %}
            if(supportsSubscription && supportsOneTime && invoiceSubscribable){
                document.getElementById('bodyText').textContent = `{{ 'The invoice you are paying and your chosen payment gateway both support subscription payments. What type of payment would you like to continue with?'|trans }}`;
                subscriptionBtn.hidden = false;
                singleBtn.hidden = false;
            } else if (supportsSubscription && invoiceSubscribable) {
                document.getElementById('bodyText').textContent = `{{ 'The invoice you are paying and your chosen payment gateway both support subscription payments. What type of payment would you like to continue with?'|trans }}`;
                subscriptionBtn.hidden = false;
            } else if (supportsOneTime) {
                if(invoiceSubscribable && canAnyGatewayDoSubs){
                    document.getElementById('bodyText').textContent = `{{ 'If you are happy with the selected payment gateway, please use the button below to continue with it. Optionally, you may choose a different payment gateway if you wish to pay using a subscription.'|trans }}`;
                } else {
                    document.getElementById('bodyText').textContent = `{{ 'If you are happy with the selected payment gateway, please use the button below to continue with it.'|trans }}`;
                }
                singleBtn.hidden = false;
            } else {
                document.getElementById('bodyText').textContent = `{{ 'This payment gateway does not support any of the payment methods available for this invoice. Please choose a different payment gateway.'|trans }}`;
            }
        {% else %}
            document.getElementById('bodyText').textContent = `{{ 'If you are happy with the selected payment gateway, please use the button below to continue with it.'|trans }}`;
            genericBtn.hidden = false;
        {% endif %}

        document.getElementById('paymentPromptLabel').textContent = `{{ 'Pay with'|trans }}`.concat(` `, title);
        subscriptionBtn.href = paymentLink;
        genericBtn.href = paymentLink;
        const singlePaymentLink = new URL(paymentLink);
        singlePaymentLink.searchParams.append('allow_subscription', 0);
        singleBtn.href = singlePaymentLink;

        modal = new bootstrap.Modal('#paymentPrompt');
        modal.show();
    }
</script>
{% endblock %}
