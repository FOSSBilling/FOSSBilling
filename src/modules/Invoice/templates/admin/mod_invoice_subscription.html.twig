{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}

{% import 'macro_functions.html.twig' as mf %}

{% set active_menu = 'invoice' %}

{% block meta_title %}{{ 'Subscription'|trans }} {{ subscription.sid }}{% endblock %}

{% block breadcrumbs %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="{{ '/'|url }}">
                <svg class="icon">
                    <use xlink:href="#home" />
                </svg>
            </a>
        </li>
        <li class="breadcrumb-item">
            <a href="{{ 'invoice/subscriptions'|url }}">{{ 'Subscriptions'|trans }}</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">{{ 'Subscription'|trans }} #{{ subscription.id }}</li>
    </ol>
{% endblock %}

{% block content %}
    <div class="card">
        <div class="card-header">
            <div>
                <h3 class="card-title">{{ 'Subscription'|trans }} {{ subscription.sid }}</h3>
                <p class="card-subtitle">{{ 'Review recurring billing details and update the stored gateway subscription record.'|trans }}</p>
            </div>
        </div>
        <div class="card-body pt-3 pb-0 px-0">
            <div class="card border-0 shadow-none rounded-0">
                <div class="card-header bg-transparent px-3 pt-0 pb-3 border-0">
                    <ul class="nav nav-pills card-header-pills" role="tablist">
                        <li class="nav-item" role="presentation">
                            <a class="nav-link active" href="#tab-index" data-bs-toggle="tab" role="tab">{{ 'Subscription'|trans }}</a>
                        </li>
                        <li class="nav-item" role="presentation">
                            <a class="nav-link" href="#tab-manage" data-bs-toggle="tab" role="tab">{{ 'Manage'|trans }}</a>
                        </li>
                    </ul>
                </div>
        <div class="tab-content border-top">
            <div class="tab-pane fade show active" id="tab-index" role="tabpanel">
                <div class="card-body overflow-auto">
                    <h5>{{ 'Subscription Details'|trans }}</h5>

                    <table class="table card-table table-vcenter table-striped text-nowrap">
                        <tbody>
                            <tr>
                                <td class="text-end">{{ 'Client'|trans }}:</td>
                                <td>
                                    <a href='{{ "client/manage/#{subscription.client.id}"|url }}'>{{ subscription.client.first_name }} {{ subscription.client.last_name }}</a>
                                </td>
                            </tr>
                            <tr>
                                <td class="text-end">{{ 'Amount'|trans }}:</td>
                                <td>{{ subscription.amount|format_currency(subscription.currency ?? default_currency) }} {{ subscription.period|period_title }}</td>
                            </tr>
                            <tr>
                                <td class="text-end">{{ 'Payment Gateway'|trans }}:</td>
                                <td>{{ subscription.gateway.title }}</td>
                            </tr>
                            <tr>
                                <td class="text-end d-none d-sm-table-cell">{{ 'Subscription ID on Payment Gateway'|trans }}:</td>
                                <td class="text-end d-sm-none">{{ 'Subscription ID on PG'|trans }}:</td>
                                <td>{{ subscription.sid|default('-') }}</td>
                            </tr>
                            <tr>
                                <td class="text-end">{{ 'Status'|trans }}:</td>
                                <td>{{ mf.status_badge(subscription.status, 'subscription') }}</td>
                            </tr>
                            <tr>
                                <td class="text-end">{{ 'Created At'|trans }}:</td>
                                <td>{{ subscription.created_at|format_date }}</td>
                            </tr>
                            {% if subscription.created_at != subscription.updated_at %}
                            <tr>
                                <td class="text-end">{{ 'Updated At'|trans }}:</td>
                                <td>{{ subscription.updated_at|format_date }}</td>
                            </tr>
                            {% endif %}
                        </tbody>
                    </table>
                </div>

                <div class="card-footer text-center">
                    <a class="btn btn-primary" href="{{ 'invoice/subscription_delete'|api_url(query: { 'id': subscription.id }) }}"
                        {{ fb_api_link({modal: {type: 'confirm', title: 'Are you sure?'|trans}, redirect: 'invoice/subscriptions'|url}) }}>
                        <svg class="icon icon-tabler" width="24" height="24">
                            <use xlink:href="#delete" />
                        </svg>
                        <span>{{ 'Delete'|trans }}</span>
                    </a>
                </div>
            </div>

            <div class="tab-pane fade" id="tab-manage" role="tabpanel">
                <div class="card-body">
                    <form method="post" action="{{ 'invoice/subscription_update'|api_url }}" {{ fb_api_form({reload: true}) }}>
                        <div class="card">
                            <div class="card-body">
                                <div class="d-flex flex-column gap-1 mb-4">
                                    <h5 class="card-title mb-0">{{ 'Subscription Settings'|trans }}</h5>
                                    <p class="text-secondary mb-0">{{ 'Update the stored recurring billing settings and gateway subscription reference.'|trans }}</p>
                                </div>
                                <div class="row g-3">
                                    <div class="col-xl-6">
                                        <label class="form-label">{{ 'Payment Gateway'|trans }}</label>
                                        {{ mf.selectbox('gateway_id', admin.invoice_gateway_get_pairs, subscription.gateway.id, 0, 'Select payment gateway'|trans) }}
                                    </div>
                                    <div class="col-xl-6">
                                        <label class="form-label" for="subscription_sid">{{ 'Subscription ID on Payment Gateway'|trans }}</label>
                                        <input class="form-control" id="subscription_sid" type="text" name="sid" value="{{ subscription.sid }}" required>
                                    </div>
                                    <div class="col-xl-6">
                                        <label class="form-label d-block">{{ 'Status'|trans }}</label>
                                        <div class="d-flex flex-wrap gap-3">
                                            <label class="form-check">
                                                <input class="form-check-input" id="radioStatusActive" type="radio" name="status" value="active"{% if subscription.status == 'active' %} checked{% endif %}>
                                                <span class="form-check-label">{{ 'Active'|trans }}</span>
                                            </label>
                                            <label class="form-check">
                                                <input class="form-check-input" id="radioStatusCanceled" type="radio" name="status" value="canceled"{% if subscription.status == 'canceled' %} checked{% endif %}>
                                                <span class="form-check-label">{{ 'Canceled'|trans }}</span>
                                            </label>
                                        </div>
                                    </div>
                                    <div class="col-xl-6">
                                        <label class="form-label">{{ 'Period'|trans }}</label>
                                        {{ mf.selectbox('period', guest.system_periods, subscription.period, 1, 'Select period'|trans) }}
                                    </div>
                                    <div class="col-xl-6">
                                        <label class="form-label" for="subscription_amount">{{ 'Amount'|trans }}</label>
                                        <input class="form-control" id="subscription_amount" type="text" name="amount" value="{{ subscription.amount }}" required>
                                    </div>
                                    <div class="col-xl-6">
                                        <label class="form-label">{{ 'Currency'|trans }}</label>
                                        {{ mf.selectbox('currency', guest.currency_get_pairs, subscription.currency, 1, 'Select currency'|trans) }}
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer d-flex justify-content-end">
                                <button class="btn btn-primary" type="submit">{{ 'Update Subscription'|trans }}</button>
                            </div>
                        </div>
                        <input type="hidden" name="id" value="{{ subscription.id }}">
                    </form>
                </div>
            </div>
        </div>
            </div>
        </div>
    </div>
{% endblock %}
