{% if order.status == 'active' %}
<div class="tn-card tn-card--compact mb-4">
    <div class="tn-card__header">
        <span class="tn-card__title">{{ 'API key'|trans }}</span>
    </div>
    <div class="tn-kv-row">
        <span class="tn-kv-row__key">{{ 'API key'|trans }}</span>
        <span class="tn-kv-row__value" style="font-family: var(--font-mono);">{{ service.api_key }}</span>
    </div>
    <div class="mt-3">
        <a class="tn-btn tn-btn--secondary tn-btn--sm" {{ fb_api_link({href: 'serviceapikey/reset'|api_url(query: {order_id: order.id}), modal: {type: 'confirm', title: 'Are you sure?'|trans}, reload: true}) }}>{{ 'Reset key'|trans }}</a>
    </div>
</div>
{% endif %}
