{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}

{% block meta_title %}{{ 'Cron Settings'|trans }}{% endblock %}

{% set active_menu = 'system' %}

{% block breadcrumbs %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="{{ '/'|url }}">
                <svg class="icon">
                    <use href="#home" />
                </svg>
            </a>
        </li>
        <li class="breadcrumb-item">
            <a href="{{ 'system'|url }}">{{ 'Settings'|trans }}</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">{{ 'Cron Settings'|trans }}</li>
    </ol>
{% endblock %}

{% block content %}
    {% set cron = admin.cron_info %}
    {% set params = admin.extension_config_get({ 'ext': 'mod_cron' }) %}
    {% set guest_cron = params.guest_cron|default(false) %}
    {% set cron_hash = params.cron_hash|default('') %}
    <div class="card">
        <div class="card-header">
            <div>
                <h3 class="card-title">{{ 'Cron Settings'|trans }}</h3>
                <p class="card-subtitle">{{ 'Review cron status, confirm your schedule, and control whether the guest cron endpoint is available.'|trans }}</p>
            </div>
        </div>
        <div class="card-body">
            <div class="alert alert-info" role="alert">
                <strong class="me-1">{{ 'Recommended Schedule:'|trans }}</strong><code>*/5 * * * * php {{ cron.cron_path }}</code>
            </div>

            <div class="row row-cards">
                <div class="col-xl-3 col-md-6">
                    <section class="card card-sm h-100">
                        <div class="card-body">
                            <div class="text-secondary small mb-1">{{ 'Timezone'|trans }}</div>
                            <div class="fw-semibold">{{ 'now'|format_date(pattern='zzz') }}</div>
                        </div>
                    </section>
                </div>
                <div class="col-xl-3 col-md-6">
                    <section class="card card-sm h-100">
                        <div class="card-body">
                            <div class="text-secondary small mb-1">{{ 'Time on Server'|trans }}</div>
                            <div class="fw-semibold">{{ 'now'|format_datetime }}</div>
                        </div>
                    </section>
                </div>
                <div class="col-xl-6">
                    <section class="card card-sm h-100">
                        <div class="card-body">
                            <div class="text-secondary small mb-1">{{ 'Last Scheduled Execution'|trans }}</div>
                            {% if cron.last_cron_exec %}
                                <div class="fw-semibold">{{ cron.last_cron_exec|format_datetime }}</div>
                                <div class="text-secondary">{{ cron.last_cron_exec|timeago }} {{ 'ago'|trans }}</div>
                            {% else %}
                                <div class="fw-semibold">{{ 'Scheduled tasks were never executed'|trans }}</div>
                            {% endif %}
                        </div>
                    </section>
                </div>
            </div>
        </div>
        <div class="card-body border-top">
            <form id="guest-cron-form" method="post" action="{{ 'cron/save_settings'|api_url }}" {{ fb_api_form({message: 'Configuration Updated'|trans, reload: true}) }}>
                <input type="hidden" name="ext" value="mod_cron">
                <div class="d-flex flex-column flex-lg-row align-items-lg-start justify-content-between gap-3 mb-3">
                    <div>
                        <h4 class="card-title mb-2">{{ 'Guest Cron Endpoint'|trans }}</h4>
                        <p class="text-secondary mb-0">{{ 'Toggle to enable or disable the guest cron URL. A security hash is generated automatically when enabled.'|trans }}</p>
                    </div>
                    <label class="form-check form-switch form-switch-2 m-0">
                        <input class="form-check-input" name="guest_cron" type="checkbox" {% if guest_cron %}checked="checked"{% endif %} onchange="document.getElementById('guest-cron-form').requestSubmit()">
                        <span class="form-check-label">{{ 'Enable Guest Access'|trans }}</span>
                    </label>
                </div>
                {% if guest_cron and cron_hash %}
                    <label class="form-label" for="guest-cron-url">{{ 'Guest Cron URL'|trans }}</label>
                    <input id="guest-cron-url" class="form-control font-monospace mb-2" type="text" value="{{ 'cron/run'|api_url(role: 'guest', query: {hash: cron_hash}) }}" readonly>
                    <div class="d-flex justify-content-end mb-3">
                        <a class="btn btn-outline-warning" href="{{ 'cron/regenerate_cron_hash'|api_url }}" {{ fb_api_link({message: 'Hash Regenerated'|trans, reload: true}) }}>
                            {{ 'Regenerate Hash'|trans }}
                        </a>
                    </div>
                {% endif %}
            </form>
        </div>
        <div class="card-footer d-flex justify-content-end">
            <a class="btn btn-primary" href="{{ 'cron/run'|api_url }}" target="_blank" {{ fb_api_link({message: 'Cron Executed'|trans}) }}>
                <svg class="icon icon-tabler">
                    <use href="#player-play"/>
                </svg>
                <span>{{ 'Execute Now'|trans }}</span>
            </a>
        </div>
    </div>

    <div class="card mt-3">
        <div class="card-header">
            <div>
                <h3 class="card-title">{{ 'What Runs on Every Cron Tick'|trans }}</h3>
                <p class="card-subtitle">{{ 'This runs every 5 minutes. Most of the tasks below happen every single time; a few only check in occasionally and skip themselves the rest of the time.'|trans }}</p>
            </div>
        </div>
        <div class="card-body">
            <h4 class="mb-2">{{ 'Runs every time (every 5 minutes)'|trans }}</h4>
            <ul class="mb-4">
                <li>{{ 'Pay invoices automatically using any account credit the client already has'|trans }}</li>
                <li>{{ 'Activate an order once its invoice has been paid'|trans }}</li>
                <li>{{ 'Send payment reminder emails for invoices coming due'|trans }}</li>
                <li>{{ 'Generate new invoices for upcoming renewals'|trans }}</li>
                <li>{{ 'Send the actual emails sitting in the outgoing mail queue - this is what "sends" every email the system generates'|trans }}</li>
                <li>{{ 'Suspend orders whose invoice is overdue'|trans }}</li>
                <li>{{ 'Cancel orders that have been suspended too long without being fixed'|trans }}</li>
                <li>{{ 'Auto-close support tickets that have had no reply for a while'|trans }}</li>
                <li>{{ 'Clear out expired "forgot password" links'|trans }}</li>
                <li>{{ 'Clear out abandoned shopping carts'|trans }}</li>
                <li>{{ 'Clean up old, expired login sessions from the database'|trans }}</li>
            </ul>

            <h4 class="mb-2">{{ 'Checks in every time, but only actually does something on its own schedule'|trans }}</h4>
            <ul class="mb-0">
                <li>{{ 'Domain status check with the registrar (e.g. OpenProvider) - confirms things like lock status and expiry date are still accurate. Runs once every 24 hours per domain by default (adjustable above under Domain Management).'|trans }}</li>
                <li>{{ 'Domain expiration date re-check against the registrar - a slower, once-a-month safety net alongside the daily check above.'|trans }}</li>
                <li>{{ 'Zoho Books sync - keeps invoices/payments in sync with Zoho Books. Runs every 5 minutes by default (adjustable in the Zoho Books extension settings).'|trans }}</li>
            </ul>
        </div>
    </div>
{% endblock %}
