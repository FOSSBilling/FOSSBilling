{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}

{% import 'macro_functions.html.twig' as mf %}

{% block meta_title %}{{ 'Cron Settings'|trans }}{% endblock %}

{% set active_menu = 'system' %}

{% block breadcrumbs %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="{{ '/'|url }}">
                <svg class="icon">
                    <use xlink:href="#home" />
                </svg>
            </a>
        </li>
        <li class="breadcrumb-item">
            <a href="{{ 'system'|url }}">{{ 'Settings'|trans }}</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">{{ 'Cron Settings'|trans }}</li>
    </ol>
{% endblock %}

{% block content %}
    <div class="card">
        <div class="card-header">
            <div>
                <h3 class="card-title">{{ 'Cron Settings'|trans }}</h3>
                <p class="card-subtitle">{{ 'Review cron status, confirm your schedule, and control whether the guest cron endpoint is available.'|trans }}</p>
            </div>
        </div>
        {% set cron = admin.cron_info %}
        <div class="table-responsive">
            <table class="table card-table table-vcenter table-striped text-nowrap">
                <tbody>
                <tr>
                    <td class="w-50 text-end">{{ 'Timezone'|trans }}:</td>
                    <td>{{ "now"|format_date(pattern='zzz') }}</td>
                </tr>
                <tr>
                    <td class="text-end">{{ 'Time on Server'|trans }}:</td>
                    <td>{{ "now"|format_datetime }}</td>
                </tr>
                <tr>
                    <td class="text-end">{{ 'Last Time Scheduled Tasks Were Executed'|trans }}:</td>
                    <td>
                        {% if cron.last_cron_exec %}
                            {{ cron.last_cron_exec|format_datetime }}
                            ({{ cron.last_cron_exec|timeago }} ago)
                        {% else %}
                            {{ 'Scheduled tasks were never executed'|trans }}
                        {% endif %}
                    </td>
                </tr>
                <tr>
                    <td class="text-end">{{ 'Recommended Crontab Setup'|trans }}:</td>
                    <td><code>*/5 * * * * php {{ cron.cron_path }}</code></td>
                </tr>
                </tbody>
            </table>
        </div>
        <div class="card-body border-top">
            {% set params = admin.extension_config_get({ 'ext': 'mod_cron' }) %}
            <form method="post" action="{{ 'extension/config_save'|api_url }}" {{ fb_api_form({message: 'Configuration Updated'|trans}) }}>
                <input type="hidden" name="ext" value="mod_cron">
                <div class="row align-items-start">
                    <div class="col-md-3">
                        <label class="form-label">{{ 'Enable the Cron API Endpoint for Guests'|trans }}</label>
                    </div>
                    <div class="col-md-1">
                        <label class="form-check form-switch">
                            <input class="form-check-input" name="guest_cron" type="checkbox" {% if params.guest_cron %} checked="checked"{% endif %}>
                        </label>
                    </div>
                    <div class="col-md-8">
                        <p class="text-muted mb-3">{{ 'If enabled, this URL can be used to execute the cronjob:'|trans }} {{ 'cron/run'|api_url(role: 'guest') }}</p>
                        <input class="btn btn-primary" type="submit" value="{{ 'Update'|trans }}">
                    </div>
                </div>
            </form>
        </div>
        <div class="card-footer text-center">
            <a class="btn btn-primary" href="{{'cron/run'|api_url }}" target="_blank" {{ fb_api_link({message: 'Cron Executed'|trans}) }}>
                <svg class="icon icon-tabler">
                    <use xlink:href="#play"/>
                </svg>
                <span>{{ 'Execute Now'|trans }}</span>
            </a>
        </div>
    </div>
{% endblock %}
