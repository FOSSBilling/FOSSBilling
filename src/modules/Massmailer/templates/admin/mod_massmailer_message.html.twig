{% extends 'layout_default.html.twig' %}

{% block meta_title %}{{ msg.subject }}{% endblock %}

{% set active_menu = 'system' %}

{% block content %}
<div class="p-3 d-flex flex-column gap-3">
    <form method="post" action="admin/massmailer/update" id="msg-form" {{ fb_api_form({callback: 'onAfterMessageUpdate'}) }}>
            {% embed 'partial_admin_form_card.html.twig' with {
                title: 'Message Details'|trans,
                subtitle: 'Set the sender identity and subject line for this mass-mail message.',
                card_class: 'mb-3'
            } %}
                {% block form_header_actions %}
                    <a href="{{ 'massmailer'|url }}" class="btn btn-secondary">
                        <svg class="icon">
                            <use href="#arrow-back-up" />
                        </svg>
                        {{ 'Back to List'|trans }}
                    </a>
                {% endblock %}

                {% block form_content %}
                    <div class="row g-3">
                        <div class="col-lg-4">
                            <label class="form-label">{{ 'From Name'|trans }}</label>
                            <input class="form-control" type="text" name="from_name" value="{{ msg.from_name }}" required="required" title="{{ 'From name'|trans }}">
                        </div>
                        <div class="col-lg-4">
                            <label class="form-label">{{ 'From Email'|trans }}</label>
                            <input class="form-control" type="text" name="from_email" value="{{ msg.from_email }}" required="required" title="{{ 'From email'|trans }}">
                        </div>
                        <div class="col-lg-4">
                            <label class="form-label">{{ 'Subject'|trans }}</label>
                            <input class="form-control" type="text" name="subject" value="{{ msg.subject }}" required="required"/>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed 'partial_admin_form_card.html.twig' with {
                title: 'Recipients Filter'|trans,
                subtitle: 'Leave every filter empty to send this message to all clients.',
                card_class: 'mb-3'
            } %}
                {% block form_content %}
                    <div class="row g-4">
                        <div class="col-lg-6">
                            <label class="form-label">{{ 'Client Status'|trans }}</label>
                            <div class="form-text mb-2">{{ 'Limit recipients to clients with these account states.'|trans }}</div>
                            <select class="form-select" name="filter[client_status][]" multiple="multiple" size="4">
                                <option value="active" {% if 'active' in msg.filter.client_status %} selected="selected"{% endif %}>{{ 'Active'|trans }}</option>
                                <option value="suspended" {% if 'suspended' in msg.filter.client_status %} selected="selected"{% endif %}>{{ 'Suspended'|trans }}</option>
                                <option value="canceled" {% if 'canceled' in msg.filter.client_status %} selected="selected"{% endif %}>{{ 'Canceled'|trans }}</option>
                            </select>
                        </div>
                        <div class="col-lg-6">
                            <label class="form-label">{{ 'Client Groups'|trans }}</label>
                            <div class="form-text mb-2">{{ 'Target only clients assigned to these groups.'|trans }}</div>
                            <select class="form-select" name="filter[client_groups][]" multiple="multiple" size="4">
                                {% for id,label in admin.client_group_get_pairs %}
                                    <option value="{{id}}" {% if id in msg.filter.client_groups %} selected="selected"{% endif %}>{{label}}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-lg-6">
                            <label class="form-label">{{ 'Has Order With Status'|trans }}</label>
                            <div class="form-text mb-2">{{ 'Match clients who have orders currently in these states.'|trans }}</div>
                            <select class="form-select" name="filter[has_order_with_status][]" multiple="multiple" size="6">
                                {% for id,label in admin.order_get_status_pairs %}
                                    <option value="{{id}}" {% if id in msg.filter.has_order_with_status %} selected="selected"{% endif %}>{{label}}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-lg-6">
                            <label class="form-label">{{ 'Has Order'|trans }}</label>
                            <div class="form-text mb-2">{{ 'Match clients who have purchased any of these products.'|trans }}</div>
                            <select class="form-select" name="filter[has_order][]" multiple="multiple" size="6">
                                {% for id,label in admin.product_get_pairs %}
                                    <option value="{{id}}" {% if id in msg.filter.has_order %} selected="selected"{% endif %}>{{label}}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                {% endblock %}
            {% endembed %}

            {% embed 'partial_admin_form_card.html.twig' with {
                title: 'Email Content'|trans
            } %}
                {% block form_content %}
                    {% embed 'partial_admin_inner_tabs.html.twig' with { nav_id: 'content-tabs' } %}
                        {% block inner_tabs %}
                            <li class="nav-item" role="presentation">
                                <a href="#tab-message" class="nav-link active" data-bs-toggle="tab" data-bs-target="#tab-message" aria-selected="true"
                                   role="tab">{{ 'Message'|trans }}</a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a href="#tab-preview" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-preview" aria-selected="false" role="tab"
                                   tabindex="-1">
                                    {{ 'Preview'|trans }}
                                </a>
                            </li>
                            <li class="nav-item" role="presentation">
                                <a href="#tab-recipients" class="nav-link" data-bs-toggle="tab" data-bs-target="#tab-recipients" aria-selected="false" role="tab"
                                   tabindex="-1" id="recipient-tab">
                                    {{ 'Recipients'|trans }}
                                </a>
                            </li>
                        {% endblock %}

                        {% block inner_tab_content %}
                            <div class="tab-pane fade show active" id="tab-message" role="tabpanel">
                                <div class="card-body">
                                    <textarea class="form-control" name="content" cols="5" rows="20"
                                              placeholder="Email content">{{ msg.content }}</textarea>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="tab-preview" role="tabpanel">
                                <div class="p-4" id="preview-banner">
                                    <h5 class="card-title mb-1">{{ 'Preview'|trans }}</h5>
                                    <p class="text-secondary mb-0">{{ 'Click'|trans }} <strong>{{ 'Update and Preview'|trans }}</strong> {{ 'to render the current message content and subject.'|trans }}</p>
                                </div>
                                <div class="d-none" id="preview">
                                    <div class="card-body border-bottom">
                                        <h5 class="card-title mb-1" id="preview-title"></h5>
                                        <p class="text-secondary mb-0">{{ 'Rendered message body using the current template and recipient filter context.'|trans }}</p>
                                    </div>
                                    <div class="card-body" id="preview-content"></div>
                                </div>
                            </div>
                            <div class="tab-pane fade" id="tab-recipients" role="tabpanel">
                                <div class="p-4" id="recipients-banner">
                                    <h5 class="card-title mb-1">{{ 'Recipients'|trans }}</h5>
                                    <p class="text-secondary mb-0">{{ 'Click'|trans }} <strong>{{ 'Update and Preview'|trans }}</strong> {{ 'to preview which clients match the current filters.'|trans }}</p>
                                </div>
                                <div class="d-none" id="recipients">
                                    <div class="card-body border-bottom">
                                        <h5 class="card-title mb-1">{{ 'Message Recipients'|trans }}</h5>
                                        <p class="text-secondary mb-0">{{ 'These clients currently match the selected audience filters.'|trans }}</p>
                                    </div>
                                    <div class="card-body">
                                        <ul class="list-group" id="recipient-list" style="max-height: 1000px; overflow-y: auto;">
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        {% endblock %}
                    {% endembed %}
                {% endblock %}

                {% block form_actions %}
                    <div class="d-flex justify-content-between align-items-center w-100">
                        <div class="d-flex gap-2">
                            <input type="submit" value="{{ 'Update and Preview'|trans }}" class="btn btn-secondary">
                            <input type="button" value="{{ 'Send Test Message'|trans }}" class="btn btn-success" id="send-test-msg">
                        </div>
                        <input type="button" value="{{ 'Send Message to Clients'|trans }}" class="btn btn-primary" id="send-msg">
                    </div>
                {% endblock %}
            {% endembed %}
        <input type="hidden" name="id" value="{{ msg.id }}">
    </form>
</div>
{% endblock %}

{% block js %}
{% autoescape "js" %}
<script>
    function onAfterMessageUpdate() {
        FOSSBilling.api.admin.post('massmailer/preview', { id: {{ msg.id }}, include_recipients: 1 },
            (result) => {
                document.querySelector('#recipients-banner').classList.add('d-none');
                document.querySelector('#preview-banner').classList.add('d-none');
                document.querySelector('#recipients').classList.remove('d-none');
                document.querySelector('#preview').classList.remove('d-none');
                document.querySelector('#preview-title').textContent = result.subject;
                document.querySelector('#preview-content').innerHTML = result.content;
                document.getElementById('recipient-list').innerHTML = '';

                result.recipients.forEach(function(recipient) {
                    const listItem = document.createElement('li');
                    listItem.classList.add('list-group-item');
                    listItem.textContent = recipient.name.concat(' (', recipient.email, ')');
                    document.getElementById('recipient-list').appendChild(listItem);
                });

                document.getElementById('recipient-tab').textContent = '{{ 'Recipients'|trans }}'.concat(' (', result.recipients.length, ')');

                const previewTab = new bootstrap.Tab(document.querySelector('#content-tabs a[data-bs-target="#tab-preview"]'));
                previewTab.show();
            });
    }

    document.querySelector('#send-msg').addEventListener('click', function() {
        Modals.create({
            type: 'small-confirm',
            title: 'Send message to clients?',
            content: 'Are you sure you want to send this message to clients?',
            confirmCallback: () => {
                FOSSBilling.api.admin.post('massmailer/send', { id: {{ msg.id }} },
                    (result) => {
                        FOSSBilling.message("{{ 'Message was added to mail queue and will be sent with scheduled tasks.'|trans }}");
                    });
            },
        });
    });

    document.querySelector('#send-test-msg').addEventListener('click', function() {
        Modals.create({
            type: 'small-confirm',
            title: 'Send test message?',
            content: 'Are you sure you want to send a test message?',
            confirmCallback: () => {
                FOSSBilling.api.admin.post('massmailer/send_test', { id: {{ msg.id }} },
                    (result) => {
                        FOSSBilling.message("{{ 'Message was sent.'|trans }}");
                    });
            },
        })
    });
</script>
{% endautoescape %}
{% endblock %}
