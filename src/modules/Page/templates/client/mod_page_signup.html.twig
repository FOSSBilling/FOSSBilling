{% extends "layout_public.html.twig" %}

{% import "macro_functions.html.twig" as mf %}

{% block meta_title %}{{ 'Register'|trans }}{% endblock %}
{% block meta_description %}{{ 'Create an account to order services, manage billing, and track support requests online.'|trans }}{% endblock %}

{% block body_class %}page-signup{% endblock %}
{% block body %}
<div class="tn-auth">
    <div class="tn-auth__visual" aria-hidden="true">
        <img src="https://picsum.photos/seed/tn-auth-workspace-launch/1200/1500" alt="" loading="eager">
        <div class="tn-auth__visual-content">
            <p class="tn-auth__visual-quote">{{ 'Register a domain, add hosting, done.'|trans }}</p>
            <p class="tn-auth__visual-sub">{{ 'Browsing the store and checking prices doesn\'t need an account. Creating one takes about a minute.'|trans }}</p>
        </div>
    </div>

    <div class="tn-auth__panel">
        <div class="tn-auth__panel-inner">
            {% if settings.login_page_show_logo %}
                {{ include('partial_company_logo.html.twig', {
                    company: company,
                    logo_url: public_logo_url,
                    dark_logo_url: public_dark_logo_url,
                    link_url: settings.login_page_logo_url|default('/'),
                    link_target: '_blank',
                    link_rel: 'noopener noreferrer',
                    image_height: '32px'
                }) }}
            {% endif %}

            <div class="tn-auth__head">
                <h1 class="tn-auth__title">{{ 'Create an account'|trans }}</h1>
                <p class="tn-auth__sub">{{ 'Free to create. You only pay when you order.'|trans }}</p>
            </div>

            <form method="post" action="{{ 'client/create'|api_url(role: 'guest') }}" class="auth tn-auth__form" {{ fb_api_form({redirect: '/'|url}) }}>
                {% set r = guest.client_required %}

                <div class="tn-auth__row">
                    <div class="tn-field">
                        <label class="tn-field__label" for="first-name">{{ 'First name'|trans }}</label>
                        <input class="tn-input" id="first-name" type="text" name="first_name"
                               value="{{ request.first_name }}" required="required"/>
                    </div>
                    <div class="tn-field">
                        <label class="tn-field__label" for="last_name">{{ 'Last name'|trans }}</label>
                        <input class="tn-input" id="last_name" type="text" name="last_name"
                               value="{{ request.last_name }}"{% if 'last_name' in r %} required="required"{% endif %}/>
                    </div>
                </div>

                <div class="tn-field">
                    <label class="tn-field__label" for="reg-email">{{ 'Email address'|trans }}</label>
                    <input class="tn-input" id="reg-email" type="email" name="email"
                           value="{{ request.email }}" required="required"/>
                </div>

                {% if 'company' in r %}
                    <div class="tn-field">
                        <label class="tn-field__label" for="company">{{ 'Company'|trans }}</label>
                        <input class="tn-input" id="company" type="text" name="company"
                               value="{{ request.company }}" required="required"/>
                    </div>
                {% endif %}

                {% if 'birthday' in r %}
                    <div class="tn-field">
                        <label class="tn-field__label" for="birthday">{{ 'Birthday'|trans }}</label>
                        <input class="tn-input" id="birthday" type="date" name="birthday" value=""/>
                    </div>
                {% endif %}

                {% if 'gender' in r %}
                    <div class="tn-field">
                        <label class="tn-field__label" for="gender">{{ 'Gender'|trans }}</label>
                        <div class="tn-select-wrap">
                            <select class="tn-select" id="gender" name="gender">
                                <option value="male">{{ 'Male'|trans }}</option>
                                <option value="female">{{ 'Female'|trans }}</option>
                                <option value="nonbinary">{{ 'Non-binary'|trans }}</option>
                                <option value="other">{{ 'Other'|trans }}</option>
                            </select>
                        </div>
                    </div>
                {% endif %}

                {% if 'address_1' in r %}
                    <div class="tn-field">
                        <label class="tn-field__label" for="address_1">{{ 'Address'|trans }}</label>
                        <input class="tn-input" id="address_1" type="text" name="address_1"
                               value="{{ request.address_1 }}"/>
                    </div>
                {% endif %}

                {% if 'address_2' in r %}
                    <div class="tn-field">
                        <label class="tn-field__label" for="address_2">{{ 'Address 2'|trans }}</label>
                        <input class="tn-input" id="address_2" type="text" name="address_2"
                               value="{{ request.address_2 }}"/>
                    </div>
                {% endif %}

                {% if 'city' in r %}
                    <div class="tn-field">
                        <label class="tn-field__label" for="city">{{ 'City'|trans }}</label>
                        <input class="tn-input" id="city" type="text" name="city"
                               value="{{ request.city }}"/>
                    </div>
                {% endif %}

                {% if 'country' in r %}
                    <div class="tn-field">
                        <label class="tn-field__label" for="country">{{ 'Country'|trans }}</label>
                        <div class="tn-select-wrap">
                            <select class="tn-select" id="country" name="country" required="required">
                                <option value="">{{ '-- Select country --'|trans }}</option>
                                {% for val,label in guest.system_countries %}
                                    <option value="{{ val }}" label="{{ label|e }}" {% if request.country|default(guest.system_default_country) == val %}selected{% endif %}>{{ label|e }}</option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                {% endif %}

                {% if 'state' in r %}
                    <div class="tn-field">
                        <label class="tn-field__label" for="state">{{ 'State'|trans }}</label>
                        <input class="tn-input" id="state" type="text" name="state"
                               value="{{ request.state }}"/>
                    </div>
                {% endif %}

                {% if 'postcode' in r %}
                    <div class="tn-field">
                        <label class="tn-field__label" for="postcode">{{ 'Zip / postal code'|trans }}</label>
                        <input class="tn-input" id="postcode" type="text" name="postcode"
                               value="{{ request.postcode }}"/>
                    </div>
                {% endif %}

                {% if 'phone' in r %}
                    <div class="tn-field">
                        <label class="tn-field__label" for="phone">{{ 'Phone number'|trans }}</label>
                        <input type="hidden" id="phone_cc" name="phone_cc" value="{{ request.phone_cc }}">
                        <input class="tn-input js-phone-input" id="phone" type="tel" name="phone" value="{{ request.phone }}" autocomplete="tel" data-initial-country="{{ request.country|default(guest.system_default_country)|lower }}" required="required"/>
                    </div>
                {% endif %}

                <div class="tn-field">
                    <label class="tn-field__label" for="reg-timezone">{{ 'Timezone'|trans }}</label>
                    <div class="tn-select-wrap">
                        <select class="tn-select" id="reg-timezone" name="timezone" data-timezone-select>
                            <option value="">{{ '-- Use system default --'|trans }}</option>
                            {% for region, identifiers in guest.system_timezones %}
                                <optgroup label="{{ region }}">
                                    {% for identifier in identifiers %}
                                        <option value="{{ identifier }}" {% if request.timezone|default('') == identifier %}selected="selected"{% endif %}>{{ identifier }}</option>
                                    {% endfor %}
                                </optgroup>
                            {% endfor %}
                        </select>
                    </div>
                    <span class="tn-field__hint">{{ 'Pre-selected from your browser. Used to display dates and times in your local time.'|trans }}</span>
                </div>

                {% set custom_fields = guest.client_custom_fields %}
                {% for field_name, field in custom_fields %}
                    {% if field.active %}
                        <div class="tn-field">
                            <label class="tn-field__label"
                                   for="{{ field_name }}">{{ field.title is not empty ? field.title : field_name|capitalize }}</label>
                            <input class="tn-input" id="{{ field_name }}" type="text"
                                   name="{{ field_name }}" value="{{ request.(field_name) }}"
                                   {% if field.required %}required="required"{% endif %} />
                        </div>
                    {% endif %}
                {% endfor %}

                {% set honeypot = antispam_honeypot() %}
                {% if honeypot.enabled %}
                    {% set honeypot_field = honeypot.field %}
                    <div class="tn-field" style="position: absolute; left: -9999px;">
                        <label class="tn-field__label" for="{{ honeypot_field }}">{{ honeypot_field }}</label>
                        <input class="tn-input" id="{{ honeypot_field }}" type="text" name="{{ honeypot_field }}" value="" tabindex="-1" autocomplete="off"/>
                    </div>
                {% endif %}

                <div class="tn-field">
                    <label class="tn-field__label" for="reg-password">{{ 'Password'|trans }}</label>
                    <input class="tn-input" id="reg-password" type="password" name="password" value=""
                           required="required"/>
                </div>

                <div class="tn-field">
                    <label class="tn-field__label" for="password-confirm">{{ 'Confirm password'|trans }}</label>
                    <input class="tn-input" id="password-confirm" type="password" name="password_confirm" value="" required="required"/>
                </div>

                {{ mf.recaptcha }}

                {% if settings.signup_tos|default('0') == 'explicit' %}
                    <label class="tn-checkbox-wrap">
                        <input class="tn-checkbox-input" type="checkbox" value="" id="flexCheckDefault" required>
                        <span class="tn-checkbox-box"></span>
                        <span>{{ 'I agree to the'|trans }} <a href="{{ 'tos'|url }}" target="_blank">{{ 'Terms of Service'|trans }}</a> {{ 'and'|trans }} <a href="{{ 'privacy-policy'|url }}" target="_blank">{{ 'Privacy Policy'|trans }}</a>.</span>
                    </label>
                {% endif %}

                <div class="tn-auth__actions">
                    <button class="tn-btn tn-btn--primary tn-btn--lg tn-btn--block" type="submit">{{ 'Create account'|trans }}</button>
                </div>

                {% if settings.signup_tos|default('0') == 'implicit' %}
                    <p class="tn-auth__consent">{{ 'By creating an account, you agree to our'|trans }} <a href="{{ 'tos'|url }}" target="_blank">{{ 'Terms of Service'|trans }}</a> {{ 'and'|trans }} <a href="{{ 'privacy-policy'|url }}" target="_blank">{{ 'Privacy Policy'|trans }}</a>.</p>
                {% endif %}
            </form>

            <p class="tn-auth__foot">
                {{ 'Already have an account?'|trans }}
                <a href="{{ 'login'|url }}">{{ 'Sign in'|trans }}</a>
                {% if settings.show_password_reset_link %}
                    &nbsp;·&nbsp;<a href="{{ 'password-reset'|url }}">{{ 'Forgot password?'|trans }}</a>
                {% endif %}
            </p>
        </div>
    </div>
</div>
{% endblock %}
