{% extends "layout_default.html.twig" %}

{% set company = guest.system_company %}

{% block meta_title %}{{ 'Privacy policy'|trans }}{% endblock %}
{% block meta_description %}{{ 'Learn how %company% collects, uses, and protects personal information.'|trans({'%company%': company.name}) }}{% endblock %}

{% block body_class %}privacy-policy{% endblock %}
{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'Privacy'|trans }}</li>
{% endblock %}

{% block content %}
    <div class="tn-card">
        <div class="tn-card__header">
            <div>
                {% if company is defined and company %}
                    <span class="tn-card__title">{{ company.name }} {{ 'privacy policy'|trans }}</span>
                    {% if company.signature %}<div class="tn-card__subtitle">{{ company.signature }}</div>{% endif %}
                {% else %}
                    <span class="tn-card__title">{{ 'Privacy policy'|trans }}</span>
                {% endif %}
            </div>
        </div>
        {% if company is defined and company %}
            <div class="tn-prose">{{ (company.privacy_policy ?? '')|markdown_to_html }}</div>
        {% endif %}
    </div>
{% endblock %}
