{% extends "layout_public.html.twig" %}

{% block meta_title %}{{ 'Login'|trans }}{% endblock %}
{% block meta_description %}{{ 'Log in to manage your services, invoices, support tickets, and account details.'|trans }}{% endblock %}

{% block body_class %}page-login{% endblock %}
{% block body %}
<div class="tn-auth">
    <div class="tn-auth__visual" aria-hidden="true">
        <img src="https://images.unsplash.com/photo-1512632578888-169bbbc64f33?q=80&amp;w=1920&amp;auto=format&amp;fit=crop" alt="" loading="eager">
        <div class="tn-auth__visual-content">
            <p class="tn-auth__visual-quote">{{ 'Every domain, every renewal, every invoice. One login.'|trans }}</p>
            <p class="tn-auth__visual-sub">{{ 'Nothing lapses quietly. You get a heads-up before anything expires or comes due.'|trans }}</p>
        </div>
    </div>

    <div class="tn-auth__panel">
        <div class="tn-auth__panel-inner">
            {% if settings.login_page_show_logo %}
                {{ include('partial_company_logo.html.twig', {
                    company: company,
                    logo_url: public_logo_url,
                    dark_logo_url: public_dark_logo_url,
                    link_url: settings.login_page_logo_url|default('/'),
                    link_target: '_blank',
                    link_rel: 'noopener noreferrer',
                    image_height: '32px'
                }) }}
            {% endif %}

            <div class="tn-auth__head">
                <h1 class="tn-auth__title">{{ 'Sign in'|trans }}</h1>
                <p class="tn-auth__sub">{{ 'Manage services, invoices and support tickets.'|trans }}</p>
            </div>

            {{ render_widgets('client.page.login.form.before') }}
            <form method="post" action="{{ 'client/login'|api_url(role: 'guest') }}" class="auth tn-auth__form" {{ fb_api_form({redirect: redirect_uri|default('/')|url}) }}>
                <div class="tn-field">
                    <label class="tn-field__label" for="email">{{ 'Email'|trans }}</label>
                    <input class="tn-input" id="email" type="email" placeholder="you@company.com" name="email" value="{{ request.email }}" required="required" autofocus>
                </div>
                <div class="tn-field">
                    <label class="tn-field__label" for="password">{{ 'Password'|trans }}</label>
                    <input class="tn-input" id="password" type="password" placeholder="••••••••••" name="password" required="required">
                </div>
                {% if settings.show_password_reset_link %}
                    <div class="tn-auth__meta">
                        <a class="tn-auth__link" href="{{ 'password-reset'|url }}">{{ 'Forgot password?'|trans }}</a>
                    </div>
                {% endif %}
                <button type="submit" class="tn-btn tn-btn--primary tn-btn--lg tn-btn--block">{{ 'Sign in'|trans }}</button>
            </form>
            {{ render_widgets('client.page.login.form.after') }}

            {% if settings.show_signup_link %}
                <p class="tn-auth__foot">
                    {{ 'New here?'|trans }}
                    <a href="{{ 'signup'|url }}">{{ 'Create an account'|trans }}</a>{{ ', it takes a minute.'|trans }}
                </p>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
