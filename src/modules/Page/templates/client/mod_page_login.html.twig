{% extends "layout_public.html.twig" %}

{% set company = guest.system_company %}

{% if settings.theme == 'dark' %}
    {% set logo_url =  company.logo_url_dark %}
{% else %}
    {% set logo_url =  company.logo_url %}
{% endif %}
{% set auth_hero_enabled = settings.auth_hero_enabled is not defined or settings.auth_hero_enabled == '1' %}
{% set auth_login_hero_title = settings.auth_login_hero_title is defined ? settings.auth_login_hero_title : 'Welcome back'|trans %}
{% set auth_login_hero_subtitle = settings.auth_login_hero_subtitle is defined ? settings.auth_login_hero_subtitle : 'Manage your billing, services, invoices, and support tickets from one secure place.'|trans %}
{% set auth_login_heading_title = settings.auth_login_heading_title is defined ? settings.auth_login_heading_title : 'Login to your account'|trans %}
{% set auth_login_heading_subtitle = settings.auth_login_heading_subtitle is defined ? settings.auth_login_heading_subtitle : 'Enter your details below to continue to the client area.'|trans %}

{% block meta_title %}{{ 'Login'|trans }}{% endblock %}

{% block body_class %}page-login{% endblock %}
{% block body %}
<div class="auth-shell container">
    <div class="auth-panel{% if not auth_hero_enabled %} auth-panel-no-hero{% endif %} row g-0">
        {% if auth_hero_enabled %}
            <div class="auth-hero col-lg-5 d-none d-lg-flex">
                <div class="auth-hero-content">
                    {% if auth_login_hero_title %}<h1>{{ auth_login_hero_title }}</h1>{% endif %}
                    {% if auth_login_hero_subtitle %}<p>{{ auth_login_hero_subtitle }}</p>{% endif %}
                </div>
            </div>
        {% endif %}
        <div class="auth-form-column col-lg-{{ auth_hero_enabled ? '7' : '12' }}">
            <div class="auth-card card">
                <div class="card-body">
                    {% if settings.login_page_show_logo %}
                        <div class="auth-brand">
                            <a href="{{ settings.login_page_logo_url|default('/') }}" target="_blank" rel="noopener">
                                <img src="{{ logo_url }}" alt="{{ company.name }}"/>
                            </a>
                        </div>
                    {% endif %}

                    <div class="auth-heading">
                        {% if auth_login_heading_title %}<h1>{{ auth_login_heading_title }}</h1>{% endif %}
                        {% if auth_login_heading_subtitle %}<p>{{ auth_login_heading_subtitle }}</p>{% endif %}
                    </div>

                    <form method="post" action="{{ 'client/login'|api_url(role: 'guest') }}" class="auth" {{ fb_api_form({redirect: redirect_uri|default('/')|url}) }}>
                        <div class="mb-3">
                            <label class="form-label" for="email">{{ 'Email'|trans }}</label>
                            <input class="form-control" id="email" type="email" placeholder="{{ 'Enter your email address'|trans }}" name="email" value="{{ request.email }}" required="required" autocomplete="email" autofocus>
                        </div>
                        <div class="mb-4">
                            <label class="form-label" for="password">{{ 'Password'|trans }}</label>
                            <input class="form-control" id="password" type="password" placeholder="{{ 'Enter your password'|trans }}" name="password" required="required" autocomplete="current-password">
                        </div>
                        <button type="submit" class="btn btn-primary w-100">{{ 'Login'|trans }}</button>
                    </form>

                    {% if settings.show_password_reset_link or settings.show_signup_link %}
                        <div class="auth-actions">
                            {% if settings.show_signup_link %}
                                <a class="btn btn-outline-primary" href="{{ 'signup'|url }}">{{ 'Create Account'|trans }}</a>
                            {% endif %}
                            {% if settings.show_password_reset_link %}
                                <a class="btn btn-link" href="{{ 'password-reset'|url }}">{{ 'Forgot Password?'|trans }}</a>
                            {% endif %}
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
