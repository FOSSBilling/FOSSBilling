{% extends "layout_public.html.twig" %}

{% import "macro_functions.html.twig" as mf %}

{% block meta_title %}{{ 'Reset Password'|trans }}{% endblock %}
{% set company = guest.system_company %}

{% if settings.theme == 'dark' %}
    {% set logo_url =  company.logo_url_dark %}
{% else %}
    {% set logo_url =  company.logo_url %}
{% endif %}
{% set auth_hero_enabled = settings.auth_hero_enabled is not defined or settings.auth_hero_enabled == '1' %}
{% set auth_password_reset_hero_title = settings.auth_password_reset_hero_title is defined ? settings.auth_password_reset_hero_title : 'Recover access'|trans %}
{% set auth_password_reset_hero_subtitle = settings.auth_password_reset_hero_subtitle is defined ? settings.auth_password_reset_hero_subtitle : 'Request a secure password reset link and get back to managing your account.'|trans %}
{% set auth_password_reset_heading_title = settings.auth_password_reset_heading_title is defined ? settings.auth_password_reset_heading_title : 'Reset your password'|trans %}
{% set auth_password_reset_heading_subtitle = settings.auth_password_reset_heading_subtitle is defined ? settings.auth_password_reset_heading_subtitle : 'Enter your email address and we will send reset instructions if an account exists.'|trans %}

{% block body_class %}page-password-reset{% endblock %}
{% block body %}
<div class="auth-shell container">
    <div class="auth-panel{% if not auth_hero_enabled %} auth-panel-no-hero{% endif %} row g-0">
        {% if auth_hero_enabled %}
            <div class="auth-hero col-lg-5 d-none d-lg-flex">
                <div class="auth-hero-content">
                    {% if auth_password_reset_hero_title %}<h1>{{ auth_password_reset_hero_title }}</h1>{% endif %}
                    {% if auth_password_reset_hero_subtitle %}<p>{{ auth_password_reset_hero_subtitle }}</p>{% endif %}
                </div>
            </div>
        {% endif %}
        <div class="auth-form-column col-lg-{{ auth_hero_enabled ? '7' : '12' }}">
            <div class="auth-card card">
                <div class="card-body">
                    {% if settings.login_page_show_logo %}
                        <div class="auth-brand">
                            <a href="{{ settings.login_page_logo_url|default('/') }}" target="_blank" rel="noopener">
                                <img src="{{ logo_url }}" alt="{{ company.name }}"/>
                            </a>
                        </div>
                    {% endif %}

                    <div class="auth-heading">
                        {% if auth_password_reset_heading_title %}<h1>{{ auth_password_reset_heading_title }}</h1>{% endif %}
                        {% if auth_password_reset_heading_subtitle %}<p>{{ auth_password_reset_heading_subtitle }}</p>{% endif %}
                    </div>

                    <form method="post" action="{{ 'client/reset_password'|api_url(role: 'guest') }}" {{ fb_api_form({message: 'A password reset confirmation email will be sent to you if we found an account with that email address.'|trans}) }}>
                        <div class="mb-4">
                            <label class="form-label" for="email">{{ 'Email'|trans }}</label>
                            <input class="form-control" id="email" type="email" placeholder="{{ 'Enter your email address'|trans }}" name="email" value="{{ request.email }}" required="required" autocomplete="email" autofocus>
                        </div>
                        {{ mf.recaptcha }}
                        <button type="submit" class="btn btn-primary w-100">{{ 'Send reset link'|trans }}</button>
                    </form>

                    <div class="auth-actions">
                        <a class="btn btn-outline-primary" href="{{ 'login'|url }}">{{ 'Back to Login'|trans }}</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
