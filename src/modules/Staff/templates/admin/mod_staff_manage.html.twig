{% extends 'layout_default.html.twig' %}

{% block meta_title %}{{ staff.name }}{% endblock %}

{% set active_menu = 'system' %}
{% set can_manage_groups = has_permission('staff', 'manage_groups') %}

{% block breadcrumbs %}
	<ol class="breadcrumb">
		<li class="breadcrumb-item">
			<a href="{{ '/'|url }}">
				<svg class="icon">
					<use href="#home"/>
				</svg>
			</a>
		</li>
		<li class="breadcrumb-item">
			<a href="{{ 'system'|url }}">{{ 'Settings'|trans }}</a>
		</li>
		<li class="breadcrumb-item">
			<a href="{{ 'extension/settings/staff'|url }}">{{ 'Staff'|trans }}</a>
		</li>
		<li class="breadcrumb-item active" aria-current="page">{{ staff.name }}</li>
	</ol>
{% endblock %}

{% block content %}
	{% if staff.system_name == 'cron' %}
		<div class="alert alert-info" role="alert" id="external-ip">
			{{ 'This staff member is used by FOSSBilling to perform system tasks and cannot be removed.'|trans }}
		</div>
	{% endif %}

	{% embed 'partial_admin_detail_tabs.html.twig' with {
		title: staff.name,
		subtitle: 'Manage the staff profile, groups, and password for this administrator account.'|trans
	} %}
		{% block detail_tabs %}
						<li class="nav-item" role="presentation">
							<a class="nav-link active" href="#tab-profile" data-bs-toggle="tab" role="tab">{{ 'Profile'|trans }}</a>
						</li>
						<li class="nav-item" role="presentation">
							<a class="nav-link" href="#tab-groups" data-bs-toggle="tab" role="tab">{{ 'Groups'|trans }}</a>
						</li>
						<li class="nav-item" role="presentation">
							<a class="nav-link" href="#tab-password" data-bs-toggle="tab" role="tab">{{ 'Password'|trans }}</a>
						</li>
		{% endblock %}

		{% block detail_tab_content %}
			{% import 'macro_functions.html.twig' as mf %}
			<div class="tab-pane fade show active" id="tab-profile" role="tabpanel">
				<div class="p-3">
					<form method="post" action="admin/staff/update" {{ fb_api_form({message: 'Staff Member Details Updated'|trans}) }}>
						{% embed 'partial_admin_form_card.html.twig' with {
							title: 'Staff Member Details'|trans,
							subtitle: 'Update the staff member account identity, status, and signature.'|trans
						} %}
							{% import 'macro_functions.html.twig' as mf %}
							{% block form_content %}
								<div class="row g-3">
									<div class="col-lg-6">
										<label class="form-label" for="inputName">{{ 'Name'|trans }}</label>
										<input class="form-control" id="inputName" type="text" name="name" value="{{ staff.name }}" required>
									</div>
									<div class="col-lg-6">
										<label class="form-label" for="inputEmail">{{ 'Email'|trans }}</label>
										<input class="form-control" id="inputEmail" type="text" name="email" value="{{ staff.email }}" required>
									</div>
									<div class="col-lg-6">
										<label class="form-label d-block">{{ 'Status'|trans }}</label>
										<div class="d-flex flex-wrap gap-3">
											<label class="form-check">
												<input class="form-check-input" id="radioStatusActive" type="radio" name="status" value="active" {% if staff.status == 'active' %} checked {% endif %}>
												<span class="form-check-label">{{ 'Active'|trans }}</span>
											</label>
											<label class="form-check">
												<input class="form-check-input" id="radioStatusInactive" type="radio" name="status" value="inactive" {% if staff.status == 'inactive' %} checked {% endif %}>
												<span class="form-check-label">{{ 'Inactive'|trans }}</span>
											</label>
										</div>
									</div>
									<div class="col-12">
										<label class="form-label" for="textareaSignature">{{ 'Signature'|trans }}</label>
										<textarea class="form-control" id="textareaSignature" name="signature" rows="2">{{ staff.signature }}</textarea>
									</div>
								</div>
								<input type="hidden" name="id" value="{{ staff.id }}">
							{% endblock %}

							{% block form_actions %}
								<button class="btn btn-primary" type="submit">{{ 'Update details'|trans }}</button>
							{% endblock %}
						{% endembed %}
					</form>
				</div>
			</div>

			<div class="tab-pane fade" id="tab-groups" role="tabpanel">
				<div class="p-3">
					{% set assigned_groups = [] %}
					{% if can_manage_groups %}
						{% set assigned_groups = admin.staff_admin_group_get_list({ 'admin_id': staff.id }) %}
					{% endif %}
					{% embed 'partial_admin_form_card.html.twig' with {
						title: 'Groups'|trans,
						subtitle: 'Manage this staff member\'s group memberships.'|trans
					} %}
						{% import 'macro_functions.html.twig' as mf %}
						{% block form_content %}
							{% if can_manage_groups %}
								<form method="post" action="{{ 'staff/group_member_add'|api_url }}" class="row g-3 align-items-end mb-4" {{ fb_api_form({message: 'Group added'|trans, reload: true}) }}>
									<input type="hidden" name="admin_id" value="{{ staff.id }}">
									<div class="col-lg-8">
										<label class="form-label" for="staff-group-add">{{ 'Add group'|trans }}</label>
										{{ mf.selectbox('group_id', admin.staff_group_get_pairs, '', 0, 'Select group'|trans) }}
									</div>
									<div class="col-lg-4">
										<button class="btn btn-primary w-100" type="submit">{{ 'Add group'|trans }}</button>
									</div>
								</form>

								{% if assigned_groups|length > 0 %}
									<div class="list-group">
										{% for group in assigned_groups %}
											<div class="list-group-item d-flex align-items-center justify-content-between gap-3">
												<div>
													<a href='{{ "staff/group/#{group.id}"|url }}'>{{ group.name }}</a>
													{% if group.protected %}
														<span class="badge bg-blue-lt ms-2">{{ 'System'|trans }}</span>
													{% endif %}
												</div>
												<a class="btn btn-outline-danger" href="{{ 'staff/group_member_remove'|api_url(query: { 'admin_id': staff.id, 'group_id': group.id }) }}"
													{{ fb_api_link({modal: {type: 'confirm', title: 'Are you sure?'|trans}, reload: true}) }}>
													{{ 'Remove from group'|trans }}
												</a>
											</div>
										{% endfor %}
									</div>
								{% else %}
									<div class="alert alert-warning mb-0" role="alert">{{ 'This staff member is not assigned to any groups.'|trans }}</div>
								{% endif %}
							{% else %}
								<div class="alert alert-info mb-0" role="alert">{{ 'You do not have permission to manage this staff member\'s groups.'|trans }}</div>
							{% endif %}
						{% endblock %}
					{% endembed %}
				</div>
			</div>

			<div class="tab-pane fade" id="tab-password" role="tabpanel">
				<div class="p-3">
					<form method="post" action="admin/staff/change_password" {{ fb_api_form({message: 'Staff Member Password Changed'|trans}) }}>
						{% embed 'partial_admin_form_card.html.twig' with {
							title: 'Change Staff Member Password'|trans,
							subtitle: 'Set a new password for this staff account and confirm it before saving.'|trans
						} %}
							{% block form_content %}
								<div class="row g-3">
									<div class="col-lg-6">
										<label class="form-label" for="inputPassword">{{ 'Password'|trans }}</label>
										<input class="form-control" id="inputPassword" type="password" name="password" required>
									</div>
									<div class="col-lg-6">
										<label class="form-label" for="inputPasswordConfirm">{{ 'Password confirmation'|trans }}</label>
										<input class="form-control" id="inputPasswordConfirm" type="password" name="password_confirm" required>
									</div>
								</div>
								<input type="hidden" name="id" value="{{ staff.id }}">
							{% endblock %}

							{% block form_actions %}
								<button class="btn btn-primary" type="submit">{{ 'Submit'|trans }}</button>
							{% endblock %}
						{% endembed %}
					</form>
				</div>
			</div>
		{% endblock %}
	{% endembed %}
{% endblock %}
