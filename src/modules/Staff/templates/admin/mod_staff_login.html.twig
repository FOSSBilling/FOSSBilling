{% extends 'layout_login.html.twig' %}

{% block meta_title %}{{ 'Login'|trans }}{% endblock %}

{% set company = guest.system_company %}

{% block content %}

<div class="page page-center">
    <div class="container-tight py-4">
        <div class="text-center mb-4">
            <a href="{{ '/'|url(area: 'client') }}">
                <img class="hide-theme-light" src="{{ company.logo_url_dark }}" style="height: 60px; width: auto;" alt="{{ company.name }}">
                <img class="hide-theme-dark" src="{{ company.logo_url }}" style="height: 60px; width: auto;" alt="{{ company.name }}">
            </a>
        </div>
        <div class="card card-md">
            <div class="card-body">
                {% set params = guest.extension_settings({ 'ext': 'mod_staff' }) %}
                <h2 class="h2 text-center mb-4">{{ 'Log Into Your Account' | trans }}</h2>
                <form method="post" action="{{ 'staff/login'|api_url(role: 'guest') }}" {{ fb_api_form({redirect: redirect_uri|default('/')|url}) }}>
                    <div class="mb-3">
                        <label class="form-label" for="inputEmail">{{ 'Email'|trans }}</label>
                        <input class="form-control"
                            id="inputEmail"
                            type="email"
                            name="email"
                            value="{{ request.email }}"
                            placeholder="{{ 'Enter your email address'|trans }}"
                            required
                            autofocus>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="inputPassword">
                            {{ 'Password'|trans }}
                            {% if params.reset_pw == 1 %}
                            <span class="form-label-description">
                                <a href="{{ 'staff/passwordreset'|url }}">{{ 'Forgot your password?'|trans }}</a>
                            </span>
                            {% endif %}
                        </label>
                        <input class="form-control"
                            id="inputPassword"
                            type="password"
                            name="password"
                            value="{{ request.password }}"
                            placeholder="{{ 'Enter your password'|trans }}"
                            required>
                    </div>
                    <div class="form-footer">
                        <button class="btn btn-primary w-100" type="submit">{{ 'Login'|trans }}</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}
