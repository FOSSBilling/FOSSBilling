{% extends 'layout_login.html.twig' %}

{% block meta_title %}{{ 'Reset your password'|trans }}{% endblock %}

{% set company = guest.system_company %}

{% block content %}

<div class="page page-center">
    <div class="container-tight py-4">
        <div class="text-center mb-4">
            <a href="{{ '/'|url(area: 'client') }}">
                <img class="hide-theme-light" src="{{ company.logo_url_dark }}" style="height: 60px; width: auto;" alt="{{ company.name }}">
                <img class="hide-theme-dark" src="{{ company.logo_url }}" style="height: 60px; width: auto;" alt="{{ company.name }}">
            </a>
        </div>
        <div class="card card-md">
            <div class="card-body">
                <h2 class="h2 text-center mb-4">{{ 'Reset Your Password' | trans }}</h2>
                <p class="text-muted mb-4">{{ 'Update Your Password' | trans }}</p>
                <form method="post" action="{{ 'staff/update_password'|api_url(role: 'guest') }}" {{ fb_api_form({ redirect: 'index'|url }) }}>
                    <div class="mb-3">
                        <label class="form-label" for="inputEmail">{{ 'Email address'|trans }}</label>
                        <input class="form-control"
                               id="inputEmail"
                               type="email"
                               name="email"
                               value="{{ data.email }}"
                               aria-readonly="true"
                               readonly>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="inputCode">{{ 'Code'|trans }}</label>
                        <input class="form-control"
                               id="inputCode"
                               type="text"
                               name="code"
                               value="{{ data.hash }}"
                               placeholder="{{ 'Enter your secret code'|trans }}"
                               required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="inputPassword">{{ 'Password'|trans }}</label>
                        <input class="form-control"
                               id="inputPassword"
                               type="password"
                               name="password"
                               placeholder="{{ 'Enter your password'|trans }}"
                               required
                               autofocus>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" for="inputPassword2">{{ 'Repeat Password'|trans }}</label>
                        <input class="form-control"
                               id="inputPassword2"
                               type="password"
                               name="password_confirm"
                               placeholder="{{ 'Enter your password'|trans }}"
                               required>
                    </div>
                    <div class="form-footer">
                        <button class="btn btn-primary w-100" type="submit">
                            <svg class="icon">
                                <use xlink:href="#mail" />
                            </svg>
                            {{ 'Update password'|trans }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <div class="text-center text-muted mt-3">
            <a href="{{ 'staff/login'|url }}">{{ 'Take me back to the login screen.'|trans }}</a>
        </div>
    </div>
</div>
{% endblock %}
