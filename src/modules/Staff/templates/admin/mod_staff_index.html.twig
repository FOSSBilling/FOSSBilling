{% extends 'layout_default.html.twig' %}

{% import 'macro_functions.html.twig' as mf %}

{% block meta_title %}{{ 'Staff'|trans }}{% endblock %}

{% set active_menu = 'system' %}
{% set has_filter_panel = true %}
{% set filter_panel_id = 'page-search-filters' %}
{% set filter_panel_open = request_has_filters %}

{% block content %}
<div class="card">
    <ul class="tabs">
        <li>
            <a href="#tab-staff">{{ 'Staff Members'|trans }}</a>
        </li>
        <li>
            <a href="#tab-new">{{ 'New Staff Member'|trans }}</a>
        </li>
        <li>
            <a href="#tab-groups">{{ 'Manage Groups'|trans }}</a>
        </li>
        <li>
            <a href="#tab-new-group">{{ 'New Group'|trans }}</a>
        </li>
    </ul>

    <div class="tab-content">
        <div class="tab_content nopadding" id="tab-staff">
            {{ include('partial_search.html.twig', {
                search_body_class: filter_panel_open ? 'pb-2 border-bottom-0' : ''
            }) }}
            <section id="{{ filter_panel_id }}" class="card-body pt-0 px-3 pb-3 border-bottom collapse{% if filter_panel_open %} show{% endif %}">
                <form method="get" class="border border-top-0 rounded-top-0 rounded-bottom-3 bg-body-tertiary p-3">
                    {% if request.search %}
                        <input type="hidden" name="search" value="{{ request.search }}">
                    {% endif %}
                    <div class="row g-3">
                        <div class="col-md-6 col-xl-3">
                            <div>
                                <label class="form-label text-muted small mb-1" for="staff-id">{{ 'Staff ID'|trans }}</label>
                                <input class="form-control" type="text" id="staff-id" name="id" value="{{ request.id }}" placeholder="{{ 'Staff ID'|trans }}">
                            </div>
                        </div>
                        <div class="col-md-6 col-xl-3">
                            <div>
                                <label class="form-label text-muted small mb-1" for="staff-group">{{ 'Group'|trans }}</label>
                                {{ mf.selectbox('admin_group_id', admin.staff_group_get_pairs, request.admin_group_id, 0, 'All Groups'|trans) }}
                            </div>
                        </div>
                        <div class="col-md-6 col-xl-3">
                            <div>
                                <label class="form-label text-muted small mb-1" for="staff-status">{{ 'Status'|trans }}</label>
                                <select class="form-select" id="staff-status" name="status">
                                    <option value="">{{ 'All Statuses'|trans }}</option>
                                    <option value="active"{% if request.status == 'active' %} selected{% endif %}>{{ 'Active'|trans }}</option>
                                    <option value="inactive"{% if request.status == 'inactive' %} selected{% endif %}>{{ 'Inactive'|trans }}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6 col-xl-3">
                            <div class="h-100 d-flex align-items-end">
                                <label class="form-check form-switch m-0">
                                    <input class="form-check-input" type="checkbox" name="no_cron" value="1"{% if request.no_cron %} checked{% endif %}>
                                    <span class="form-check-label">{{ 'Exclude Cron User'|trans }}</span>
                                </label>
                            </div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <a class="btn btn-outline-secondary" href="{{ request_path|url }}">{{ 'Reset'|trans }}</a>
                        <button class="btn btn-primary" type="submit">
                            <svg class="icon">
                                <use xlink:href="#filter" />
                            </svg>
                            {{ 'Apply Filters'|trans }}
                        </button>
                    </div>
                </form>
            </section>
            <table class="tableStatic wide">
                <thead>
                    <tr>
                        <th colspan="2">{{ 'Name'|trans }}</th>
                        <th>{{ 'Email'|trans }}</th>
                        <th>{{ 'Group'|trans }}</th>
                        <th>{{ 'Status'|trans }}</th>
                        <th class="w-1"></th>
                    </tr>
                </thead>

                <tbody>
                {% set members = admin.staff_get_list({ 'per_page': 100, 'page': request.page }|merge(request)) %}
                {% for i, member in members.list %}
                <tr>
                    <td>
                        <a href='{{ "staff/manage/#{member.id}"|url }}'>
                            {{ mf.avatar(member.email, 25, 'db-avatar') }}
                        </a>
                    </td>
                    <td>{{ member.name }}</td>
                    <td>{{ member.email }}</td>
                    <td>
                        <a href='{{ "staff/group/#{member.group.id}"|url }}'>{{ member.group.name }}</a>
                    </td>
                    <td>{{ mf.status_badge(member.status, 'generic') }}</td>
                    <td style="width: 13%" class="actions">
                        <a class="btn btn14" href='{{ "staff/manage/#{member.id}"|url }}'>
                            <img src="assets/icons/edit.svg" alt="">
                        </a>
                        <a class="btn btn14" href="{{ 'staff/delete'|api_url(query: { 'id': member.id }) }}"
                            {{ fb_api_link({modal: {type: 'confirm', title: 'Are you sure?'|trans}, redirect: 'staff'|url}) }}>
                            <img src="assets/icons/delete.svg" alt="">
                        </a>
                    </td>
                </tr>
                </tbody>

                {% else %}
                <tbody>
                    <tr>
                        <td colspan="5">{{ 'The list is empty'|trans }}</td>
                    </tr>
                </tbody>
                {% endfor %}
            </table>
        </div>

        <div class="fix"></div>
        <div class="tab_content nopadding" id="tab-new">
            <form method="post" action="{{ 'staff/create'|api_url }}" {{ fb_api_form({callback: 'onAfterStaffCreate'}) }}>
                <fieldset>
                    <div class="rowElem noborder">
                        <label>{{ 'Group'|trans }}</label>
                        <div class="formRight">
                            {{ mf.selectbox('admin_group_id', admin.staff_group_get_pairs, '', 1) }}
                        </div>
                        <div class="fix"></div>
                    </div>

                    <div class="rowElem">
                        <label>{{ 'Name'|trans }}</label>
                        <div class="formRight">
                            <input type="text" name="name" value="" required>
                        </div>
                        <div class="fix"></div>
                    </div>

                    <div class="rowElem">
                        <label>{{ 'Email'|trans }}</label>
                        <div class="formRight">
                            <input type="email" name="email" value="{{ request.email }}" required>
                        </div>
                        <div class="fix"></div>
                    </div>
                    <div class="rowElem">
                        <label>{{ 'Password'|trans }}</label>
                        <div class="formRight">
                            <input type="password" name="password" required>
                        </div>
                        <div class="fix"></div>
                    </div>
                    <div class="rowElem">
                        <label>{{ 'Signature'|trans }}</label>
                        <div class="formRight">
                            <textarea name="signature" rows="2"></textarea>
                        </div>
                        <div class="fix"></div>
                    </div>
                    <div class="rowElem">
                        <label>{{ 'Status'|trans }}:</label>
                        <div class="formRight">
                            <input type="radio" name="status" value="inactive" checked>
                            <label>{{ 'Inactive'|trans }}</label>
                            <input type="radio" name="status" value="active">
                            <label>{{ 'Active'|trans }}</label>
                        </div>
                        <div class="fix"></div>
                    </div>

                    <input type="submit" value="{{ 'Create'|trans }}" class="btn btn-primary submitForm">
                </fieldset>
            </form>
        </div>

        <div class="fix"></div>
        <div class="tab_content nopadding" id="tab-groups">
            <table class="tableStatic wide">
                <thead>
                    <tr>
                        <td>{{ 'Name'|trans }}</td>
                        <td style="width: 13%">&nbsp;</td>
                    </tr>
                </thead>
                <tbody>
                {% set groups = admin.staff_group_get_list({ 'per_page': 100, 'page': request.page }) %}
                {% for i, group in groups.list %}
                <tr>
                    <td>{{ group.name }}</td>
                    <td class="actions">
                        <a class="btn btn14" href='{{ "staff/group/#{group.id}"|url }}'>
                            <img src="assets/icons/edit.svg" alt="">
                        </a>
                        <a class="btn btn14" href="{{ 'staff/group_delete'|api_url(query: {'id' : group.id }) }}"
                            {{ fb_api_link({modal: {type: 'confirm', title: 'Are you sure?'|trans}, redirect: 'staff'|url}) }}>
                            <img src="assets/icons/delete.svg" alt="">
                        </a>
                    </td>
                </tr>
                </tbody>
                {% else %}
                <tbody>
                    <tr>
                        <td colspan="5">{{ 'The list is empty'|trans }}</td>
                    </tr>
                </tbody>
                {% endfor %}
            </table>
        </div>

        <div class="fix"></div>
        <div class="tab_content nopadding" id="tab-new-group">
=
            <form method="post" action="{{ 'staff/group_create'|api_url }}" {{ fb_api_form({redirect: 'staff'|url}) }}>
                <div class="rowElem noborder">
                    <label>{{ 'Name'|trans }}</label>
                    <div class="formRight">
                        <input type="text" name="name" value="" required>
                    </div>
                    <div class="fix"></div>
                </div>
                <input type="submit" value="{{ 'Create group'|trans }}" class="btn btn-primary submitForm">
            </form>
        </div>
    </div>
</div>
{% endblock %}

{% block js %}
<script>
    function onAfterStaffCreate(id) {
        window.location = "{{ 'staff/manage/'|url }}/" + id + '#tab-permissions';
    }
</script>
{% endblock %}
