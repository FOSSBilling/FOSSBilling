{% extends 'layout_login.html.twig' %}

{% import 'macro_functions.html.twig' as mf %}

{% block meta_title %}{{ 'Reset your password'|trans }}{% endblock %}

{% set company = guest.system_company %}

{% block content %}

<div class="page page-center">
    <div class="container-tight py-4">
        <div class="text-center mb-4">
            <a href="{{ '/'|url(area: 'client') }}">
                <img class="hide-theme-light" src="{{ company.logo_url_dark }}" style="height: 60px; width: auto;" alt="{{ company.name }}">
                <img class="hide-theme-dark" src="{{ company.logo_url }}" style="height: 60px; width: auto;" alt="{{ company.name }}">
            </a>
        </div>
        <div class="card card-md">
            <div class="card-body">
                <h2 class="h2 text-center mb-4">{{ 'Reset Your Password' | trans }}</h2>
                <p class="text-muted mb-4">{{ 'Enter your email address. You will receive a confirmation link if your account exists.' | trans }}</p>
                <form method="post" action="{{ 'staff/passwordreset'|api_url(role: 'guest') }}"
                    {{ fb_api_form({message: 'A password reset confirmation email will be sent to you if we found an account with that email address.'|trans, redirect: 'index'|url}) }}>
                    <div class="mb-3">
                        <label class="form-label" for="inputEmail">{{ 'Email address'|trans }}</label>
                        <input class="form-control"
                               id="inputEmail"
                               type="email"
                               name="email"
                               value="{{ request.email }}"
                               placeholder="{{ 'Enter your email address'|trans }}"
                               required
                               autofocus>
                    </div>
                    {{ mf.recaptcha }}
                    <div class="form-footer">
                        <button class="btn btn-primary w-100" type="submit">
                            <svg class="icon">
                                <use xlink:href="#mail" />
                            </svg>
                            {{ 'Send me the link'|trans }}
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <div class="text-center text-muted mt-3">
            <a href="{{ 'staff/login'|url }}">{{ 'Take me back to the login screen.'|trans }}</a>
        </div>
    </div>
</div>
{% endblock %}
