{% extends 'layout_default.html.twig' %}

{% block meta_title %}{{ 'Staff Group Management'|trans }}{% endblock %}

{% set active_menu = 'system' %}

{% block breadcrumbs %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="{{ '/'|url }}">
                <svg class="icon">
                    <use href="#home" />
                </svg>
            </a>
        </li>
        <li class="breadcrumb-item">
            <a href="{{ 'system'|url }}">{{ 'Settings'|trans }}</a>
        </li>
        <li class="breadcrumb-item">
            <a href="{{ 'extension/settings/staff'|url }}">{{ 'Staff'|trans }}</a>
        </li>
        <li class="breadcrumb-item">
            <a href="{{ 'extension/settings/staff'|url }}#tab-groups">{{ 'Groups'|trans }}</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">{{ group.name }}</li>
    </ol>
{% endblock %}

{% block content %}
    {% embed 'partial_admin_detail_tabs.html.twig' with {
        title: group.name,
        subtitle: 'Manage this staff group details, permissions, and members.'|trans
    } %}
        {% block detail_tabs %}
            <li class="nav-item" role="presentation">
                <a class="nav-link active" href="#tab-details" data-bs-toggle="tab" role="tab">{{ 'Details'|trans }}</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" href="#tab-permissions" data-bs-toggle="tab" role="tab">{{ 'Permissions'|trans }}</a>
            </li>
            <li class="nav-item" role="presentation">
                <a class="nav-link" href="#tab-members" data-bs-toggle="tab" role="tab">{{ 'Members'|trans }}</a>
            </li>
        {% endblock %}

        {% block detail_tab_content %}
            <div class="tab-pane fade show active" id="tab-details" role="tabpanel">
                <div class="p-3">
                    {% if group.protected or not is_super_admin|default(false) %}
                        {% embed 'partial_admin_form_card.html.twig' with {
                            title: 'Group details'|trans,
                            subtitle: group.protected ? ('This protected system group cannot be modified.'|trans) : ('Only Super Administrators can change staff group details.'|trans)
                        } %}
                            {% block form_content %}
                                <div class="row g-3">
                                    {% if group.system_name %}
                                        <div class="col-lg-4">
                                            <label class="form-label" for="inputSystemName">{{ 'System name'|trans }}</label>
                                            <input class="form-control" id="inputSystemName" type="text" value="{{ group.system_name }}" readonly>
                                        </div>
                                    {% endif %}
                                    <div class="col-lg-4">
                                        <label class="form-label" for="inputName">{{ 'Name'|trans }}</label>
                                        <input class="form-control" id="inputName" type="text" value="{{ group.name }}" readonly>
                                    </div>
                                    <div class="col-lg-4">
                                        <label class="form-label" for="inputParent">{{ 'Parent group'|trans }}</label>
                                        <input class="form-control" id="inputParent" type="text" value="{{ group.parent_name|default('(This is a root group)'|trans) }}" readonly>
                                    </div>
                                </div>
                            {% endblock %}
                        {% endembed %}
                    {% else %}
                        <form method="post" action="{{ 'staff/group_update'|api_url }}" {{ fb_api_form({message: 'Staff Group Updated'|trans}) }}>
                            {% embed 'partial_admin_form_card.html.twig' with {
                                title: 'Group details'|trans,
                                subtitle: 'Rename the group and change its parent group.'|trans
                            } %}
                                {% block form_content %}
                                    <div class="row g-3">
                                        {% if group.system_name %}
                                            <div class="col-lg-4">
                                                <label class="form-label" for="inputSystemName">{{ 'System name'|trans }}</label>
                                                <input class="form-control" id="inputSystemName" type="text" value="{{ group.system_name }}" readonly>
                                            </div>
                                        {% endif %}
                                        <div class="col-lg-4">
                                            <label class="form-label" for="inputName">{{ 'Name'|trans }}</label>
                                            <input class="form-control" id="inputName" type="text" name="name" value="{{ group.name }}" required>
                                        </div>
                                        <div class="col-lg-4">
                                            <label class="form-label" for="inputParent">{{ 'Parent group'|trans }}</label>
                                            <select class="form-select" id="inputParent" name="parent_id" required>
                                                {% for parentId, parentName in parent_pairs %}
                                                    <option value="{{ parentId }}"{% if group.parent_id|default(null) == parentId %} selected{% endif %}>{{ parentName }}</option>
                                                {% endfor %}
                                            </select>
                                            <div class="form-text">{{ 'Members of a higher group can manage staff members below their assigned groups.'|trans }}</div>
                                        </div>
                                    </div>
                                    <input type="hidden" name="id" value="{{ group.id }}">
                                {% endblock %}

                                {% block form_actions %}
                                    <button class="btn btn-primary" type="submit">{{ 'Save details'|trans }}</button>
                                {% endblock %}
                            {% endembed %}
                        </form>
                    {% endif %}
                </div>
            </div>

            <div class="tab-pane fade" id="tab-permissions" role="tabpanel">
                <div class="p-3">
                    {% if group.protected %}
                        {% if group.system_name == 'super_admin' %}
                            {% embed 'partial_admin_form_card.html.twig' with {
                                title: group.name,
                                subtitle: 'Members of this protected system group bypass permission checks.'|trans
                            } %}
                                {% block form_content %}
                                    <div class="alert alert-success d-flex align-items-center" role="alert">
                                        <svg class="icon" style="width:24px;height:24px;"><use href="#check"/></svg>
                                        <div>
                                            <strong>{{ 'Super Administrator Access'|trans }}</strong><br>
                                            {{ 'Members of this group have unrestricted access to all system modules and actions.'|trans }}
                                        </div>
                                    </div>

                                    <ul class="list-group mt-3">
                                        <li class="list-group-item d-flex align-items-center">
                                            <svg class="icon text-success me-2" style="width:20px;height:20px;"><use href="#check"/></svg>
                                            {{ 'Can manage staff groups and memberships'|trans }}
                                        </li>
                                        <li class="list-group-item d-flex align-items-center">
                                            <svg class="icon text-success me-2" style="width:20px;height:20px;"><use href="#check"/></svg>
                                            {{ 'Can access all client and billing records'|trans }}
                                        </li>
                                        <li class="list-group-item d-flex align-items-center">
                                            <svg class="icon text-success me-2" style="width:20px;height:20px;"><use href="#check"/></svg>
                                            {{ 'Can configure system settings and modules'|trans }}
                                        </li>
                                    </ul>

                                    <div class="mt-3 text-muted">
                                        <small>{{ 'This protected group cannot be edited or deleted.'|trans }}</small>
                                    </div>
                                {% endblock %}
                            {% endembed %}
                        {% else %}
                            {% embed 'partial_admin_form_card.html.twig' with {
                                title: group.name,
                                subtitle: 'This is a protected system group. Its permissions are controlled by FOSSBilling and cannot be edited.'|trans
                            } %}
                                {% block form_content %}
                                    <div class="alert alert-info mb-0" role="alert">
                                        {{ 'The permission matrix is not available for protected system groups.'|trans }}
                                    </div>
                                {% endblock %}
                            {% endembed %}
                        {% endif %}
                    {% elseif not is_super_admin|default(false) %}
                        {% embed 'partial_admin_form_card.html.twig' with {
                            title: 'Permissions'|trans,
                            subtitle: 'Only Super Administrators can change staff group permissions.'|trans
                        } %}
                            {% block form_content %}
                                <div class="alert alert-info mb-0" role="alert">
                                    {{ 'You can still manage group memberships within your hierarchy, but permission changes are restricted to Super Administrators.'|trans }}
                                </div>
                            {% endblock %}
                        {% endembed %}
                    {% else %}
                        <form method="post" action="{{ 'staff/group_update'|api_url }}" {{ fb_api_form({message: 'Staff Group Updated'|trans}) }}>
                            {% embed 'partial_admin_form_card.html.twig' with {
                                title: 'Permissions'|trans,
                                subtitle: 'Update the permissions assigned to members of this group.'|trans,
                                body_class: 'pt-4'
                            } %}
                                {% block form_header_actions %}
                                    <button class="btn btn-secondary" type="button" onclick="toggleAll(true);">{{ 'Grant All Permissions'|trans }}</button>
                                    <button class="btn btn-danger" type="button" onclick="toggleAll(false);">{{ 'Revoke All Permissions'|trans }}</button>
                                {% endblock %}

                                {% block form_content %}
                                    <input type="hidden" name="id" value="{{ group.id }}">
                                    <input type="hidden" name="permissions[_submitted]" value="1">

                                    {% for modName, mod in mods|filter(mod => mod.permissions.hide_permissions|default(false) is not true) %}
                                        <section class="mb-4 pb-4 border-bottom">
                                            <div class="row g-3">
                                                <div class="col-lg-3">
                                                    <h6 class="card-title mb-0">{{ modName|replace({'_': ' '})|title|trim }}</h6>
                                                </div>
                                                <div class="col-lg-9">
                                                    {% if not mod.permissions.can_always_access|default(false) %}
                                                        <div class="form-check mb-3">
                                                            <input class="form-check-input permission-box" id="input-{{ modName }}" type="checkbox" name="permissions[{{ modName }}][access]" value="1" {% if group.permissions[modName].access|default(false) %} checked {% endif %}>
                                                            <label class="form-check-label" for="input-{{ modName }}">{{ 'Module access'|trans }}
                                                                <svg class="icon" data-bs-toggle="tooltip" data-bs-title="{{ 'Can be disabled to prevent group members from using any part of this module.'|trans }}" data-bs-placement="right"><use href="#info-circle"/></svg>
                                                            </label>
                                                        </div>
                                                    {% endif %}

                                                    <div class="row g-3">
                                                        {% for permissionName, permission in mod.permissions %}
                                                            {% if permission.type == 'bool' %}
                                                                <div class="col-lg-6">
                                                                    <div class="form-check mt-1">
                                                                        <input class="form-check-input permission-box" id="input-{{ modName }}-{{ permissionName }}" type="checkbox" name="permissions[{{ modName }}][{{ permissionName }}]" value="1"{% if group.permissions[modName][permissionName]|default(false) %} checked {% endif %}>
                                                                        <label class="form-check-label" for="input-{{ modName }}-{{ permissionName }}">{{ permission.display_name }}
                                                                            <svg class="icon" data-bs-toggle="tooltip" data-bs-title="{{ permission.description }}" data-bs-placement="right"><use href="#info-circle"/></svg>
                                                                        </label>
                                                                    </div>
                                                                </div>
                                                            {% endif %}

                                                            {% if permission.type == 'select' %}
                                                                <div class="col-lg-6">
                                                                    <label for="input-{{ modName }}-{{ permissionName }}" class="form-label">{{ permission.display_name }}
                                                                        <svg class="icon" data-bs-toggle="tooltip" data-bs-title="{{ permission.description }}" data-bs-placement="right"><use href="#info-circle"/></svg>
                                                                    </label>
                                                                    <select class="form-select permission-select" id="input-{{ modName }}-{{ permissionName }}" name="permissions[{{ modName }}][{{ permissionName }}]">
                                                                        <option value="">{{ 'None'|trans }}</option>
                                                                        {% for optionName, option in permission.options %}
                                                                            <option value="{{ optionName }}" {% if group.permissions[modName][permissionName]|default(false) == optionName %} selected {% endif %}>{{ option }}</option>
                                                                        {% endfor %}
                                                                    </select>
                                                                </div>
                                                            {% endif %}
                                                        {% endfor %}
                                                    </div>
                                                </div>
                                            </div>
                                        </section>
                                    {% endfor %}
                                {% endblock %}

                                {% block form_actions %}
                                    <button class="btn btn-primary" type="submit">{{ 'Save permissions'|trans }}</button>
                                {% endblock %}
                            {% endembed %}
                        </form>
                    {% endif %}
                </div>
            </div>

            <div class="tab-pane fade" id="tab-members" role="tabpanel">
                <div class="p-3">
                    {% embed 'partial_admin_form_card.html.twig' with {
                        title: 'Members'|trans,
                        subtitle: 'Staff members assigned to this group.'|trans
                    } %}
                        {% block form_content %}
                            {% if members|length > 0 %}
                                <div class="list-group">
                                    {% for member in members %}
                                        <a class="list-group-item list-group-item-action d-flex align-items-center justify-content-between gap-3" href='{{ "staff/manage/#{member.id}"|url }}'>
                                            <span>
                                                <strong>{{ member.name }}</strong>
                                                <span class="text-secondary ms-2">{{ member.email }}</span>
                                            </span>
                                            <span class="badge {% if member.status == 'active' %}bg-green-lt{% else %}bg-secondary-lt{% endif %}">{{ member.status|title }}</span>
                                        </a>
                                    {% endfor %}
                                </div>
                            {% else %}
                                <div class="alert alert-warning mb-0" role="alert">{{ 'This group has no staff members.'|trans }}</div>
                            {% endif %}
                        {% endblock %}
                    {% endembed %}
                </div>
            </div>
        {% endblock %}
    {% endembed %}
{% endblock %}

{% block js %}
<script>
    function toggleAll(check) {
        document.querySelectorAll('.permission-box').forEach((element) => {
            element.checked = check;
        });
    }
</script>
{% endblock %}
