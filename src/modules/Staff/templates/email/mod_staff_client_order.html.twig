{% block subject %}[{{ guest.system_company.name }}] New Order Placed{% endblock %}
{% block content %}
{% set order = order|default({}) %}
<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<style type="text/css">
		body {
			font-family: Arial, sans-serif;
			font-size: 14px;
			color: #333333;
		}

		h1 {
			font-size: 24px;
			font-weight: bold;
			margin: 0 0 20px;
		}

		p {
			margin: 0 0 10px;
		}

		strong {
			font-weight: bold;
		}

		.signature {
			font-style: italic;
			color: #999999;
			margin-top: 20px;
			border-top: 1px solid #cccccc;
			padding-top: 10px;
		}
	</style>
</head>
<body>
	<h1>New Order Placed</h1>
	<p>Hello {{ staff.name|default('') }},</p>
	<p>Client <strong>{{ order.client.first_name|default('') }} {{ order.client.last_name|default('') }}</strong> placed a new order for <strong>{{ order.title|default('') }}</strong> on {{ order.created_at|default('')|format_date }}</p>

    <p><a href='{{ "order/manage/#{order.id|default('')}"|url(area: 'admin') }}' target="_blank">Manage order.</a>

	<div class="signature">{{ guest.system_email.signature }}</div>
</body>
</html>
{% endblock %}
