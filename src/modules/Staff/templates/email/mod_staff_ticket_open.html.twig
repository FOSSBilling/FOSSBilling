{% block subject %}[{{ guest.system_company.name }}] {{ ticket.subject|default('') }}{% endblock %}
{% block content %}
<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<style type="text/css">
		body {
			font-family: Arial, sans-serif;
			font-size: 14px;
			color: #333333;
		}

		h1 {
			font-size: 24px;
			font-weight: bold;
			margin: 0 0 20px;
		}

		p {
			margin: 0 0 10px;
		}

		strong {
			font-weight: bold;
		}

		.signature {
			font-style: italic;
			color: #999999;
			margin-top: 20px;
			border-top: 1px solid #cccccc;
			padding-top: 10px;
		}
	</style>
</head>
<body>
	<h1>Ticket Opened</h1>
	<p>Hello {{ staff.name|default('') }},</p>

    <p><strong>{{ ticket.author.name|default('') }}</strong> opened a new support ticket #{{ ticket.id|default('') }}</p>
	<a href='{{ "support/ticket/#{ticket.id|default('')}"|url(area: 'admin') }}' target="_blank">Review the ticket</a>

    <h2>Ticket contents</h2>
    <p>{{ ticket.messages|default([])[0].content|default('') }}</p>

    <p>Ticket info</p>
    <ul>
        <li><strong>Ticket ID:</strong> #{{ticket.id|default('')}}</li>
        <li><strong>Department:</strong> {{ticket.helpdesk|default({}).name|default('')}}</li>
        <li><strong>Status:</strong> {{ticket.status|default('')|title}}</li>
    </ul>

    <a href='{{ "support/ticket/#{ticket.id|default('')}"|url(area: 'admin') }}' target="_blank">Reply</a>

    <p>You may <a href="{{ 'staff/login'|url(query: { 'email': staff.email|default('') }, area: 'admin') }}" target="_blank">login</a> or <a href="{{ 'staff/profile'|url(area: 'admin') }}" target="_blank">edit your profile.</a>

	<div class="signature">{{ guest.system_email.signature }}</div>
</body>
</html>
{% endblock %}
