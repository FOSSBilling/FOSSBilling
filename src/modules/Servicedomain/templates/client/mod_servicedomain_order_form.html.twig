{% set periods = guest.system_periods %}
{% set pricing = product.pricing %}
{% set transfer_tlds = guest.serviceDomain_tlds({ "allow_transfer": 1 }) %}
{% set tlds = guest.serviceDomain_tlds({"allow_register":1}) %}

<div class="tn-tabchip-row mb-3" role="tablist">
    {% if tlds is not empty %}
        <button type="button" class="tn-tabchip" data-tn-domain-tab="register" data-active="true">{{ 'Register'|trans }}</button>
    {% endif %}
    {% if transfer_tlds is not empty %}
        <button type="button" class="tn-tabchip" data-tn-domain-tab="transfer" {% if tlds is empty %}data-active="true"{% endif %}>{{ 'Transfer'|trans }}</button>
    {% endif %}
</div>

{% if tlds is not empty %}
    <div class="tn-domain-tabpanel" data-tn-domain-panel="register" {% if tlds is empty %}hidden{% endif %}>
        <label class="form-label mb-2">{{ 'Register a new domain'|trans }}</label>
        <div class="d-flex gap-2">
            <div class="tn-input-wrap flex-grow-1">
                <input class="tn-input" type="text" name="register_sld"
                    value="{{ request.register_sld }}"
                    placeholder="{{ 'Enter domain name'|trans }}">
            </div>
            <select class="tn-input domain-tld-select" name="register_tld" style="max-width:120px;">
                {% for tld in tlds %}
                    <option value="{{ tld.tld }}" label="{{ tld.tld }}">{{ tld.tld }}</option>
                {% endfor %}
            </select>
            <button class="tn-btn tn-btn--primary tn-btn--md" type="button" id="domain-check">{{ 'Check'|trans }}</button>
        </div>

        <div class="onAfterDomainCheck" style="display:none;">
            <label class="form-label mt-3 mb-1">{{ 'Registration length'|trans }}</label>
            <select class="tn-input" name="register_years" id="registration-years" style="max-width:260px;"></select>

            <label class="tn-switch-wrap d-flex justify-content-between align-items-center py-2 mt-3" style="width:100%; max-width:420px;">
                <span>{{ 'I want to use my nameservers'|trans }}</span>
                <span class="tn-switch-track" id="nameservers-switch">
                    <input class="tn-switch-input" type="checkbox" id="nameserversCb">
                    <span class="tn-switch-thumb"></span>
                </span>
            </label>
            <div id="nameservers" class="row" style="display:none;">
                <div class="mb-2 col-md-6">
                    <input class="tn-input" type="text" name="ns1" value="" placeholder="{{ 'Nameserver 1'|trans }}"/>
                </div>
                <div class="mb-2 col-md-6">
                    <input class="tn-input" type="text" name="ns2" value="" placeholder="{{ 'Nameserver 2'|trans }}"/>
                </div>
                <div class="mb-2 col-md-6">
                    <input class="tn-input" type="text" name="ns3" value="" placeholder="{{ 'Nameserver 3'|trans }}"/>
                </div>
                <div class="mb-2 col-md-6">
                    <input class="tn-input" type="text" name="ns4" value="" placeholder="{{ 'Nameserver 4'|trans }}"/>
                </div>
            </div>
        </div>
    </div>
{% endif %}

{% if transfer_tlds is not empty %}
    <div class="tn-domain-tabpanel" data-tn-domain-panel="transfer" {% if tlds is not empty %}hidden{% endif %}>
        <label class="form-label mb-2">{{ 'Transfer a domain'|trans }}</label>
        <div class="d-flex gap-2">
            <div class="tn-input-wrap flex-grow-1">
                <input class="tn-input" type="text" name="transfer_sld"
                       value="{{ request.transfer_sld }}"
                       placeholder="{{ 'Enter domain name'|trans }}">
            </div>
            <select class="tn-input domain-tld-select" name="transfer_tld" id="transfer-tld-select" style="max-width:120px;">
                {% for tld in transfer_tlds %}
                    <option value="{{ tld.tld }}" label="{{ tld.tld }}" data-requires-code="{{ tld.requires_transfer_code ? '1' : '0' }}">{{ tld.tld }}</option>
                {% endfor %}
            </select>
            <button class="tn-btn tn-btn--primary tn-btn--md" type="button" id="transfer-check">{{ 'Check'|trans }}</button>
        </div>

        <div id="domain-transfer-config" style="display:none;">
            <p class="small mt-3">{{ 'Transfer price is'|trans }}&nbsp;<span class="fw-bold" id="transfer-price"></span></p>
            <div class="tn-input-wrap" style="max-width:420px;">
                <input class="tn-input" type="text" name="transfer_code" id="transfer-code-input" value="{{ request.transfer_code }}"
                       placeholder="{{ 'Enter domain transfer code'|trans }}">
            </div>
            <p class="small text-muted mt-2" id="transfer-code-hint"></p>
            <p class="small text-muted mt-2" id="transfer-ns-scan-status"></p>

            <label class="tn-switch-wrap d-flex justify-content-between align-items-center py-2 mt-2" style="width:100%; max-width:420px;">
                <span>{{ 'I want to use my nameservers'|trans }}</span>
                <span class="tn-switch-track" id="transfer-nameservers-switch">
                    <input class="tn-switch-input" type="checkbox" id="transferNameserversCb">
                    <span class="tn-switch-thumb"></span>
                </span>
            </label>
            <div id="transferNameservers" class="row" style="display:none;">
                <div class="mb-2 col-md-6">
                    <input class="tn-input" type="text" name="ns1" value="" placeholder="{{ 'Nameserver 1'|trans }}"/>
                </div>
                <div class="mb-2 col-md-6">
                    <input class="tn-input" type="text" name="ns2" value="" placeholder="{{ 'Nameserver 2'|trans }}"/>
                </div>
                <div class="mb-2 col-md-6">
                    <input class="tn-input" type="text" name="ns3" value="" placeholder="{{ 'Nameserver 3'|trans }}"/>
                </div>
                <div class="mb-2 col-md-6">
                    <input class="tn-input" type="text" name="ns4" value="" placeholder="{{ 'Nameserver 4'|trans }}"/>
                </div>
            </div>
        </div>
    </div>
{% endif %}

<input type="hidden" name="id" value="{{ product.id }}"/>
<input type="hidden" name="action" value="register" id="domain-action"/>

{% set currency = guest.cart_get_currency %}
<script type="text/javascript">
    function fadeIn(el) {
        el.style.removeProperty('display');
        el.style.opacity = '0';
        el.style.transition = 'opacity 0.15s ease-in';
        requestAnimationFrame(() => el.style.opacity = '1');
    }

    function slideDown(el) {
        el.style.removeProperty('display');
        el.style.overflow = 'hidden';
        el.style.height = '0';
        el.style.transition = 'height 0.2s ease-out';
        requestAnimationFrame(() => el.style.height = el.scrollHeight + 'px');
    }

    document.addEventListener('DOMContentLoaded', function () {
        document.querySelectorAll('[data-tn-domain-tab]').forEach(function (chip) {
            chip.addEventListener('click', function () {
                const target = chip.getAttribute('data-tn-domain-tab');
                document.querySelectorAll('[data-tn-domain-tab]').forEach(function (c) { c.removeAttribute('data-active'); });
                chip.setAttribute('data-active', 'true');
                document.querySelectorAll('[data-tn-domain-panel]').forEach(function (p) {
                    p.hidden = p.getAttribute('data-tn-domain-panel') !== target;
                });
                document.getElementById('domain-action').value = target;
            });
        });

        function wireSwitch(inputId, trackId, panelId) {
            const input = document.getElementById(inputId);
            const track = document.getElementById(trackId);
            if (!input || !track) { return; }
            input.addEventListener('change', function () {
                track.classList.toggle('tn-switch-track--on', input.checked);
                const panel = document.getElementById(panelId);
                if (!panel) { return; }
                if (input.checked) { fadeIn(panel); } else { panel.style.display = 'none'; }
            });
        }
        wireSwitch('nameserversCb', 'nameservers-switch', 'nameservers');
        wireSwitch('transferNameserversCb', 'transfer-nameservers-switch', 'transferNameservers');

        const configNext = document.getElementById('config-next');
        configNext.style.display = 'none';
        configNext.disabled = true;

        const addons = document.querySelector('.addons');
        if (addons) {
            const orderButton = document.querySelector('.order-button');
            if (orderButton) {
                orderButton.addEventListener('click', function () {
                    this.style.display = 'none';
                    slideDown(addons);
                    return false;
                });
            }
        }

        document.querySelectorAll('.addon-period-selector').forEach(el => {
            el.addEventListener('change', function () {
                const r = this.getAttribute('rel');
                const spans = document.querySelectorAll('#' + r + ' span');
                spans.forEach(span => span.style.display = 'none');
                const visibleSpan = document.querySelector('#' + r + ' span.' + this.value);
                if (visibleSpan) {
                    fadeIn(visibleSpan);
                }
            });
            el.dispatchEvent(new Event('change'));
        });

        const formatCurrency = (price, rate, code, multiply) => {
            let total = parseFloat(price) * parseFloat(rate);
            if (typeof multiply !== 'undefined') {
                total *= multiply;
            }
            return new Intl.NumberFormat(undefined, {
                style: 'currency',
                currency: code,
                currencyDisplay: 'narrowSymbol',
            }).format(total);
        };

        const transferNameserversCb = document.getElementById('transferNameserversCb');

        function transferCodeRequired() {
            const select = document.getElementById('transfer-tld-select');
            const option = select ? select.options[select.selectedIndex] : null;
            return option ? option.getAttribute('data-requires-code') === '1' : true;
        }

        function updateTransferCodeRequirement() {
            const hint = document.getElementById('transfer-code-hint');
            const codeInput = document.getElementById('transfer-code-input');
            const required = transferCodeRequired();
            if (hint) {
                hint.textContent = required
                    ? "{{ 'This TLD requires an auth/EPP code from your current registrar to transfer.'|trans|e('js') }}"
                    : "{{ 'This TLD does not require an auth code to transfer — you can leave this blank.'|trans|e('js') }}";
            }
            const hasCode = codeInput && codeInput.value.trim() !== '';
            const domainTransferConfig = document.getElementById('domain-transfer-config');
            const configVisible = domainTransferConfig && domainTransferConfig.style.display !== 'none';
            if (configVisible && configNext) {
                configNext.disabled = required && !hasCode;
            }
        }

        const transferCodeInput = document.getElementById('transfer-code-input');
        if (transferCodeInput) {
            transferCodeInput.addEventListener('input', updateTransferCodeRequirement);
        }
        const transferTldSelectEl = document.getElementById('transfer-tld-select');
        if (transferTldSelectEl) {
            transferTldSelectEl.addEventListener('change', updateTransferCodeRequirement);
        }
        document.getElementById('registration-years')?.addEventListener('change', function () {
            if (typeof updateConfigSummaryForRegister === 'function') { updateConfigSummaryForRegister(); }
        });

        const transferCheck = document.getElementById('transfer-check');
        if (transferCheck) {
            transferCheck.addEventListener('click', function (event) {
                const sld = document.querySelector('input[name="transfer_sld"]').value.toLowerCase();
                const tld = document.querySelector('select[name="transfer_tld"]').value.toLowerCase();
                document.getElementById('domain-action').value = 'transfer';
                const domain = sld + tld;

                FOSSBilling.api.guest.post(
                    'servicedomain/can_be_transferred',
                    {sld: sld, tld: tld},
                    function (result) {
                        setTransferPricing(tld);
                        const domainNameEl = document.getElementById('domain-name');
                        if (domainNameEl) domainNameEl.textContent = domain;
                        const transferConfig = document.getElementById('domain-transfer-config');
                        if (transferConfig) fadeIn(transferConfig);
                        const onAfterDomainCheck = document.querySelector('.onAfterDomainCheck');
                        if (onAfterDomainCheck) fadeIn(onAfterDomainCheck);

                        const transferOrderButton = document.querySelector('#transfer .order-button');
                        if (transferOrderButton) transferOrderButton.style.display = '';

                        const statusEl = document.getElementById('transfer-ns-scan-status');
                        const ns1 = document.querySelector('#transferNameservers input[name="ns1"]');
                        const ns2 = document.querySelector('#transferNameservers input[name="ns2"]');
                        const ns3 = document.querySelector('#transferNameservers input[name="ns3"]');
                        const ns4 = document.querySelector('#transferNameservers input[name="ns4"]');
                        if (statusEl) statusEl.textContent = "{{ 'Scanning current nameservers...'|trans|e('js') }}";

                        FOSSBilling.api.guest.post(
                            'servicedomain/scan_nameservers',
                            {sld: sld, tld: tld},
                            function (scanned) {
                                if (Array.isArray(scanned) && scanned.length > 0) {
                                    if (ns1) ns1.value = scanned[0] || '';
                                    if (ns2) ns2.value = scanned[1] || '';
                                    if (ns3) ns3.value = scanned[2] || '';
                                    if (ns4) ns4.value = scanned[3] || '';
                                    if (statusEl) statusEl.textContent = "{{ 'Detected the domain\'s current nameservers below. Review and edit them, or uncheck to use our default nameservers instead.'|trans|e('js') }}";
                                    if (transferNameserversCb) {
                                        transferNameserversCb.checked = true;
                                        transferNameserversCb.dispatchEvent(new Event('change'));
                                    }
                                } else if (statusEl) {
                                    statusEl.textContent = "{{ 'Could not detect current nameservers. Enter them manually if you want to keep them, or leave unchecked to use our default nameservers.'|trans|e('js') }}";
                                }
                            },
                            function () {
                                if (statusEl) statusEl.textContent = "{{ 'Could not detect current nameservers. Enter them manually if you want to keep them, or leave unchecked to use our default nameservers.'|trans|e('js') }}";
                            },
                        );
                    },
                );

                return false;
            });
        }

        const domainCheck = document.getElementById('domain-check');
        if (domainCheck) {
            domainCheck.addEventListener('click', function (event) {
                const sld = document.querySelector('input[name="register_sld"]').value.toLowerCase();
                const tld = document.querySelector('select[name="register_tld"]').value.toLowerCase();
                const domain = sld + tld;
                document.getElementById('domain-action').value = 'register';
                FOSSBilling.api.guest.post(
                    'servicedomain/check',
                    {sld: sld, tld: tld},
                    function (result) {
                        setPricing(tld);
                        const domainNameEl = document.getElementById('domain-name');
                        if (domainNameEl) domainNameEl.textContent = domain;
                        const onAfterDomainCheck = document.querySelector('.onAfterDomainCheck');
                        if (onAfterDomainCheck) fadeIn(onAfterDomainCheck);

                        const registerOrderButton = document.querySelector('#register .order-button');
                        if (registerOrderButton) registerOrderButton.style.display = '';
                    },
                );

                return false;
            });
        }

        let registerYearTotals = {};

        function updateConfigSummaryForRegister() {
            const yearsSelect = document.getElementById('registration-years');
            if (!yearsSelect || !window.tnSetConfigSummaryBase) { return; }
            const years = parseInt(yearsSelect.value, 10) || 1;
            window.tnSetConfigSummaryBase(registerYearTotals[years] || 0);
        }

        function setPricing(tld) {
            FOSSBilling.api.guest.post(
                'servicedomain/pricing',
                {tld: tld},
                function (result) {
                    const yearsSelect = document.getElementById('registration-years');
                    if (!yearsSelect) return;
                    yearsSelect.innerHTML = '';

                    const regPrice = Number(result.price_registration);
                    let renewPrice = Number(result.price_renew);

                    if (result.price_renew === null || typeof result.price_renew === 'undefined' || isNaN(renewPrice)) {
                        renewPrice = regPrice;
                    }

                    const yearLabel = "{{ ' Year @ '|trans|e('js') }}";
                    const yearsLabel = "{{ ' Years @ '|trans|e('js') }}";

                    registerYearTotals = {};
                    for (let i = 1; i <= 5; i++) {
                        const totalPrice = (i === 1) ? regPrice : regPrice + (i - 1) * renewPrice;
                        const priceFormatted = formatCurrency(
                            totalPrice,
                            {{ currency.conversion_rate }},
                            "{{ currency.code }}",
                            1
                        );
                        registerYearTotals[i] = totalPrice * {{ currency.conversion_rate }};

                        yearsSelect.append(
                            new Option(i + (i === 1 ? yearLabel : yearsLabel) + priceFormatted, i)
                        );
                    }

                    updateConfigSummaryForRegister();

                    configNext.style.display = '';
                    configNext.disabled = false;
                },
            );
        }

        function setTransferPricing(tld) {
            FOSSBilling.api.guest.post(
                'servicedomain/pricing',
                {tld: tld},
                function (result) {
                    const price = formatCurrency(result.price_transfer, {{ currency.conversion_rate }}, "{{ currency.code }}");
                    const transferPriceEl = document.getElementById('transfer-price');
                    if (transferPriceEl) transferPriceEl.textContent = price;
                    if (window.tnSetConfigSummaryBase) {
                        window.tnSetConfigSummaryBase(Number(result.price_transfer) * {{ currency.conversion_rate }});
                    }
                    configNext.style.display = '';
                    updateTransferCodeRequirement();
                },
            );
        }

        // Handle URL parameters for pre-filling domain form
        const urlParams = new URLSearchParams(window.location.search);

        const tldParam = urlParams.get('tld');
        if (tldParam) {
            const normalizedTldParam = tldParam.charAt(0) === '.' ? tldParam : '.' + tldParam;
            const registerTldSelect = document.querySelector('select[name="register_tld"]');
            if (registerTldSelect) {
                for (let i = 0; i < registerTldSelect.options.length; i++) {
                    if (registerTldSelect.options[i].value === normalizedTldParam) {
                        registerTldSelect.selectedIndex = i;
                        break;
                    }
                }
            }
            const transferTldSelect = document.querySelector('select[name="transfer_tld"]');
            if (transferTldSelect) {
                for (let i = 0; i < transferTldSelect.options.length; i++) {
                    if (transferTldSelect.options[i].value === normalizedTldParam) {
                        transferTldSelect.selectedIndex = i;
                        break;
                    }
                }
            }
        }

        const nameParam = urlParams.get('name');
        if (nameParam) {
            const registerSldInput = document.querySelector('input[name="register_sld"]');
            if (registerSldInput) {
                registerSldInput.value = nameParam;
            }
            const transferSldInput = document.querySelector('input[name="transfer_sld"]');
            if (transferSldInput) {
                transferSldInput.value = nameParam;
            }
        }

        const tabParam = urlParams.get('tab');
        if (tabParam) {
            const chip = document.querySelector('[data-tn-domain-tab="' + tabParam + '"]');
            if (chip) { chip.click(); }
        }

        if (nameParam && tabParam === 'transfer') {
            const transferCheckBtn = document.getElementById('transfer-check');
            if (transferCheckBtn) { transferCheckBtn.click(); }
        } else if (nameParam && tabParam !== 'transfer') {
            const domainCheckBtn = document.getElementById('domain-check');
            if (domainCheckBtn) { domainCheckBtn.click(); }
        }
    });
</script>
