{% if order.status == 'active' %}
    {% set days_left = service.expires_at ? service.expires_at|daysleft : null %}
    {% set expiring_soon = days_left is not null and days_left <= 30 %}

    <div class="tn-card mb-4">
        <div class="d-flex justify-content-between align-items-start flex-wrap mb-3" style="gap: var(--space-3);">
            <div>
                <div class="d-flex align-items-center flex-wrap" style="gap: var(--space-2);">
                    <h1 class="mb-0 font-mono" style="font-size: var(--fs-h3);">{{ service.domain }}</h1>
                    {{ mf.status_badge(order.status, 'order') }}
                </div>
                <span class="small text-muted">
                    {% if service.registered_at %}{{ 'Registered'|trans }} {{ service.registered_at|format_date(pattern="MMM dd, yyyy") }} &middot; {% endif %}
                    {% if service.expires_at %}{{ 'expires'|trans }} {{ service.expires_at|format_date(pattern="MMM dd, yyyy") }}{% endif %}
                    {% if service.contact.first_name or service.contact.last_name %} &middot; {{ 'registrant'|trans }} {{ service.contact.first_name }} {{ service.contact.last_name }}{% endif %}
                </span>
            </div>
            {% if expiring_soon and order.period %}
                <a class="tn-btn tn-btn--primary tn-btn--sm"
                   {{ fb_api_link({href: 'invoice/renewal_invoice'|api_url(query: {order_id: order.id}), modal: {type: 'confirm', title: 'Are you sure?'|trans, content: 'This will generate new invoice. Are you sure you want to continue?'|trans}, callback: 'onRenewalInvoiceCreated'}) }}>
                    {{ 'Renew now'|trans }} &middot; {{ order.total|format_currency(order.currency ?? default_currency) }}
                </a>
                <script>window.onRenewalInvoiceCreated = (hash) => { window.location = "{{ 'invoice'|url }}/" + hash; };</script>
            {% endif %}
        </div>

        {% if expiring_soon %}
            <div class="tn-attention-row mb-3" style="border: var(--bw-hair) solid var(--danger-500); border-radius: var(--r-md); background: var(--danger-bg);">
                <span class="tn-attention-row__icon tn-attention-row__icon--danger">
                    <svg class="icon"><use href="#alert-triangle" /></svg>
                </span>
                <div class="tn-attention-row__body">
                    <span class="tn-attention-row__title">
                        {% if days_left <= 0 %}{{ 'This domain has expired'|trans }}{% else %}{{ 'This domain expires in %days% day(s)'|trans({'%days%': days_left}) }}{% endif %}
                    </span>
                    <span class="tn-attention-row__sub">{{ 'Renew it to avoid service interruption.'|trans }}</span>
                </div>
            </div>
        {% endif %}

        {# Real, navigable sections only: no DNS-record CRUD exists on Servicedomain's
           Client API in this install - only nameservers/WHOIS/lock/privacy/transfer-code -
           so tabs map 1:1 to what's real rather than the design spec's DNS/records naming. #}
        <div class="tn-tabs mb-3">
            <div class="tn-tabs__nav">
                <button type="button" class="tn-tabs__tab tn-tabs__tab--active" data-tn-tab="#overview">{{ 'Overview'|trans }}</button>
                <button type="button" class="tn-tabs__tab" data-tn-tab="#nameservers">{{ 'Nameservers'|trans }}</button>
                <button type="button" class="tn-tabs__tab" data-tn-tab="#whois">{{ 'Whois'|trans }}</button>
                <button type="button" class="tn-tabs__tab" data-tn-tab="#transfer">{{ 'Transfer'|trans }}</button>
            </div>
        </div>

        <div class="tn-tab-panes">
            <div class="tn-tab-pane" id="overview" style="display:block;">
                <div class="d-flex flex-wrap" style="gap: var(--space-4);">
                    <div style="flex: 1 1 420px; min-width: 0;">
                        {# No DNS-record CRUD exists in this install's Servicedomain API - relabeled
                           "Nameservers" (the real, mutable field set) rather than a fabricated DNS table. #}
                        <div class="tn-card tn-card--compact mb-3">
                            <div class="tn-card__header">
                                <span class="tn-card__title">{{ 'Nameservers'|trans }}</span>
                                <button type="button" class="tn-btn tn-btn--secondary tn-btn--sm" data-tn-tab="#nameservers">{{ 'Change'|trans }}</button>
                            </div>
                            <span class="tn-card__subtitle mb-2 d-block">{{ 'Changes propagate in up to 24 hours.'|trans }}</span>
                            <div class="tn-kv-row">
                                <span class="tn-kv-row__key">NS1</span>
                                <span class="tn-kv-row__value font-mono">{{ service.ns1 ?: '—' }}</span>
                            </div>
                            <div class="tn-kv-row">
                                <span class="tn-kv-row__key">NS2</span>
                                <span class="tn-kv-row__value font-mono">{{ service.ns2 ?: '—' }}</span>
                            </div>
                            {% if service.ns3 %}
                            <div class="tn-kv-row">
                                <span class="tn-kv-row__key">NS3</span>
                                <span class="tn-kv-row__value font-mono">{{ service.ns3 }}</span>
                            </div>
                            {% endif %}
                            {% if service.ns4 %}
                            <div class="tn-kv-row">
                                <span class="tn-kv-row__key">NS4</span>
                                <span class="tn-kv-row__value font-mono">{{ service.ns4 }}</span>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                    <div style="flex: 0 0 330px; width: 330px; max-width: 100%;">
                        <div class="tn-card tn-card--compact mb-3">
                            <div class="tn-card__header">
                                <span class="tn-card__title">{{ 'Protection'|trans }}</span>
                            </div>
                            <label class="tn-switch-wrap d-flex justify-content-between align-items-center py-2" style="width:100%;">
                                <span>{{ 'WHOIS privacy'|trans }}</span>
                                <span class="tn-switch-track{{ service.privacy == 1 ? ' tn-switch-track--on' : '' }}" id="privacy-switch">
                                    <input class="tn-switch-input" type="checkbox" {% if service.privacy == 1 %}checked{% endif %} id="domain-privacy-toggle">
                                    <span class="tn-switch-thumb"></span>
                                </span>
                            </label>
                            <label class="tn-switch-wrap d-flex justify-content-between align-items-center py-2" style="width:100%;">
                                <span>{{ 'Transfer lock'|trans }}</span>
                                <span class="tn-switch-track{{ service.locked == 1 ? ' tn-switch-track--on' : '' }}" id="lock-switch">
                                    <input class="tn-switch-input" type="checkbox" {% if service.locked == 1 %}checked{% endif %} id="domain-lock-toggle">
                                    <span class="tn-switch-thumb"></span>
                                </span>
                            </label>
                            {# DNSSEC is not a field exposed anywhere on Model_ServiceDomain / this Client API - omitted rather than fabricated. #}
                        </div>

                        <div class="tn-card tn-card--compact mb-3">
                            <div class="tn-card__header">
                                <span class="tn-card__title">{{ 'Renewal'|trans }}</span>
                            </div>
                            <label class="tn-switch-wrap d-flex justify-content-between align-items-center py-2" style="width:100%;">
                                <span>{{ 'Auto-renew'|trans }}</span>
                                <span class="tn-switch-track{{ service.autorenew == 1 ? ' tn-switch-track--on' : '' }}" id="autorenew-switch">
                                    <input class="tn-switch-input" type="checkbox" {% if service.autorenew == 1 %}checked{% endif %} id="domain-autorenew-toggle">
                                    <span class="tn-switch-thumb"></span>
                                </span>
                            </label>
                            <span class="small text-muted d-block mt-1">{{ 'When off, this domain won\'t be automatically invoiced or renewed near its expiry date.'|trans }}</span>
                        </div>

                        <div class="tn-card tn-card--compact mb-3">
                            <div class="tn-card__header">
                                <span class="tn-card__title">{{ 'Danger zone'|trans }}</span>
                            </div>
                            <span class="small text-muted d-block mb-2">{{ 'Transfer away — unlocks and emails the EPP code.'|trans }}</span>
                            <button class="tn-btn tn-btn--secondary tn-btn--block" type="button" id="get-epp">{{ 'Get EPP code'|trans }}</button>
                        </div>
                    </div>
                </div>
            </div>

            {# Domain nameservers #}
            <div class="tn-tab-pane" id="nameservers" style="display:none;">
                <div class="tn-card tn-card--compact" style="max-width: 480px;">
                    <h5 class="mb-1">{{ 'Update Nameservers'|trans }}</h5>
                    <span class="small text-muted d-block mb-3">{{ 'If you would like to host this domain with another company you can update nameservers.'|trans }}</span>
                    <form method="post" action="{{ 'servicedomain/update_nameservers'|api_url }}" {{ fb_api_form({message: 'Nameservers Updated'|trans}) }}>
                        <div class="d-flex flex-column mb-3" style="gap: var(--space-2);">
                            <div>
                                <label class="form-label small text-muted">NS1</label>
                                <input class="tn-input" type="text" name="ns1" value="{{ request.ns1|default(service.ns1) }}" required>
                            </div>
                            <div>
                                <label class="form-label small text-muted">NS2</label>
                                <input class="tn-input" type="text" name="ns2" value="{{ request.ns2|default(service.ns2) }}" required>
                            </div>
                            <div>
                                <label class="form-label small text-muted">NS3</label>
                                <input class="tn-input" type="text" name="ns3" value="{{ request.ns3|default(service.ns3) }}">
                            </div>
                            <div>
                                <label class="form-label small text-muted">NS4</label>
                                <input class="tn-input" type="text" name="ns4" value="{{ request.ns4|default(service.ns4) }}">
                            </div>
                        </div>
                        <input type="hidden" name="order_id" value="{{ order.id }}">
                        <button class="tn-btn tn-btn--primary" type="submit">{{ 'Update'|trans }}</button>
                    </form>
                </div>
            </div>

            {# Domain WHOIS #}
            <div class="tn-tab-pane" id="whois" style="display:none;">
                <div class="tn-card tn-card--compact">
                    <h5 class="mb-1">{{ 'Update Domain Contact Details'|trans }}</h5>
                    <span class="small text-muted d-block mb-3">{{ 'Domain contact details will be displayed once someone will check WHOIS output (which is public) of your service. This will update Technical, Billing and Admin contacts for this service. You can enable domain privacy protection above if you want to hide your public WHOIS information.'|trans }}</span>
                    <form method="post" action="{{ 'servicedomain/update_contacts'|api_url }}" {{ fb_api_form({message: 'Contact Details Updated'|trans}) }}>
                        <div class="mb-3 row">
                            <div class="col-md-5">
                                <label for="whois_first_name" class="form-label">{{ 'First Name'|trans }}</label>
                                <input class="tn-input" type="text" name="contact[first_name]" id="whois_first_name"
                                       value="{{ request.first_name|default(service.contact.first_name) }}" required>
                            </div>
                            <div class="col-md-5">
                                <label for="whois_last_name" class="form-label">{{ 'Last Name'|trans }}</label>
                                <input class="tn-input" type="text" name="contact[last_name]" id="whois_last_name"
                                       value="{{ request.last_name|default(service.contact.last_name) }}" required>
                            </div>
                        </div>
                        <div class="mb-3 row">
                            <div class="col-md-5">
                                <label for="whois_email" class="form-label">{{ 'Email'|trans }}</label>
                                <input class="tn-input" type="text" name="contact[email]" id="whois_email"
                                       value="{{ request.email|default(service.contact.email) }}" required>
                            </div>
                            <div class="col-md-5">
                                <label for="whois_company" class="form-label">{{ 'Company'|trans }}</label>
                                <input class="tn-input" type="text" name="contact[company]" id="whois_company"
                                       value="{{ request.company|default(service.contact.company) }}">
                            </div>
                        </div>
                        <div class="mb-3 row">
                            <div class="col-md-5">
                                <label for="whois_address1" class="form-label">{{ 'Address Line 1'|trans }}</label>
                                <input class="tn-input" type="text" name="contact[address1]" id="whois_address1"
                                       value="{{ request.address1|default(service.contact.address1) }}" required>
                            </div>
                            <div class="col-md-5">
                                <label for="whois_address2" class="form-label">{{ 'Address Line 2'|trans }}</label>
                                <input class="tn-input" type="text" name="contact[address2]" id="whois_address2"
                                       value="{{ request.address2|default(service.contact.address2) }}">
                            </div>
                        </div>
                        <div class="mb-3 row">
                            <div class="col-md-5">
                                <label for="whois_country" class="form-label">{{ 'Country'|trans }}</label>
                                <select class="tn-select" name="contact[country]" id="whois_country" required>
                                    <option value="">{{ 'Select Country'|trans }}</option>
                                    {% for code, name in country_names() %}
                                        <option value="{{ code }}" {% if (request.country|default(service.contact.country)) == code %}selected{% endif %}>{{ name }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-md-5">
                                <label for="whois_city" class="form-label">{{ 'City'|trans }}</label>
                                <input class="tn-input" type="text" name="contact[city]" id="whois_city"
                                       value="{{ request.city|default(service.contact.city) }}" required>
                            </div>
                        </div>
                        <div class="mb-3 row">
                            <div class="col-md-5">
                                <label for="whois_state" class="form-label">{{ 'State'|trans }}</label>
                                <input class="tn-input" type="text" name="contact[state]" id="whois_state"
                                       value="{{ request.state|default(service.contact.state) }}" required>
                            </div>

                            <div class="col-md-5">
                                <label for="whois_postcode" class="form-label">{{ 'Zip'|trans }}</label>
                                <input class="tn-input" type="text" name="contact[postcode]" id="whois_postcode"
                                       value="{{ request.postcode|default(service.contact.postcode) }}" required>
                            </div>
                        </div>
                        <div class="mb-3 row">
                            <div class="col-md-10">
                                <label for="whois_phone" class="form-label">{{ 'Phone Number'|trans }}</label>
                                <input type="hidden" name="contact[phone_cc]" id="whois_phone_cc" value="{{ request.phone_cc|default(service.contact.phone_cc) }}">
                                <input class="tn-input js-phone-input" type="tel" name="contact[phone]" id="whois_phone"
                                       value="{{ request.phone|default(service.contact.phone) }}" autocomplete="tel" data-initial-country="{{ request.country|default(service.contact.country)|lower }}" required>
                            </div>
                        </div>
                        <input type="hidden" name="order_id" value="{{ order.id }}">
                        <button class="tn-btn tn-btn--primary" type="submit">{{ 'Update'|trans }}</button>
                    </form>
                </div>
            </div>

            {# Domain transfer #}
            <div class="tn-tab-pane" id="transfer" style="display:none;">
                <div class="tn-card tn-card--compact" style="max-width: 480px;">
                    <h5 class="mb-1">{{ 'Domain Secret'|trans }}</h5>
                    <span class="small text-muted d-block mb-3">{{ 'Most domain names (except a few top-level domains like .EU and .UK) have a Domain Secret Key/Authorization Code (EPP Code) associated with them. This code is typically required when transferring the domain to a new registrar.'|trans }}</span>
                    <button class="tn-btn tn-btn--primary" type="button" id="get-epp-tab">{{ 'Get EPP Code'|trans }}</button>
                </div>
            </div>
        </div>
    </div>

    {% block js %}
        <script>
            document.addEventListener("DOMContentLoaded", function() {
                document.querySelectorAll('[data-tn-tab]').forEach(function (btn) {
                    btn.addEventListener('click', function () {
                        var target = btn.getAttribute('data-tn-tab');
                        var pane = document.querySelector(target);
                        if (!pane) return;
                        document.querySelectorAll('.tn-tabs__tab').forEach(function (t) { t.classList.remove('tn-tabs__tab--active'); });
                        document.querySelectorAll('.tn-tab-pane').forEach(function (p) { p.style.display = 'none'; });
                        var navBtn = document.querySelector('.tn-tabs__tab[data-tn-tab="' + target + '"]');
                        if (navBtn) navBtn.classList.add('tn-tabs__tab--active');
                        pane.style.display = 'block';
                        pane.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    });
                });

                function toggleSwitch(el, on) {
                    el.classList.toggle('tn-switch-track--on', on);
                    el.querySelector('.tn-switch-input').checked = on;
                }

                document.getElementById('domain-lock-toggle').addEventListener('change', function (event) {
                    var track = document.getElementById('lock-switch');
                    var endpoint = event.target.checked ? 'servicedomain/lock' : 'servicedomain/unlock';
                    FOSSBilling.api.client.post(endpoint, { order_id: {{ order.id }} },
                        () => {
                            FOSSBilling.message(event.target.checked ? 'Domain locked' : 'Domain unlocked');
                            toggleSwitch(track, event.target.checked);
                        },
                        () => { event.target.checked = !event.target.checked; }
                    );
                });

                document.getElementById('domain-privacy-toggle').addEventListener('change', function (event) {
                    var track = document.getElementById('privacy-switch');
                    var endpoint = event.target.checked ? 'servicedomain/enable_privacy_protection' : 'servicedomain/disable_privacy_protection';
                    FOSSBilling.api.client.post(endpoint, { order_id: {{ order.id }} },
                        () => {
                            FOSSBilling.message(event.target.checked ? 'Privacy Protection enabled' : 'Privacy Protection disabled');
                            toggleSwitch(track, event.target.checked);
                        },
                        () => { event.target.checked = !event.target.checked; }
                    );
                });

                document.getElementById('domain-autorenew-toggle').addEventListener('change', function (event) {
                    var track = document.getElementById('autorenew-switch');
                    var endpoint = event.target.checked ? 'servicedomain/enable_autorenew' : 'servicedomain/disable_autorenew';
                    FOSSBilling.api.client.post(endpoint, { order_id: {{ order.id }} },
                        () => {
                            FOSSBilling.message(event.target.checked ? 'Auto-renew enabled' : 'Auto-renew disabled');
                            toggleSwitch(track, event.target.checked);
                        },
                        () => { event.target.checked = !event.target.checked; }
                    );
                });

                function fetchEpp() {
                    FOSSBilling.api.client.post('servicedomain/get_transfer_code', { order_id: {{ order.id }} },
                        (result) => {
                            FOSSBilling.message('Domain transfer code is: ' + result);
                        });
                }
                document.getElementById('get-epp').addEventListener('click', function (event) {
                    event.preventDefault();
                    fetchEpp();
                });
                document.getElementById('get-epp-tab').addEventListener('click', function (event) {
                    event.preventDefault();
                    fetchEpp();
                });
            });
        </script>
    {% endblock %}
{% endif %}
