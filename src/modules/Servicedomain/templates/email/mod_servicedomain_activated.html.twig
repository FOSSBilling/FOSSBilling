{% block subject %}[{{ guest.system_company.name }}] {{ order.title|default('') }}{% endblock %}
{% block content %}
{% set order = order|default({}) %}
{% set service = service|default({}) %}
<!DOCTYPE html>
<html>
<head>
	<meta charset="utf-8">
	<style type="text/css">
		body {
			font-family: Arial, sans-serif;
			font-size: 14px;
			color: #333333;
		}

		h1 {
			font-size: 24px;
			font-weight: bold;
			margin: 0 0 20px;
		}

		p {
			margin: 0 0 10px;
		}

		strong {
			font-weight: bold;
		}

		.signature {
			font-style: italic;
			color: #999999;
			margin-top: 20px;
			border-top: 1px solid #cccccc;
			padding-top: 10px;
		}
	</style>
</head>
<body>
	<h1>Order Activated</h1>
	<p>Hello {{ c.first_name|default('') }} {{ c.last_name|default('') }},</p>
	<p>Your <strong>{{ order.title|default('') }}</strong> is now activated.</p>
    <p>Please keep in mind that your domain name may not be visible on the internet instantly due to the propagation process which may take up to 48 hours.</p>
    <p>Your website and email will not function until the domain has propagated.</p>

    <p>Domain details:</p>
    <ul>
        <li><strong>Domain:</strong> {{ service.domain|default('') }}</li>
        <li><strong>Registration Date:</strong> {{order.created_at|default('')|format_date}}</li>
        <li><strong>Registration Period:</strong> {{service.period|default('')}} Year(s)</li>
        {% if order.expires_at|default(false) %}<li><strong>Expires On:</strong> {{ order.expires_at|format_date }}</li>{% endif %}
        {% if order.period|default(false) %}<li><strong>Billing Period:</strong> {{ order.total|default(0)|format_currency(order.currency|default(default_currency)) }} every {{ order.period|default('')|period_title }}</li>{% endif %}
    </ul>

    <p>Nameserver details:</p>
    <ul>
        <li><strong>Nameserver 1:</strong> {{ service.server.ns1|default('') }}</li>
        <li><strong>Nameserver 2:</strong> {{ service.server.ns2|default('') }}</li>
        {% if  service.server.ns3|default('') %}<li><strong>Nameserver 3:</strong> {{ service.server.ns3|default('') }}</li>{% endif %}
        {% if  service.server.ns4|default('') %}<li><strong>Nameserver 4:</strong> {{ service.server.ns4|default('') }}</li>{% endif %}
    </ul>

    <p>You may <a href="{{ 'login'|url(query: { 'email': c.email|default('') }, area: 'client') }}" target="_blank">login</a> or <a href='{{ "order/service/manage/#{order.id|default('')}"|url(area: 'client') }}' target="_blank">manage your order.</a>

	<p class="signature">{{ guest.system_company.signature }}</p>
</body>
</html>
{% endblock %}
