{% extends 'layout_default.html.twig' %}

{% import 'macro_functions.html.twig' as mf %}

{% set active_menu = 'products' %}

{% block meta_title %}{{ 'Product Configuration'|trans }}{% endblock %}

{% block breadcrumbs %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="{{ '/'|url }}">
                <svg class="icon">
                    <use xlink:href="#home" />
                </svg>
            </a>
        </li>
        <li class="breadcrumb-item">
            <a href="{{ 'product'|url }}">{{ 'Products'|trans }}</a>
        </li>
        <li class="breadcrumb-item active">{{ product.title }}</li>
    </ol>
{% endblock %}

{% block content %}
{% embed 'partial_admin_detail_tabs.html.twig' with {
    title: product.title,
    subtitle: 'Manage product settings, service configuration, related addons, and upgrade paths.'|trans
} %}
    {% block detail_tabs %}
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="settings-tab" data-bs-toggle="tab" data-bs-target="#tab-settings" type="button" role="tab" aria-controls="index" aria-selected="true">{{ 'General Settings'|trans }}</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="config-tab" data-bs-toggle="tab" data-bs-target="#tab-config" type="button" role="tab" aria-controls="index" aria-selected="true">{{ 'Configuration'|trans }}</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="addons-tab" data-bs-toggle="tab" data-bs-target="#tab-addons" type="button" role="tab" aria-controls="index" aria-selected="true">{{ 'Addons'|trans }}</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="upgrades-tab" data-bs-toggle="tab" data-bs-target="#tab-upgrades" type="button" role="tab" aria-controls="index" aria-selected="true">{{ 'Upgrades'|trans }}</button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="links-tab" data-bs-toggle="tab" data-bs-target="#tab-links" type="button" role="tab" aria-controls="index" aria-selected="true">{{ 'Links'|trans }}</button>
                    </li>
    {% endblock %}

    {% block detail_tab_content %}
        {% import 'macro_functions.html.twig' as mf %}
        <div class="tab-pane fade show active" id="tab-settings" role="tabpanel">
            <div class="p-3">
                <form method="post" action="admin/product/update" name="form" {{ fb_api_form({message: 'Product Configuration Updated'|trans}) }}>
                    {% embed 'partial_admin_form_card.html.twig' with {
                        title: 'Product Settings'|trans,
                        subtitle: 'Manage visibility, fulfillment behavior, stock controls, pricing, and ordering details for this product.'|trans
                    } %}
                        {% import 'macro_functions.html.twig' as mf %}
                        {% block form_content %}
                            <h6 class="card-title text-secondary mb-3">{{ 'Product Details'|trans }}</h6>
                            <div class="row g-3">
                                <div class="col-lg-6">
                                    <label class="form-label">{{ 'Category'|trans }}</label>
                                    {{ mf.selectbox('product_category_id', guest.product_category_get_pairs, product.product_category_id, 0, 'None') }}
                                </div>
                                {% if guest.extension_is_on({ 'mod': 'formbuilder' }) %}
                                <div class="col-lg-6">
                                    <label class="form-label">{{ 'Order Form'|trans }}</label>
                                    {% set tpl = 'mod_service' ~ product.type ~ '_order_form.html.twig' %}
                                    {% if guest.system_template_exists({ 'file': tpl }) %}
                                        <div class="form-control-plaintext text-secondary py-2">
                                            {{ 'Edit'|trans }} <code>{{ tpl }}</code> {{ 'to change the order form for'|trans }} <strong>{{ product.type }}</strong> {{ 'category products.'|trans }}
                                        </div>
                                    {% else %}
                                        <div class="input-group">
                                            {{ mf.selectbox('form_id', admin.formbuilder_get_pairs, product.form_id, 0, 'None') }}
                                            <a href="{{ 'extension/settings/formbuilder'|url }}{% if product.form_id %}?id={{ product.form_id }}{% endif %}" class="btn" id="formbuilder_btn">
                                                {% if product.form_id %}
                                                <svg class="icon">
                                                    <use xlink:href="#edit" />
                                                </svg>
                                                {{ 'Edit'|trans }}
                                                {% else %}
                                                <svg class="icon">
                                                    <use xlink:href="#plus" />
                                                </svg>
                                                {{ 'Add New'|trans }}
                                                {% endif %}
                                            </a>
                                        </div>
                                    {% endif %}
                                </div>
                                {% endif %}
                                <div class="col-lg-4">
                                    <label class="form-label d-block">{{ 'Status'|trans }}</label>
                                    <div class="d-flex flex-wrap gap-3">
                                        <label class="form-check">
                                            <input class="form-check-input" type="radio" id="statusEnabled" name="status" value="enabled"{% if product.status == 'enabled' %} checked{% endif %}>
                                            <span class="form-check-label">{{ 'Enabled'|trans }}</span>
                                        </label>
                                        <label class="form-check">
                                            <input class="form-check-input" type="radio" id="statusDisabled" name="status" value="disabled"{% if product.status == 'disabled' %} checked{% endif %}>
                                            <span class="form-check-label">{{ 'Disabled'|trans }}</span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <label class="form-label d-block">{{ 'Hidden'|trans }}</label>
                                    <div class="d-flex flex-wrap gap-3">
                                        <label class="form-check">
                                            <input class="form-check-input" type="radio" name="hidden" value="1"{% if product.hidden %} checked{% endif %} id="hidden-yes">
                                            <span class="form-check-label">{{ 'Yes'|trans }}</span>
                                        </label>
                                        <label class="form-check">
                                            <input class="form-check-input" type="radio" name="hidden" value="0"{% if not product.hidden %} checked{% endif %} id="hidden-no">
                                            <span class="form-check-label">{{ 'No'|trans }}</span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <label class="form-label d-block">{{ 'Activation'|trans }}</label>
                                    <div class="d-flex flex-wrap gap-3">
                                        <label class="form-check">
                                            <input class="form-check-input" type="radio" name="setup" value="after_order"{% if product.setup == 'after_order' %} checked{% endif %} id="activation-after-order">
                                            <span class="form-check-label">{{ 'After Order is Placed'|trans }}</span>
                                        </label>
                                        <label class="form-check">
                                            <input class="form-check-input" type="radio" name="setup" value="after_payment"{% if product.setup == 'after_payment' %} checked{% endif %} id="activation-after-payment">
                                            <span class="form-check-label">{{ 'After Payment is Received'|trans }}</span>
                                        </label>
                                        <label class="form-check">
                                            <input class="form-check-input" type="radio" name="setup" value="manual"{% if product.setup == 'manual' %} checked{% endif %} id="activation-manual">
                                            <span class="form-check-label">{{ 'Manual Activation'|trans }}</span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <label class="form-label">{{ 'Icon/Image URL'|trans }}</label>
                                    <input class="form-control" type="text" name="icon_url" id="bb-icon" value="{{ product.icon_url }}">
                                </div>
                                <div class="col-lg-6">
                                    <label class="form-label">{{ 'Title'|trans }}</label>
                                    <input class="form-control" type="text" name="title" value="{{ product.title }}" required>
                                </div>
                                <div class="col-lg-6">
                                    <label class="form-label">{{ 'Slug'|trans }}</label>
                                    <input class="form-control" type="text" name="slug" value="{{ product.slug }}" required>
                                </div>
                            </div>

                            <hr class="my-4">
                            <h6 class="card-title text-secondary mb-3">{{ 'Pricing and Stock Control'|trans }}</h6>
                            <div class="row g-3">
                                <div class="col-lg-6">
                                    <label class="form-label d-block">{{ 'Enable Stock Control'|trans }}</label>
                                    <div class="d-flex flex-wrap gap-3">
                                        <label class="form-check">
                                            <input class="form-check-input" type="radio" id="radioStockControlYes" name="stock_control" value="1"{% if product.stock_control %} checked{% endif %}>
                                            <span class="form-check-label">{{ 'Yes'|trans }}</span>
                                        </label>
                                        <label class="form-check">
                                            <input class="form-check-input" type="radio" id="radioStockControlNo" name="stock_control" value="0"{% if not product.stock_control %} checked{% endif %}>
                                            <span class="form-check-label">{{ 'No'|trans }}</span>
                                        </label>
                                    </div>
                                </div>
                                <div class="col-lg-6">
                                    <label class="form-label">{{ 'Quantity in Stock'|trans }}</label>
                                    <input class="form-control" type="text" name="quantity_in_stock" value="{{ product.quantity_in_stock }}">
                                </div>
                            </div>

                            <div class="mt-4">
                                {{ include('partial_pricing.html.twig', { 'product': product }) }}
                            </div>

                            <hr class="my-4">
                            <h6 class="card-title text-secondary mb-3">{{ 'Description'|trans }}</h6>
                            <div class="row g-3">
                                <div class="col-12">
                                    <label class="form-label">{{ 'Description'|trans }}</label>
                                    <textarea class="editor-textarea" name="description" rows="5">{{ product.description }}</textarea>
                                </div>
                            </div>

                            <input type="hidden" name="id" value="{{ product.id }}">
                        {% endblock %}

                        {% block form_actions %}
                            <button type="submit" class="btn btn-primary">{{ 'Update'|trans }}</button>
                        {% endblock %}
                    {% endembed %}
                </form>
            </div>
        </div>

        <div class="tab-pane fade" id="tab-config" role="tabpanel" aria-labelledby="config-tab">
            {% set service_partial = 'mod_service' ~ product.type ~ '_config.html.twig' %}
            {% if admin.system_template_exists({ 'file': service_partial }) %}
                {{ include(service_partial, { 'product': product }) }}
            {% else %}
                <div class="card-body">
                    <p class="text-muted mb-0">{{ 'No additional configuration for this product is required'|trans }}</p>
                </div>
            {% endif %}
        </div>

        <div class="tab-pane fade" id="tab-addons" role="tabpanel" aria-labelledby="addons-tab">
            <form method="post" action="admin/product/update" {{ fb_api_form({message: 'Product Configuration Updated'|trans}) }}>
                {% embed 'partial_admin_related_section.html.twig' with {
                    title: 'Product Addons'|trans,
                    subtitle: 'Choose which addons can be sold alongside this product and jump directly to addon editing when needed.'|trans,
                    card_class: 'm-3'
                } %}
                    {% block section_content %}
                        <input type="hidden" name="addons[]" value="">
                        <div class="table-responsive">
                            <table class="table card-table table-vcenter table-striped text-nowrap">
                                <tbody>
                                    {% for addon_id, addon_title in admin.product_addon_get_pairs %}
                                    <tr>
                                        <td class="w-1">
                                            <input class="form-check-input" type="checkbox" name="addons[]" value="{{ addon_id }}" id="addon_{{ addon_id }}"{% if addon_id in assigned_addons %} checked{% endif %}>
                                        </td>
                                        <td>
                                            <label for="addon_{{ addon_id }}">{{ addon_title }}</label>
                                        </td>
                                        <td class="w-1">
                                            <a class="btn btn-icon" href='{{ "product/addon/#{addon_id}"|url }}'>
                                                <svg class="icon">
                                                    <use xlink:href="#edit" />
                                                </svg>
                                            </a>
                                        </td>
                                    </tr>
                                    {% else %}
                                    <tr>
                                        <td class="text-muted" colspan="3">{{ 'The list is empty'|trans }}</td>
                                    </tr>
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endblock %}

                    {% block section_footer %}
                        <div class="d-flex justify-content-end gap-2">
                            <a href="{{ 'product/addons'|url }}#tab-new" class="btn btn-primary">
                                <svg class="icon">
                                    <use xlink:href="#plus" />
                                </svg>
                                {{ 'Create New Addon'|trans }}
                            </a>
                            <input type="hidden" name="id" value="{{ product.id }}">
                            <input type="submit" value="{{ 'Update'|trans }}" class="btn btn-primary">
                        </div>
                    {% endblock %}
                {% endembed %}
            </form>
        </div>

        <div class="tab-pane fade" id="tab-upgrades" role="tabpanel">
            <form method="post" action="admin/product/update" {{ fb_api_form({message: 'Product Configuration Updated'|trans}) }}>
                {% embed 'partial_admin_related_section.html.twig' with {
                    title: 'Product Upgrades'|trans,
                    subtitle: 'Choose which other products this product can upgrade to for existing clients.'|trans,
                    card_class: 'm-3'
                } %}
                    {% block section_content %}
                        <input type="hidden" name="upgrades[]" value=""/>
                        <div class="table-responsive">
                            <table class="table card-table table-vcenter table-striped text-nowrap">
                                <tbody>
                                    {% set products = admin.product_get_pairs %}
                                    {% for id,ptitle in products %}
                                    {% if id != product.id %}
                                    <tr>
                                        <td class="w-1">
                                            <input class="form-check-input" type="checkbox" name="upgrades[]" value="{{id}}" id="upgrades{{ id }}" {% if product.upgrades[id] %} checked{% endif %}>
                                        </td>
                                        <td>
                                            <label for="upgrades[{{ id }}]">{{ ptitle }}</label>
                                        </td>
                                    </tr>
                                    {% endif %}
                                    {% endfor %}
                                </tbody>
                            </table>
                        </div>
                    {% endblock %}

                    {% block section_footer %}
                        <div class="d-flex justify-content-end">
                            <input type="hidden" name="id" value="{{ product.id }}">
                            <button type="submit" class="btn btn-primary">{{ 'Update'|trans }}</button>
                        </div>
                    {% endblock %}
                {% endembed %}
            </form>
        </div>

        <div class="tab-pane fade" id="tab-links" role="tabpanel">
            {% embed 'partial_admin_related_section.html.twig' with {
                title: 'Product Links'|trans,
                subtitle: 'Use these client-facing links to open the product order page directly or share it externally.'|trans,
                card_class: 'm-3'
            } %}
                {% block section_content %}
                    <div class="card-body pt-0">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label">{{ 'Order Page (via ID)'|trans }}</label>
                                <input class="form-control" type="text" value='{{ "order/#{product.id}"|url(area: 'client') }}' readonly>
                            </div>
                            <div class="col-12">
                                <label class="form-label">{{ 'Order Page (via Link)'|trans }}</label>
                                <input class="form-control" type="text" value='{{ "order/#{product.slug}"|url(area: 'client') }}' readonly>
                            </div>
                        </div>
                    </div>
                {% endblock %}

                {% block section_footer %}
                    <div class="d-flex justify-content-center">
                        <a href='{{ "order/#{product.slug}"|url(area: 'client') }}' class="btn btn-primary" target="_blank">
                            <svg class="icon" width="24" height="24">
                                <use xlink:href="#search" />
                            </svg>
                            <span>{{ 'View as Client'|trans }}</span>
                        </a>
                    </div>
                {% endblock %}
            {% endembed %}
        </div>
    {% endblock %}
{% endembed %}
{% endblock %}

{% block head %}{{ mf.wysiwyg('.editor-textarea') }}{% endblock %}

{% block js %}
<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (document.querySelector("[name='form_id']")) {
            const formId = document.querySelector("[name='form_id']").value;
            const btn = document.getElementById("formbuilder_btn");

            if (formId !== "") {
                btn.innerHTML = "{{ 'Edit Form'|trans }}";
                const href = "{{ 'extension/settings/formbuilder'|url(query: { 'id': '' }) }}" + formId;
                btn.setAttribute('href', href);
            } else {
                btn.innerHTML = "{{ 'Add New Form'|trans }}";
                btn.setAttribute('href', "{{ 'extension/settings/formbuilder'|url }}");
            }
        }
    });
</script>
{% endblock %}
