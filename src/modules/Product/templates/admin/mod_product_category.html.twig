{% extends 'layout_default.html.twig' %}

{% import 'macro_functions.html.twig' as mf %}

{% set active_menu = 'products' %}

{% block meta_title %}{{ category.title }}{% endblock %}

{% block breadcrumbs %}
<ul class="breadcrumb">
    <li class="breadcrumb-item">
        <a href="{{ '/'|url }}">
            <svg class="icon">
                <use xlink:href="#home" />
            </svg>
        </a>
    </li>
    <li class="breadcrumb-item">
        <a href="{{ 'product'|url }}">{{ 'Products'|trans }}</a>
    </li>
    <li class="breadcrumb-item">
        <a href="{{ 'product'|url }}#tab-categories">{{ 'Categories'|trans }}</a>
    </li>
    <li class="breadcrumb-item active" aria-current="page">{{ category.title}}</li>
</ul>
{% endblock %}

{% block content %}
<div class="card">
    <form method="post" action="{{ 'product/category_update'|api_url }}" {{ fb_api_form({message: 'Category Updated'|trans}) }}>
        <div class="card-body">
            <div class="mb-3">
                <h3 class="card-title mb-1">{{ category.title }}</h3>
                <p class="text-secondary mb-0">{{ 'Update the category title, icon, and description shown on the products area.'|trans }}</p>
            </div>

            <div class="row g-3">
                <div class="col-lg-6">
                    <label class="form-label">{{ 'Title'|trans }}</label>
                    <input class="form-control" type="text" name="title" value="{{ category.title }}" required>
                </div>
                <div class="col-lg-6">
                    <label class="form-label">{{ 'Icon'|trans }}</label>
                    <div class="input-group">
                        <input class="form-control" type="text" name="icon_url" id="bb-icon" value="{{ category.icon_url }}">
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label">{{ 'Description'|trans }}</label>
                    <textarea class="editor-textarea" name="description" rows="5">{{ category.description }}</textarea>
                </div>
            </div>
        </div>

        <input type="hidden" name="id" value="{{ category.id }}">

        <div class="card-footer d-flex flex-wrap gap-2 justify-content-between">
            <a href="{{ 'product'|url }}" class="btn btn-secondary">
                <svg class="icon">
                    <use xlink:href="#arrow-sm-left" />
                </svg>
                {{ 'Go Back'|trans }}
            </a>
            <button class="btn btn-primary" type="submit">{{ 'Update'|trans }}</button>
        </div>
    </form>
</div>
{% endblock %}

{% block head %}{{ mf.wysiwyg('.editor-textarea') }}{% endblock %}
