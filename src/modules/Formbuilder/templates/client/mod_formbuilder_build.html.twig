{% if guest.extension_is_on({ "mod": "formbuilder" }) %}
    {% set form = guest.formbuilder_get({ "id": product.form_id }) %}
    <div class="tn-card tn-card--compact mb-3 mt-3">
    {% if form.style.show_title != "0" %}
        <div class="tn-card__header">
            <span class="tn-card__title">{{ form.name }}</span>
        </div>
    {% endif %}

        <fieldset class="d-flex flex-column gap-3">
            {% for field in form.fields %}
                {% if form.style.type == 'horizontal' %}
                    <div class="row align-items-start">
                        {% if field.hide_label != 1 %}
                            <label class="tn-field__label col-sm-2 pt-2" for="{{ field.name }}">{{ field.label }}</label>
                        {% endif %}
                        {% if field.description %}<div class="col-sm-2 fs-8 text-muted mt-0">{{ field.description | markdown_to_html }}</div>{% endif %}
                        <div class="col-sm-10">
                {% else %}
                    {% if field.hide_label != 1 %}
                        <label class="tn-field__label" for="{{ field.name }}">{{ field.label }}</label>
                    {% endif %}
                    {% if field.description %}<div class="fs-8 text-muted mt-0 mb-2">{{ field.description | markdown_to_html }}</div>{% endif %}
                {% endif %}

                {% if field.type == "text" %}
                    {% if field.prefix is not empty or field.suffix is not empty %}
                        <div class="tn-input-wrap">
                            {% if field.prefix is not empty %}<span class="tn-input__prefix">{{ field.prefix }}</span>{% endif %}
                            <input type="text" class="tn-input" name="{{ field.name }}" value="{{ field.default_value }}"
                                {% if field.required==1 %}required="required"{% endif %}
                                {% if field.readonly==1 %}readonly="readonly"{% endif %}
                            />
                            {% if field.suffix is not empty %}<span class="tn-input__suffix">{{ field.suffix }}</span>{% endif %}
                        </div>
                    {% else %}
                        <input type="text" class="tn-input" name="{{ field.name }}" value="{{ field.default_value }}"
                            {% if field.required==1 %}required="required"{% endif %}
                            {% if field.readonly==1 %}readonly="readonly"{% endif %}
                        />
                    {% endif %}

                {% elseif field.type == "url" %}
                    <input type="url" class="tn-input" name="{{ field.name }}" value="{{ field.default_value }}"
                        {% if field.required==1 %}required="required"{% endif %}
                        {% if field.readonly==1 %}readonly="readonly"{% endif %}
                        placeholder="https://example.com"
                    />

                {% elseif field.type == "select" %}
                    <div class="tn-select-wrap">
                        <select class="tn-select" name="{{ field.name }}" required="required">
                            {% for k,v in field.options %}
                                <option value="{{v}}" {% if v == field.default_value %}selected="selected"{% endif %}>{{ k }}</option>
                            {% endfor %}
                        </select>
                        <span class="tn-select-caret"><svg class="icon"><use href="#chevron-down" /></svg></span>
                    </div>

                {% elseif field.type == "checkbox" %}
                    <div class="d-flex flex-column gap-2">
                        {% for k,v in field.options %}
                            <label class="tn-checkbox-wrap">
                                <input class="tn-checkbox-input" type="checkbox" name="{{ field.name }}[]" value="{{ v }}"
                                    {% if field.readonly==1 %}readonly="readonly"{% endif %}
                                    {% if v in field.default_value %}checked="checked"{% endif %}
                                />
                                <span class="tn-checkbox-box"></span>
                                <span>{{k}}</span>
                            </label>
                        {% endfor %}
                    </div>

                {% elseif field.type == "radio" %}
                    <div class="d-flex flex-column gap-2">
                        {% for k,v in field.options %}
                            <label class="tn-checkbox-wrap">
                                <input type="radio" name="{{ field.name }}" value="{{ v }}"
                                    {% if field.default_value == v %}checked{% endif %}
                                    {% if field.required==1 %}required="required"{% endif %}
                                    {% if field.readonly==1 %}readonly="readonly"{% endif %}
                                />
                                <span>{{k}}</span>
                            </label>
                        {% endfor %}
                    </div>

                {% elseif field.type == "textarea" %}
                    {% set textarea_width = field.options.width|default(null) %}
                    {% set textarea_height = field.options.height|default(null) %}
                    <textarea class="tn-input" style="height:auto; padding-top:10px; padding-bottom:10px;" id="{{ field.name }}" name="{{ field.name }}"
                        {% if textarea_width or textarea_height %}
                            style="{% if textarea_width %}width: min(100%, {{ textarea_width }}px);{% endif %}{% if textarea_height %}height: {{ textarea_height }}px; min-height: {{ textarea_height }}px;{% endif %}"
                        {% endif %}
                        {% if field.required==1 %}required="required"{% endif %}
                        {% if field.readonly==1 %}readonly="readonly"{% endif %}
                    >{{field.default_value}}</textarea>
                {% endif %}

                {% if form.style.type == 'horizontal' %}
                        </div>
                    </div>
                {% endif %}
            {% endfor %}
        </fieldset>
        <input type="hidden" name="form_id" value="{{ form.id }}" />
        <input type="hidden" name="id" value="{{ product.id }}" />
    </div>
{% endif %}
