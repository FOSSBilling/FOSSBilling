{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}
{% set active_menu = 'emails' %}

{% block meta_title %}{{ 'Emails'|trans }}{% endblock %}
{% block breadcrumb %}
    <li class="active breadcrumb-item" aria-current="page">{{ 'Emails'|trans }}</li>{% endblock %}

{% set emails = client.email_get_list({"per_page":10, "page":request.page}) %}

{% block body_class %}email-index{% endblock %}
{% block content %}
    <div class="mb-4">
        <h1 class="mb-1">{{ 'Emails'|trans }}</h1>
        <span class="text-muted">{{ "Every email we've sent you, in one place."|trans }}</span>
    </div>

    <div class="tn-card tn-card--compact">
        {% if emails.list is empty %}
            <p class="text-muted mb-0">{{ 'There are no emails to display'|trans }}</p>
        {% else %}
            <div class="tn-mail">
                <div class="tn-mail__list" id="list-tab" role="tablist">
                    {% for i, email in emails.list %}
                        <a class="tn-mail__item{% if loop.first %} active{% endif %}"
                           href="#mail-{{ loop.index }}" data-bs-toggle="list" role="tab">
                            <span class="tn-mail__item-subject">{{ email.subject|truncate }}</span>
                            <span class="tn-mail__item-date">{{ email.created_at|format_datetime }}</span>
                        </a>
                    {% endfor %}
                </div>

                <div class="tn-mail__body tab-content">
                    {% for i, email in emails.list %}
                        <div class="tab-pane fade{% if loop.first %} show active{% endif %}"
                             id="mail-{{ loop.index }}" role="tabpanel">
                            <div class="tn-mail__head">
                                <h2 class="tn-mail__subject">{{ email.subject }}</h2>
                                <div class="tn-mail__meta">
                                    <span><span class="text-muted">{{ 'From'|trans }}</span> {{ email.sender }}</span>
                                    <span><span class="text-muted">{{ 'To'|trans }}</span> {{ email.recipients }}</span>
                                </div>
                                <div class="tn-mail__actions">
                                    <a class="tn-iconbtn tn-iconbtn--outline tn-iconbtn--sm" href='{{ "email/#{email.id}"|url }}' data-bs-toggle="tooltip" data-bs-title="{{ 'View'|trans }}">
                                        <svg class="icon"><use href="#eye" /></svg>
                                    </a>
                                    <a class="tn-iconbtn tn-iconbtn--outline tn-iconbtn--sm email-resend" href="#" data-id="{{ email.id }}" data-bs-toggle="tooltip" data-bs-title="{{ 'Resend'|trans }}">
                                        <svg class="icon"><use href="#arrows-exchange" /></svg>
                                    </a>
                                    <a class="tn-iconbtn tn-iconbtn--outline tn-iconbtn--sm" data-bs-toggle="tooltip" data-bs-title="{{ 'Delete'|trans }}"
                                       {{ fb_api_link({href: 'email/delete'|api_url(query: {id: email.id}), modal: {type: 'confirm', title: 'Are you sure?'|trans}, redirect: 'email'|url}) }}>
                                        <svg class="icon"><use href="#trash" /></svg>
                                    </a>
                                </div>
                            </div>
                            {# Workaround: email styling can effect the style of this page, so instead we use JS to insert the email contents into an iframe. A default height is set in case of errors #}
                            <iframe class="tn-mail__frame" id="email-content-{{ i }}" src="about:blank" sandbox="allow-same-origin allow-popups" style="height: 30em"></iframe>
                            <script>
                                (function () {
                                    const frame = document.getElementById("email-content-{{ i }}");
                                    frame.srcdoc = '{{ email.content_html|e('js') }}';
                                })();
                            </script>
                        </div>
                    {% endfor %}
                </div>
            </div>
            {% if emails.pages >= 2 %}
                <div class="mt-3 pt-3" style="border-top: var(--bw-hair) solid var(--border);">
                    {{ include('partial_pagination.html.twig', { 'list': emails, 'url': 'email' }) }}
                </div>
            {% endif %}
        {% endif %}
    </div>
{% endblock %}

{% block js %}
    {% autoescape "js" %}
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                const resendEmailBtn = document.querySelectorAll('.email-resend');

                resendEmailBtn.forEach((resendBtn) => {
                    resendBtn.addEventListener('click', (e) => {
                        e.preventDefault();
                        toggleLoader();
                        FOSSBilling.api.client.post('email/resend', { id: resendBtn.dataset.id },
                            () => {
                                flashMessage({
                                    message: 'Email resent',
                                    reload: '{{ 'email'|url }}'
                                });
                            },
                            (res) => {
                                FOSSBilling.message(`${res.message} (${res.code})`, 'error');
                                toggleLoader();
                            }
                        )
                    });
                });

                const toggleLoader = () => {
                    let loader = document.querySelector('.wait');
                    if (loader.style.display === 'none') {
                        loader.style.display = 'block';
                    } else {
                        loader.style.display = 'none';
                    }
                }

                {# Resizing the email iframes proved to be temperamental. The below code does it automatically using events. We can't do it all at once as the hidden tabs end up with a height of 0 #}
                function setEmailHeights(){
                    const emails = document.querySelectorAll('.tn-mail__frame');
                    emails.forEach(email => {
                        var body = email.contentDocument.body;
                        var html = email.contentDocument.documentElement;
                        if(body){
                            var height = Math.max(body.scrollHeight, body.offsetHeight);
                        } else if (html) {
                            var height = Math.max(html.clientHeight, html.scrollHeight, html.offsetHeight);
                        } else {
                            return;
                        }
                        email.height = height;
                    });
                };

                window.addEventListener("DOMContentLoaded", setEmailHeights());

                var tabElms = document.querySelectorAll('a[data-bs-toggle="list"]');

                tabElms.forEach(element => {
                    element.addEventListener('shown.bs.tab', function() {
                        setEmailHeights()
                    });
                });
            });
        </script>
    {% endautoescape %}
{% endblock %}
