{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}

{% import 'macro_functions.html.twig' as mf %}

{% block meta_title %}{{ 'Update FOSSBilling'|trans }}{% endblock %}

{% block content %}
    {% set update_info = admin.system_update_info %}
    <div class="card">
        <div class="card-header">
            <div>
                <h3 class="card-title">{{ 'Update FOSSBilling'|trans }}</h3>
                <p class="card-subtitle">{{ 'Review release notes, check for updates, and apply available platform updates.'|trans }}</p>
            </div>
        </div>
        <div class="card-body">
            {% if admin.system_update_available or update_info['branch'] == 'preview' %}
                {% if update_info['branch'] == 'preview' %}
                    <h4 class="mb-2">{{ 'Update Release Notes'|trans }}</h4>
                    <p class="text-secondary mb-3">{{ 'Preview branch updates track the latest development changes. Review them carefully before updating a production instance.'|trans }}</p>
                {% else %}
                    <h4 class="mb-0">{{ 'Update Release Notes'|trans }} ({{ FOSSBillingVersion }} => {{ update_info['version'] }})</h4>
                    <p class="text-secondary mb-3">{{ 'Required PHP version:'|trans }} {{ update_info['minimum_php_version'] }}</p>
                {% endif %}
                {% if update_info['update_type'] == 2 %}
                    <div class="alert alert-danger" role="alert">
                        <strong class="me-1">{{ 'Important:'|trans }}</strong>{{ 'This update is considered to be a major update, you should check the release notes for any breaking changes.'|trans }}
                    </div>
                {% endif %}
                {% if update_info['update_type'] == 1 %}
                    <div class="alert alert-warning" role="alert">
                        <strong class="me-1">{{ 'Warning:'|trans }}</strong>{{ 'This update is considered to be a minor update, there are low chances of incompatibilities.'|trans }}
                    </div>
                {% endif %}
                {{ (update_info['release_notes'] ?? '')|markdown_to_html }}
            {% else %}
                <h2 class="card-title">{{ 'There Is No Update Available'|trans }}</h2>
                <p>{{ 'You appear to be running the latest version of FOSSBilling, so no action is needed at the moment. If you think this is a mistake, you may use the button below to check again.'|trans }}</p>
            {% endif %}
        </div>
        <div class="card-footer">
            <div class="d-flex flex-wrap gap-2">
                {% if admin.system_update_available or update_info['branch'] == 'preview' %}
                    <a class="btn btn-primary" href="{{ 'system/update_core'|api_url }}"
                        {{ fb_api_link({ message: 'Are you sure?'|trans, modal: {type: 'confirm', title: 'Are you sure?'|trans}, reload: true }) }}>
                        <svg class="icon">
                            <use xlink:href="#download" />
                        </svg>
                        {{ 'Update FOSSBilling'|trans }}
                    </a>
                {% else %}
                    <a class="btn btn-secondary disabled" aria-disabled="true">
                        <svg class="icon">
                            <use xlink:href="#download" />
                        </svg>
                        {{ 'Update FOSSBilling'|trans }}
                    </a>
                {% endif %}
                <a class="btn btn-outline-secondary" href="{{ 'system/recheck_update'|api_url }}" {{ fb_api_link({ reload: true }) }}>
                    <svg class="icon">
                        <use xlink:href="#refresh" />
                    </svg>
                    {{ 'Check for Updates'|trans }}
                </a>
                <a class="btn btn-outline-secondary" href="{{ 'system/manual_update'|api_url }}"
                    {{ fb_api_link({ message: 'Patches Applied and Configuration Updated'|trans, modal: {type: 'confirm', title: 'Are you sure?'|trans} }) }}>
                    <svg class="icon">
                        <use xlink:href="#cog-play" />
                    </svg>
                    {{ 'Apply Patches & Update Configuration'|trans }}
                </a>
            </div>
            <div class="alert alert-info mt-3 mb-0" role="alert">
                {{ "Applying patches and updating the configuration should happen automatically. Use the manual action only if you are troubleshooting update issues."|trans }}
            </div>
            <div class="d-flex flex-wrap gap-4 mt-3 text-secondary small">
                <div>{{ 'Last update check:'|trans }} {{ update_info['last_check']|format_datetime() }}.</div>
                <div>{{ 'Next update check:'|trans }} {{ update_info['next_check']|format_datetime() }}.</div>
            </div>
        </div>
    </div>
{% endblock %}
