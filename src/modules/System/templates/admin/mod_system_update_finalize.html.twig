{% extends 'layout_login.html.twig' %}

{% block meta_title %}{{ 'Finalize Update'|trans }}{% endblock %}

{% block content %}
    {% set finalization = admin.system_update_finalization_status %}
    {% set state = finalization.state|default({}) %}
    {% set status = finalization.status|default('not_required') %}
    {% set finalized = status == 'finalized' %}
    {% set updateType = state.update_type is defined and state.update_type is not same as(null) ? state.update_type + 0 : null %}

    <div class="page page-center">
        <div class="container-tight py-4">
            <div class="text-center mb-4">
                <div class="h1 mb-1">{{ 'Hello'|trans }}</div>
                <p class="text-secondary mb-0">{{ 'Welcome to FOSSBilling %version%.'|trans({'%version%': FOSSBillingVersion}) }}</p>
            </div>

            <div class="card card-md">
                <div class="card-body">
                    {% if not finalization.required %}
                        <div class="empty">
                            <div class="empty-icon text-success">
                                <svg class="icon icon-lg">
                                    <use xlink:href="#check" />
                                </svg>
                            </div>
                            <p class="empty-title">{{ 'Update Finalization Complete'|trans }}</p>
                            <p class="empty-subtitle text-secondary">{{ 'This FOSSBilling installation has already been finalized for the current version.'|trans }}</p>
                            <div class="empty-action">
                                <a class="btn btn-primary" href="{{ ''|url }}">{{ 'Go to Dashboard'|trans }}</a>
                            </div>
                        </div>
                    {% else %}
                        <div class="d-flex align-items-start gap-3 mb-3">
                            <span class="avatar avatar-md bg-primary text-primary-fg">
                                <svg class="icon">
                                    <use xlink:href="#info" />
                                </svg>
                            </span>
                            <div>
                                <h2 class="card-title mb-1">{{ finalized ? 'Review Your Updated Installation'|trans : 'Finalize Your Update'|trans }}</h2>
                                <p class="text-secondary mb-0">{{ finalized ? 'Review important settings, then finish finalization to reopen the installation.'|trans : 'FOSSBilling needs to apply update patches with the newly installed code before normal admin usage resumes.'|trans }}</p>
                            </div>
                        </div>

                        <div class="datagrid mb-3">
                            <div class="datagrid-item">
                                <div class="datagrid-title">{{ 'From Version'|trans }}</div>
                                <div class="datagrid-content">{{ state.from_version|default('Unknown'|trans) }}</div>
                            </div>
                            <div class="datagrid-item">
                                <div class="datagrid-title">{{ 'Current Version'|trans }}</div>
                                <div class="datagrid-content">{{ state.target_version|default(FOSSBillingVersion) }}</div>
                            </div>
                            <div class="datagrid-item">
                                <div class="datagrid-title">{{ 'Update Branch'|trans }}</div>
                                <div class="datagrid-content">{{ state.branch|default('release') }}</div>
                            </div>
                            <div class="datagrid-item">
                                <div class="datagrid-title">{{ 'Pending Patches'|trans }}</div>
                                <div class="datagrid-content">{{ finalization.pending_patches is same as(null) ? 'Unknown'|trans : finalization.pending_patches }}</div>
                            </div>
                        </div>

                        <div class="alert alert-warning" role="alert">
                            <strong class="me-1">{{ 'Maintenance mode is active.'|trans }}</strong>{{ 'Public traffic remains paused until finalization is finished.'|trans }}
                        </div>

                        {% if not finalized %}
                            <p>{{ 'Finalization applies database and configuration patches, clears runtime caches, and removes installer files if they are present.'|trans }}</p>
                            <div class="d-grid">
                                <a class="btn btn-primary" href="{{ 'system/finalize_update'|api_url }}"
                                    {{ fb_api_link({
                                        reload: true,
                                        timeoutMs: 180000,
                                        timeoutMessage: 'Finalization took longer than expected. The server may still be applying patches. Wait a minute before refreshing or trying again.'|trans,
                                        preventNavigation: true,
                                        loading: {
                                            target: '#finalization-progress',
                                            button: 'Finalizing update...'|trans,
                                            message: 'FOSSBilling is applying update patches. Keep this tab open until the request completes.'|trans
                                        }
                                    }) }}>
                                    <svg class="icon">
                                        <use xlink:href="#cog-play" />
                                    </svg>
                                    {{ 'Run Finalization'|trans }}
                                </a>
                            </div>
                            <div id="finalization-progress"></div>
                        {% else %}
                            {% if updateType == 2 %}
                                <div class="alert alert-info" role="alert">
                                    <strong class="me-1">{{ 'Major update:'|trans }}</strong>{{ 'Review the settings below before reopening the installation.'|trans }}
                                </div>
                            {% endif %}

                            <p class="text-secondary">{{ 'After finishing, revisit these areas if this update introduced changes that affect your installation.'|trans }}</p>
                            <div class="list-group list-group-flush mb-3">
                                <div class="list-group-item">
                                    <div class="row align-items-center">
                                        <div class="col">{{ 'Security and rate limiting settings'|trans }}</div>
                                        <div class="col-auto text-secondary">{{ 'Recommended'|trans }}</div>
                                    </div>
                                </div>
                                <div class="list-group-item">
                                    <div class="row align-items-center">
                                        <div class="col">{{ 'Error reporting and system settings'|trans }}</div>
                                        <div class="col-auto text-secondary">{{ 'Optional'|trans }}</div>
                                    </div>
                                </div>
                                <div class="list-group-item">
                                    <div class="row align-items-center">
                                        <div class="col">{{ 'Localization and company settings'|trans }}</div>
                                        <div class="col-auto text-secondary">{{ 'Optional'|trans }}</div>
                                    </div>
                                </div>
                            </div>

                            <div class="d-grid">
                                <a class="btn btn-success" href="{{ 'system/complete_update_finalization'|api_url }}"
                                    {{ fb_api_link({
                                        redirect: ''|url,
                                        timeoutMs: 60000,
                                        loading: {
                                            button: 'Finishing...'|trans,
                                            message: 'Restoring maintenance mode settings and reopening the installation.'|trans
                                        }
                                    }) }}>
                                    <svg class="icon">
                                        <use xlink:href="#check" />
                                    </svg>
                                    {{ 'Finish Finalization'|trans }}
                                </a>
                            </div>
                        {% endif %}
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
