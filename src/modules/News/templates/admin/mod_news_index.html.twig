{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}

{% import 'macro_functions.html.twig' as mf %}

{% set active_menu = 'support' %}
{% set has_filter_panel = true %}
{% set filter_panel_id = 'page-search-filters' %}
{% set filter_panel_open = request_has_filters %}

{% block meta_title %}{{ 'News'|trans }}{% endblock %}

{% block content %}
    <div class="card">
        <div class="card-header">
            <div>
                <h3 class="card-title">{{ 'News & Announcements'|trans }}</h3>
                <p class="card-subtitle">{{ 'Manage published announcements and draft new updates for the client area.'|trans }}</p>
            </div>
        </div>
        <div class="card-body pt-3 pb-0 px-0">
            <div class="card border-0 shadow-none rounded-0">
                <div class="card-header bg-transparent px-3 pt-0 pb-3 border-0">
                    <ul class="nav nav-pills card-header-pills">
                        <li class="nav-item">
                            <a class="nav-link active" href="#tab-index" data-bs-toggle="tab" role="tab">{{ 'News & Announcements'|trans }}</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#tab-new" data-bs-toggle="tab" role="tab">
                                <svg class="icon me-2">
                                    <use xlink:href="#plus" />
                                </svg>
                                {{ 'New Announcement'|trans }}
                            </a>
                        </li>
                    </ul>
                </div>
                <div class="tab-content border-top">
                    <div class="tab-pane fade show active" id="tab-index" role="tabpanel">
            {{ include('partial_search.html.twig', {
                search_body_class: filter_panel_open ? 'pb-2 border-bottom-0' : ''
            }) }}
            <section id="{{ filter_panel_id }}" class="card-body pt-0 px-3 pb-3 border-bottom collapse{% if filter_panel_open %} show{% endif %}">
                <form method="get" class="border border-top-0 rounded-top-0 rounded-bottom-3 bg-body-tertiary p-3">
                    {% if request.search %}
                        <input type="hidden" name="search" value="{{ request.search }}">
                    {% endif %}
                    <div class="row g-3">
                        <div class="col-md-6 col-xl-3">
                            <div>
                                <label class="form-label text-muted small mb-1" for="news-id">{{ 'ID'|trans }}</label>
                                <input class="form-control" type="text" id="news-id" name="id" value="{{ request.id }}" placeholder="{{ 'Post ID'|trans }}">
                            </div>
                        </div>
                        <div class="col-md-6 col-xl-3">
                            <div>
                                <label class="form-label text-muted small mb-1" for="news-status">{{ 'Status'|trans }}</label>
                                <select class="form-select" id="news-status" name="status">
                                    <option value="">{{ 'All Posts'|trans }}</option>
                                    <option value="draft"{% if request.status == 'draft' %} selected{% endif %}>{{ 'Draft'|trans }}</option>
                                    <option value="active"{% if request.status == 'active' %} selected{% endif %}>{{ 'Active'|trans }}</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-12 col-xl-6">
                            <div>
                                <label class="form-label text-muted small mb-1" for="news-section">{{ 'Section'|trans }}</label>
                                <input class="form-control" type="text" id="news-section" name="section" value="{{ request.section }}" placeholder="{{ 'Section Name'|trans }}">
                            </div>
                        </div>
                    </div>
                    <div class="d-flex justify-content-end gap-2 mt-3">
                        <a class="btn btn-outline-secondary" href="{{ request_path|url }}">{{ 'Reset'|trans }}</a>
                        <button class="btn btn-primary" type="submit">
                            <svg class="icon">
                                <use xlink:href="#filter" />
                            </svg>
                            {{ 'Apply Filters'|trans }}
                        </button>
                    </div>
                </form>
            </section>
            <div class="table-responsive">
                <table class="table card-table table-vcenter table-striped text-nowrap sortable">
                <thead>
                    <tr>
                        <th class="w-1 no-sort">
                            <input type="checkbox" class="form-check-input m-0 align-middle batch-delete-master-checkbox">
                        </th>
                        <th class="w-1">#</th>
                        <th>{{ 'Title'|trans }}</th>
                        <th>{{ 'Active'|trans }}</th>
                        <th>{{ 'Date'|trans }}</th>
                        <th class="w-1 no-sort"></th>
                    </tr>
                </thead>
                <tbody>
                    {% set posts = admin.news_get_list({ 'per_page': 25, 'page': request.page }|merge(request)) %}
                    {% for i, post in posts.list %}
                    <tr>
                        <td>
                            <input type="checkbox" class="form-check-input m-0 align-middle batch-delete-checkbox" data-item-id="{{ post.id }}">
                        </td>
                        <td>{{ post.id }}</td>
                        <td>
                            <a href='{{ "news/post/#{post.id}"|url }}'>{{ post.title }}</a>
                        </td>
                        <td>
                            {% if post.status == 'active' %}
                                <span class="badge bg-success me-1"></span>
                            {% endif %}
                            {% if post.status == 'draft' %}
                                <span class="badge bg-secondary me-1"></span>
                            {% endif %}
                            {{ mf.status_name(post.status) }}
                        </td>
                        <td>{{ post.created_at|format_datetime }}</td>
                        <td>
                            <a class="btn btn-icon" href='{{ "news/post/#{post.id}"|url }}'>
                                <svg class="icon">
                                    <use xlink:href="#edit" />
                                </svg>
                            </a>
                            <a class="btn btn-icon" href="{{ 'news/delete'|api_url(query: { 'id': post.id }) }}"
                                {{ fb_api_link({modal: {type: 'confirm', title: 'Are you sure?'|trans}, redirect: 'news'|url}) }}>
                                <svg class="icon">
                                    <use xlink:href="#delete" />
                                </svg>
                            </a>
                        </td>
                    </tr>
                    {% else %}
                    <tr>
                        <td class="text-muted" colspan="5">{{ 'The list is empty'|trans }}</td>
                    </tr>
                    {% endfor %}
                </tbody>
                </table>
            </div>

            <div class="card-footer d-flex align-items-center justify-content-between">
                {% include 'partial_batch_delete.html.twig' with { 'action': 'news/batch_delete' } %}
                {% include 'partial_pagination.html.twig' with { 'list': posts, 'url': 'news/index' } %}
            </div>
        </div>

        <div class="tab-pane fade" id="tab-new" role="tabpanel">
            <div class="p-3">
                <form method="post" action="{{ 'news/create'|api_url }}" {{ fb_api_form({redirect: 'news'|url}) }}>
                    <div class="mb-3 row">
                        <label class="form-label col-3 col-form-label">{{ 'Title'|trans }}:</label>
                        <div class="col">
                            <input class="form-control" type="text" name="title" value="{{ request.title }}" required>
                        </div>
                    </div>
                    <div class="mb-3 row">
                        <label class="form-label col-3 col-form-label">{{ 'Status'|trans }}:</label>
                        <div class="col">
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" id="radioStatusDraft" type="radio" name="status" value="draft"checked>
                                <label class="form-check-label" for="radioStatusDraft">{{ 'Draft'|trans }}</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" id="radioStatusActive" type="radio" name="status" value="active">
                                <label class="form-check-label" for="radioStatusActive">{{ 'Active'|trans }}</label>
                            </div>
                        </div>
                    </div>
                    <div class="mb-3 row">
                        <label class="form-label col-3 col-form-label">{{ 'Content'|trans }}</label>
                        <div class="col">
                            <textarea class="editor-textarea" name="content" rows="10">{{ request.content }}</textarea>
                            <small class="mt-2 form-hint">{{ 'If the text is very long you can use <strong>&lt;!--more--&gt;</strong> tag. Inserting this tag within the post will create and excerpt of text (before the tag) to be displayed in posts list. Users will be able to see whole content when they click on "Read more" button.'|trans|raw }}</small>
                        </div>
                    </div>

                    <input type="submit" value="{{ 'Create'|trans }}" class="btn btn-primary w-100">
                </form>
            </div>
        </div>
                </div>
            </div>
        </div>
    </div>
{% endblock %}

{% block head %}{{ mf.wysiwyg('.editor-textarea') }}{% endblock %}
