<style type="text/css">
    :root {
        color-scheme: light;
        --embed-bg: #ffffff;
        --embed-border: #d9e0e8;
        --embed-border-strong: #c4cfdb;
        --embed-text: #182433;
        --embed-muted: #5f6b7a;
        --embed-primary: #206bc4;
        --embed-primary-hover: #18539a;
        --embed-focus: rgba(32, 107, 196, 0.2);
        --embed-radius: 12px;
        --embed-shadow: 0 1px 2px rgba(24, 36, 51, 0.08);
        --embed-font: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    }

    * {
        box-sizing: border-box;
    }

    html,
    body {
        margin: 0;
        padding: 0;
        background: transparent;
        color: var(--embed-text);
        font: 14px/1.4 var(--embed-font);
    }

    body {
        min-height: 100vh;
    }

    .embed-shell {
        width: 100%;
        padding: 12px;
        border: 1px solid var(--embed-border);
        border-radius: var(--embed-radius);
        background: var(--embed-bg);
        box-shadow: var(--embed-shadow);
    }

    .embed-title {
        margin: 0 0 10px;
        font-size: 14px;
        font-weight: 600;
        line-height: 1.3;
    }

    .embed-stack {
        display: grid;
        gap: 10px;
    }

    .embed-field {
        display: grid;
        gap: 6px;
    }

    .embed-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px;
    }

    .embed-label {
        display: block;
        margin: 0;
        font-size: 12px;
        font-weight: 600;
        line-height: 1.3;
        color: var(--embed-muted);
    }

    .embed-input,
    .embed-select,
    .embed-textarea,
    .embed-button {
        width: 100%;
        min-height: 36px;
        padding: 8px 10px;
        border: 1px solid var(--embed-border-strong);
        border-radius: 10px;
        background: #ffffff;
        color: var(--embed-text);
        font: inherit;
        transition: border-color 0.15s ease, box-shadow 0.15s ease, background-color 0.15s ease;
    }

    .embed-textarea {
        min-height: 96px;
        resize: vertical;
    }

    .embed-input:focus,
    .embed-select:focus,
    .embed-textarea:focus {
        outline: none;
        border-color: var(--embed-primary);
        box-shadow: 0 0 0 3px var(--embed-focus);
    }

    .embed-button {
        border-color: var(--embed-primary);
        background: var(--embed-primary);
        color: #ffffff;
        font-weight: 600;
        cursor: pointer;
    }

    .embed-button:hover {
        background: var(--embed-primary-hover);
        border-color: var(--embed-primary-hover);
    }

    .embed-button:focus {
        outline: none;
        box-shadow: 0 0 0 3px var(--embed-focus);
    }

    .embed-sr-only {
        position: absolute;
        width: 1px;
        height: 1px;
        padding: 0;
        margin: -1px;
        overflow: hidden;
        clip: rect(0, 0, 0, 0);
        white-space: nowrap;
        border: 0;
    }

    .embed-inline-form {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 96px auto;
        gap: 8px;
        align-items: center;
    }

    .embed-inline-form .embed-button {
        width: auto;
        padding-right: 14px;
        padding-left: 14px;
        white-space: nowrap;
    }

    .embed-inline-form .embed-select {
        min-width: 0;
    }

    .embed-note {
        font-size: 12px;
        color: var(--embed-muted);
    }

    @media (max-width: 420px) {
        .embed-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
