{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}
{% set active_menu = 'payments' %}

{% block meta_title %}{{ 'Wallet'|trans }}{% endblock %}
{% block breadcrumb %} <li class="breadcrumb-item active" aria-current="page">{{ 'Wallet'|trans }}</li>{% endblock %}

{% set profile = client.profile_get %}

{% block body_class %}client-balance{% endblock %}
{% block content %}
    <div class="mb-4">
        <h1 class="mb-1">{{ 'Account'|trans }}</h1>
        <span class="text-muted">{{ 'Profile, company details and security.'|trans }}</span>
    </div>

    <div class="tn-tabs mb-4">
        <div class="tn-tabs__nav">
            <a class="tn-tabs__tab" href="{{ 'client/profile'|url }}">
                <svg class="icon" width="16" height="16"><use href="#user" /></svg>
                {{ 'Profile'|trans }}
            </a>
            <a class="tn-tabs__tab tn-tabs__tab--active" href="{{ 'client/balance'|url }}">
                <svg class="icon" width="16" height="16"><use href="#wallet" /></svg>
                {{ 'Balance'|trans }}
            </a>
        </div>
    </div>

    <div class="d-flex flex-column flex-lg-row gap-4 align-items-start">
        <div class="flex-fill" style="min-width:0;">
            <div class="tn-card tn-card--compact">
                <div class="tn-card__header">
                    <div class="tn-card__title">{{ 'History'|trans }}</div>
                </div>
                {# FOSSBilling's API dispatch convention is <module>_<method> — this
                   resolves to the Client module's balance_get_list(), not a
                   nonexistent "Balance" module. Do not "simplify" this to
                   balance_get_list(), that breaks module resolution entirely. #}
                {% set transactions = client.client_balance_get_list({ "per_page": 10, "page": request.page }) %}
                {% for i, tx in transactions.list %}
                    {% set tx_amount = tx.amount ?? 0 %}
                    <div class="tn-kv-row tn-row-hover">
                        <div class="fs-8 text-muted" style="font-family: var(--font-mono); flex: none; width: 90px;">
                            {{ tx.created_at|format_date }}
                        </div>
                        <div class="tn-kv-row__key" style="flex: 1;">
                            {{ tx.description }}
                        </div>
                        <div class="tn-kv-row__value {{ tx_amount > 0 ? 'text-success' : '' }}" style="font-family: var(--font-mono);">
                            {{ tx_amount > 0 ? '+' : '' }}{{ tx_amount|format_currency(tx.currency ?? default_currency) }}
                        </div>
                    </div>
                {% else %}
                    <p class="text-muted mb-0">{{ 'The list is empty'|trans }}</p>
                {% endfor %}
                {{ include('partial_pagination.html.twig', { 'list': transactions, 'url': 'client/balance' }) }}
            </div>
        </div>

        <div style="width:320px; flex:none;" class="w-100 w-lg-auto">
            <div class="tn-card tn-card--compact">
                <div class="fs-9 text-muted mb-1" style="font-family: var(--font-mono); font-weight:600; letter-spacing: var(--ls-eyebrow); text-transform: uppercase;">
                    {{ 'Available balance'|trans }}
                </div>
                <div class="mb-2" style="font-family: var(--font-display); font-weight:700; font-size: 30px; letter-spacing: var(--ls-tight); color: var(--text);">
                    {{ profile.balance|format_currency(profile.currency ?? default_currency) }}
                </div>
                <p class="fs-7 text-muted mb-3">
                    {{ 'Applies automatically to eligible invoices when your order is placed, before any other payment method is charged.'|trans }}
                </p>

                <form method="post" action="{{ 'invoice/funds_invoice'|api_url }}" {{ fb_api_form({callback: 'onAfterInvoiceCreated'}) }}>
                    <div class="tn-field mb-2">
                        <label class="tn-field__label" for="appendedPrependedInput">{{ 'Top-up amount'|trans }}</label>
                        <input id="appendedPrependedInput" class="tn-input" type="text" name="amount" placeholder="0" required="required">
                    </div>
                    <div class="d-flex gap-2 mb-3">
                        <button type="button" class="tn-btn tn-btn--secondary tn-btn--sm flex-fill" onclick="document.getElementById('appendedPrependedInput').value=100">100</button>
                        <button type="button" class="tn-btn tn-btn--primary tn-btn--sm flex-fill" onclick="document.getElementById('appendedPrependedInput').value=250">250</button>
                        <button type="button" class="tn-btn tn-btn--secondary tn-btn--sm flex-fill" onclick="document.getElementById('appendedPrependedInput').value=500">500</button>
                    </div>
                    <button class="tn-btn tn-btn--primary tn-btn--block tn-btn--md" type="submit">
                        {{ 'Top up'|trans }} {{ profile.currency ?? default_currency }} 250
                    </button>
                </form>
            </div>
        </div>
    </div>
{% endblock %}

{% block js %}
<script>
    function onAfterInvoiceCreated(hash) {
        window.location = '{{ "invoice"|url }}/' + hash;
    }
</script>
{% endblock %}
