{% extends "layout_public.html.twig" %}

{% block meta_title %}{{ 'Set new password'|trans }}{% endblock %}

{% block body_class %}page-set-password{% endblock %}
{% block body %}
<div class="tn-auth tn-auth--solo">
    <div class="tn-auth__panel">
        <div class="tn-auth__panel-inner">
            {% if settings.login_page_show_logo %}
                {{ include('partial_company_logo.html.twig', {
                    company: company,
                    logo_url: public_logo_url,
                    dark_logo_url: public_dark_logo_url,
                    link_url: settings.login_page_logo_url|default('/'),
                    link_target: '_blank',
                    link_rel: 'noopener noreferrer',
                    image_height: '32px'
                }) }}
            {% endif %}

            {% if expired is defined and expired %}
                <div class="tn-auth__head">
                    <h1 class="tn-auth__title">{{ 'Link expired'|trans }}</h1>
                    <p class="tn-auth__sub">{{ 'This password reset link has expired or has already been used. Request a new one below.'|trans }}</p>
                </div>
                <div class="tn-auth__actions">
                    <a class="tn-btn tn-btn--primary tn-btn--lg tn-btn--block" href="{{ 'password-reset'|url }}">{{ 'Request a new link'|trans }}</a>
                </div>
                <p class="tn-auth__foot"><a href="{{ 'login'|url }}">{{ 'Back to sign in'|trans }}</a></p>
            {% else %}
                <div class="tn-auth__head">
                    <h1 class="tn-auth__title">{{ 'Set new password'|trans }}</h1>
                    <p class="tn-auth__sub">{{ 'Choose a new password for your account.'|trans }}</p>
                </div>
                <form method="post" action="{{ 'client/update_password'|api_url(role: 'guest') }}" class="tn-auth__form" {{ fb_api_form({redirect: 'login'|url}) }} autocomplete="off">
                    <input type="hidden" id="hash" name="hash" value="{{ hash }}"/>
                    <div class="tn-field">
                        <label class="tn-field__label" for="password">{{ 'New password'|trans }}</label>
                        <input class="tn-input" id="password" type="password" placeholder="••••••••••" name="password" required="required" autofocus>
                    </div>
                    <div class="tn-field">
                        <label class="tn-field__label" for="password2">{{ 'Repeat new password'|trans }}</label>
                        <input class="tn-input" id="password2" type="password" placeholder="••••••••••" name="password_confirm" required="required">
                    </div>
                    <button type="submit" class="tn-btn tn-btn--primary tn-btn--lg tn-btn--block">{{ 'Set new password'|trans }}</button>
                </form>
                <p class="tn-auth__foot"><a href="{{ 'login'|url }}">{{ 'Back to sign in'|trans }}</a></p>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}

{% block js %}
<script>
    // Set value of hash field to last part of URL.
    document.addEventListener('DOMContentLoaded', function() {
        const hashField = document.getElementById('hash');
        if (hashField) {
            hashField.value = window.location.href.split('/').pop();
        }
    });
</script>
{% endblock %}
