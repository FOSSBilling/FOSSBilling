{% extends "layout_public.html.twig" %}

{% block meta_title %}{{ 'Set New Password'|trans }}{% endblock %}

{% set company = guest.system_company %}

{% if settings.theme == 'dark' %}
    {% set logo_url =  company.logo_url_dark %}
{% else %}
    {% set logo_url =  company.logo_url %}
{% endif %}
{% set auth_hero_enabled = settings.auth_hero_enabled is not defined or settings.auth_hero_enabled == '1' %}
{% set auth_set_password_hero_title = settings.auth_set_password_hero_title is defined ? settings.auth_set_password_hero_title : 'Secure your account'|trans %}
{% set auth_set_password_hero_subtitle = settings.auth_set_password_hero_subtitle is defined ? settings.auth_set_password_hero_subtitle : 'Choose a new password before returning to the client area.'|trans %}
{% set auth_set_password_heading_title = settings.auth_set_password_heading_title is defined ? settings.auth_set_password_heading_title : 'Set new password'|trans %}
{% set auth_set_password_heading_subtitle = settings.auth_set_password_heading_subtitle is defined ? settings.auth_set_password_heading_subtitle : 'Use a strong password that you have not used with this account before.'|trans %}

{% block body_class %}page-set-password{% endblock %}
{% block body %}
<div class="auth-shell container">
    <div class="auth-panel{% if not auth_hero_enabled %} auth-panel-no-hero{% endif %} row g-0">
        {% if auth_hero_enabled %}
            <div class="auth-hero col-lg-5 d-none d-lg-flex">
                <div class="auth-hero-content">
                    {% if auth_set_password_hero_title %}<h1>{{ auth_set_password_hero_title }}</h1>{% endif %}
                    {% if auth_set_password_hero_subtitle %}<p>{{ auth_set_password_hero_subtitle }}</p>{% endif %}
                </div>
            </div>
        {% endif %}
        <div class="auth-form-column col-lg-{{ auth_hero_enabled ? '7' : '12' }}">
            <div class="auth-card card">
                <div class="card-body">
                    {% if settings.login_page_show_logo %}
                        <div class="auth-brand">
                            <a href="{{ settings.login_page_logo_url|default('/') }}" target="_blank" rel="noopener">
                                <img src="{{ logo_url }}" alt="{{ company.name }}"/>
                            </a>
                        </div>
                    {% endif %}

                    <div class="auth-heading">
                        {% if auth_set_password_heading_title %}<h1>{{ auth_set_password_heading_title }}</h1>{% endif %}
                        {% if auth_set_password_heading_subtitle %}<p>{{ auth_set_password_heading_subtitle }}</p>{% endif %}
                    </div>

                    <form method="post" action="{{ 'client/update_password'|api_url(role: 'guest') }}" class="auth" {{ fb_api_form({redirect: 'login'|url}) }} autocomplete="off">
                        <input type="hidden" id="hash" name="hash" value="{{ hash }}"/>
                        <div class="mb-3">
                            <label class="form-label" for="password">{{ 'New Password'|trans }}</label>
                            <input class="form-control" id="password" type="password" placeholder="{{ 'New Password'|trans }}" name="password" required="required" autocomplete="new-password" autofocus>
                        </div>
                        <div class="mb-4">
                            <label class="form-label" for="password2">{{ 'Repeat New Password'|trans }}</label>
                            <input class="form-control" id="password2" type="password" placeholder="{{ 'Repeat New Password'|trans }}" name="password_confirm" required="required" autocomplete="new-password">
                        </div>
                        <button type="submit" class="btn btn-primary w-100">{{ 'Set New Password'|trans }}</button>
                    </form>

                    <div class="auth-actions">
                        <a class="btn btn-outline-primary" href="{{ 'login'|url }}">{{ 'Back to Login'|trans }}</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block js %}
<script>
    // Set value of hash field to last part of URL.
    document.addEventListener('DOMContentLoaded', function() {
        const hash = window.location.href.split('/').pop();
        document.getElementById('hash').value = hash;
    });
</script>
{% endblock %}
