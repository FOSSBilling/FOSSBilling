{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}

{% import 'macro_functions.html.twig' as mf %}
{% set can_view_client_login_history = has_permission('client', 'view_login_history') %}

{% block meta_title %}{{ 'Clients Login History'|trans }}{% endblock %}

{% set active_menu = 'activity' %}
{% set has_filter_panel = true %}
{% set filter_panel_id = 'page-search-filters' %}
{% set filter_panel_open = request_has_filters %}

{% block content %}
<div class="card">
    <div class="card-header">
        <div>
            <h3 class="card-title">{{ 'Client Login History'|trans }}</h3>
            <p class="card-subtitle">{{ 'Review successful client logins, related IP addresses, and origin countries.'|trans }}</p>
        </div>
    </div>

    {% if can_view_client_login_history %}
    {{ include('partial_search.html.twig', {
        search_body_class: filter_panel_open ? 'pb-2 border-bottom-0' : ''
    }) }}
    <section id="{{ filter_panel_id }}" class="card-body pt-0 px-3 pb-3 border-bottom collapse{% if filter_panel_open %} show{% endif %}">
        <form method="get" class="border border-top-0 rounded-top-0 rounded-bottom-3 bg-body-tertiary p-3">
            {% if request.search %}
                <input type="hidden" name="search" value="{{ request.search }}">
            {% endif %}
            <div class="row g-3">
                <div class="col-md-6 col-xl-3">
                    <div>
                        <label class="form-label text-muted small mb-1" for="client-login-history-id">{{ 'Event ID'|trans }}</label>
                        <input class="form-control" type="text" id="client-login-history-id" name="id" value="{{ request.id }}" placeholder="{{ 'Login Event ID'|trans }}">
                    </div>
                </div>
                <div class="col-md-6 col-xl-5">
                    <div>
                        <label class="form-label text-muted small mb-1" for="client-login-history-client">{{ 'Client'|trans }}</label>
                        <select class="form-control autocomplete-selector"
                                placeholder="{{ 'Start Typing the Client Name or ID'|trans }}"
                                id="client-login-history-client"
                                name="client_id"
                                data-resturl="/api/admin/client/get_pairs">
                        {% if request.client_id %}
                            {% set client = admin.client_get({ 'id': request.client_id }) %}
                            <option value="{{ request.client_id }}" selected>{{ client.first_name }} {{ client.last_name }} ({{ client.email }})</option>
                        {% endif %}
                        </select>
                    </div>
                </div>
                <div class="col-md-6 col-xl-4">
                    <div>
                        <label class="form-label text-muted small mb-1" for="client-login-history-ip">{{ 'IP Address'|trans }}</label>
                        <input class="form-control" type="text" id="client-login-history-ip" name="ip" value="{{ request.ip }}" placeholder="{{ 'Filter by IP Address'|trans }}">
                    </div>
                </div>
                <div class="col-md-6 col-xl-4">
                    <div>
                        <label class="form-label text-muted small mb-1" for="client-login-history-date-range">{{ 'Date Range'|trans }}</label>
                        <div class="input-group">
                            <div class="input-icon w-100">
                                <input class="form-control datepicker"
                                       id="client-login-history-date-range"
                                       placeholder="{{ 'Select Date Range'|trans }}"
                                       value="{% if request.date_from %}{{ request.date_from|date('Y-m-d') }}{% endif %}{% if request.date_to %} to {{ request.date_to|date('Y-m-d') }}{% endif %}"
                                       data-name-from="date_from"
                                       data-name-to="date_to">
                                <span class="input-icon-addon">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
                                        <path d="M4 5m0 2a2 2 0 0 1 2 -2h12a2 2 0 0 1 2 2v12a2 2 0 0 1 -2 2h-12a2 2 0 0 1 -2 -2z"></path>
                                        <path d="M16 3l0 4"></path>
                                        <path d="M8 3l0 4"></path>
                                        <path d="M4 11l16 0"></path>
                                        <path d="M11 15l1 0"></path>
                                        <path d="M12 15l0 3"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="d-flex justify-content-end gap-2 mt-3">
                <a class="btn btn-outline-secondary" href="{{ request_path|url }}">{{ 'Reset'|trans }}</a>
                <button class="btn btn-primary" type="submit">
                    <svg class="icon">
                        <use xlink:href="#filter" />
                    </svg>
                    {{ 'Apply Filters'|trans }}
                </button>
            </div>
        </form>
    </section>
    <div class="table-responsive">
        <table class="table card-table table-vcenter table-striped text-nowrap">
            <thead>
                <tr>
                    <th>{{ '#'|trans }}</th>
                    <th class="w-1 no-sort"></th>
                    <th>{{ 'User'|trans }}</th>
                    <th>{{ 'IP'|trans }}</th>
                    <th>{{ 'Country'|trans }}</th>
                    <th>{{ 'Date'|trans }}</th>
                </tr>
            </thead>

            <tbody>
            {% set history = admin.client_login_history_get_list({ 'per_page': 25, 'page': request.page }|merge(request)) %}
            {% for i, event in history.list %}
            <tr>
                <td>{{ event.id }}</td>
                <td>
                    <a href='{{ "client/manage/#{event.client.id}"|url }}'>
                        {{ mf.avatar(event.client.email, 24, 'db-avatar avatar avatar-xs d-none d-md-inline-block') }}
                    </a>
                </td>
                <td>
                    <a href='{{ "client/manage/#{event.client.id}"|url }}'>{{ event.client.first_name }} {{ event.client.last_name }}</a>
                </td>
                <td>
                    {{ mf.ip_lookup_link(event.ip) }}
                    {% if event.ip %}
                    <a href="{{ 'antispam/block_ip'|api_url(query: { 'ip': event.ip }) }}" {{ fb_api_link({ modal: {type: 'confirm', title: 'Block IP'|trans, content: ('Are you sure you want to block IP address %ip%?'|trans({'%ip%': event.ip}))}, reload: true }) }} title="{{ 'Block IP'|trans }}">
                        <svg class="icon icon-xs text-danger" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="12" r="10"></circle>
                            <line x1="4.93" y1="4.93" x2="19.07" y2="19.07"></line>
                        </svg>
                    </a>
                    {% endif %}
                </td>
                <td>{{ event.ip|ip_country_name|default('Unknown'|trans) }}</td>
                <td>{{ event.created_at|format_datetime }}</td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6">{{ 'The list is empty'|trans }}</td>
            </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

    <div class="card-footer d-flex align-items-center">
        {{ include('partial_pagination.html.twig', { 'list': history, 'url': 'client/logins', 'split_footer_controls': true }) }}
    </div>
    {% else %}
    <div class="card-body">
        <p class="text-muted mb-0">{{ 'You do not have permission to view client login history.'|trans }}</p>
    </div>
    {% endif %}
</div>
{% endblock %}
