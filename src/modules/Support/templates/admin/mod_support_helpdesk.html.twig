{% extends request.ajax ? 'layout_blank.html.twig' : 'layout_default.html.twig' %}

{% block meta_title %}{{ helpdesk.name }}{% endblock %}

{% set active_menu = 'system' %}

{% block breadcrumbs %}
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a href="{{ '/'|url }}">
                <svg class="icon">
                    <use xlink:href="#home" />
                </svg>
            </a>
        </li>
        <li class="breadcrumb-item">
            <a href="{{ 'system'|url }}">{{ 'Settings'|trans }}</a>
        </li>
        <li class="breadcrumb-item">
            <a href="{{ 'extension/settings/support'|url }}#tab-helpdesks">{{ 'Support'|trans }}</a>
        </li>
        <li class="breadcrumb-item active" aria-current="page">{{ 'Helpdesk -'|trans }} {{ helpdesk.name }}</li>
    </ol>
{% endblock %}

{% block content %}
<div class="card">
    <div class="card-header">
        <div>
            <h3 class="card-title">{{ helpdesk.name }}</h3>
            <p class="card-subtitle">{{ 'Helpdesk name will be visible for clients when submitting a new ticket.'|trans }}</p>
        </div>
    </div>
    <form method="post" action="{{ 'support/helpdesk_update'|api_url }}" {{ fb_api_form({ message: 'Helpdesk Updated'|trans }) }}>
        {% embed 'partial_admin_form_card.html.twig' with {
            title: 'Helpdesk Settings'|trans,
            subtitle: 'Configure the inbox identity, auto-close timing, and whether tickets can be reopened.'|trans,
            body_class: 'pt-4'
        } %}
            {% block form_content %}
                <div class="row g-3">
                    <div class="col-lg-6">
                        <label class="form-label">{{ 'Title'|trans }}</label>
                        <input class="form-control" type="text" name="name" value="{{ helpdesk.name }}" required>
                    </div>
                    <div class="col-lg-6">
                        <label class="form-label">{{ 'Email'|trans }}</label>
                        <input class="form-control" type="email" name="email" value="{{ helpdesk.email }}" required>
                    </div>
                    <div class="col-12">
                        <label class="form-label">{{ 'Signature'|trans }}</label>
                        <textarea class="form-control" name="signature" rows="3">{{ helpdesk.signature }}</textarea>
                    </div>
                    <div class="col-lg-6">
                        <label class="form-label">{{ 'Close Tickets After (in hours)'|trans }}</label>
                        <input class="form-control" type="text" name="close_after" value="{{ helpdesk.close_after }}" required>
                        <div class="form-text">{{ 'Define a very large number of hours to disable auto close ticket option.'|trans }}</div>
                    </div>
                    <div class="col-lg-6">
                        <label class="form-label d-block">{{ 'Tickets Can Be Reopened?'|trans }}</label>
                        <div class="d-flex flex-wrap gap-3">
                            <label class="form-check">
                                <input class="form-check-input" id="radioCanReopenYes" type="radio" name="can_reopen" value="1"{% if helpdesk.can_reopen %} checked{% endif %}>
                                <span class="form-check-label">{{ 'Yes'|trans }}</span>
                            </label>
                            <label class="form-check">
                                <input class="form-check-input" id="radioCanReopenNo" type="radio" name="can_reopen" value="0"{% if not helpdesk.can_reopen %} checked{% endif %}>
                                <span class="form-check-label">{{ 'No'|trans }}</span>
                            </label>
                        </div>
                    </div>
                </div>
                <input type="hidden" name="id" value="{{ helpdesk.id }}">
            {% endblock %}

            {% block form_actions %}
                <a href="{{ 'extension/settings/support'|url }}" class="btn btn-secondary">
                    <svg class="icon">
                        <use xlink:href="#arrow-sm-left" />
                    </svg>
                    {{ 'Go Back'|trans }}
                </a>
                <a class="btn btn-danger" href="{{ 'support/helpdesk_delete'|api_url(query: { 'id': helpdesk.id }) }}"
                    {{ fb_api_link({ message: 'Are you sure?'|trans, modal: {type: 'confirm', title: 'Are you sure?'|trans}, redirect: 'extension/settings/support'|url }) }}>
                    <svg class="icon">
                        <use xlink:href="#delete" />
                    </svg>
                    {{ 'Delete'|trans }}
                </a>
                <button class="btn btn-primary" type="submit">{{ 'Update'|trans }}</button>
            {% endblock %}
        {% endembed %}
    </form>
</div>
{% endblock %}
