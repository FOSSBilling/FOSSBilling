{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}
{% set active_menu = 'support' %}

{% import "macro_functions.html.twig" as mf %}

{% block meta_title %}{{ 'Contact us'|trans }}{% endblock %}
{% block meta_description %}{{ 'Send a support request or question to our team using the contact form.'|trans }}{% endblock %}

{% block body_class %}support-contact-us{% endblock %}
{% block breadcrumb %}
    <li class="breadcrumb-item active" aria-current="page">{{ 'Contact us'|trans }}</li>
{% endblock %}

{% block head %}
    {{ wysiwyg('.editor-textarea') }}
{% endblock %}

{% block content %}
    {% set company = guest.system_company %}
    <div class="tn-card">
        <div class="tn-card__header">
            <div>
                <span class="tn-card__title">{{ 'Contact us'|trans }}</span>
                {% if company.signature %}<div class="tn-card__subtitle">{{ company.signature }}</div>{% endif %}
            </div>
        </div>
        <form method="post" action="{{ 'support/ticket_create'|api_url(role: 'guest') }}" id="public-ticket-create" {{ fb_api_form({ callback: 'onTicketCreate' }) }} class="d-flex flex-column gap-3">
            <div class="row">
                <div class="col-md-6">
                    <div class="tn-field">
                        <label class="tn-field__label" for="name">{{ 'Name'|trans }}</label>
                        <input class="tn-input" type="text" name="name" value="{{ request.name }}" required="required" id="name">
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="tn-field">
                        <label class="tn-field__label" for="email">{{ 'Email'|trans }}</label>
                        <input class="tn-input" type="email" name="email" value="{{ request.email }}" required="required" id="email">
                    </div>
                </div>
            </div>
            <div class="tn-field">
                <label for="support-helpdesk-id" class="tn-field__label">{{ 'Helpdesk'|trans }}</label>
                {{ mf.selectbox('support_helpdesk_id', guest.support_helpdesk_get_pairs, request.support_helpdesk_id, 1) }}
            </div>
            <div class="tn-field">
                <label class="tn-field__label" for="subject">{{ 'Subject'|trans }}</label>
                <input class="tn-input" type="text" name="subject" value="{{ request.subject }}" required="required" id="subject">
            </div>
            {% if guest.support_kb_suggestions_enabled({ 'area': 'contact' }) %}
                {{ include('mod_support_kb_suggestions.html.twig', { 'input_id': 'subject' }) }}
            {% endif %}
            <div class="tn-field">
                <label class="tn-field__label" for="message">{{ 'Message'|trans }}</label>
                <textarea class="editor-textarea tn-input" style="height:auto; padding-top:10px;" name="content" cols="5" rows="5" required="required" id="message">{{ request.content }}</textarea>
            </div>

            {{ mf.recaptcha }}

            <div>
                <button class="tn-btn tn-btn--primary tn-btn--lg" type="submit" value="{{ 'Send'|trans }}" data-loading-text="Loading...">{{ 'Send'|trans }}</button>
            </div>
            <input type="hidden" name="anti-spam" value="1" id="anti-spam" required="required"/>
        </form>

        {% if company.address_1 or company.tel or company.email %}
            <div class="mt-4 pt-4 d-flex flex-column gap-1" style="border-top: var(--bw-hair) solid var(--border); font-size: var(--fs-xs); color: var(--text-muted);">
                <span>{{ company.name }}</span>
                {% if company.address_1 %}<span>{{ company.address_1 }}</span>{% endif %}
                {% if company.address_2 %}<span>{{ company.address_2 }}</span>{% endif %}
                {% if company.address_3 %}<span>{{ company.address_3 }}</span>{% endif %}
                {% if company.tel %}<span>{{ company.tel }}</span>{% endif %}
                {% if company.www %}<span>{{ company.www }}</span>{% endif %}
                {% if company.email %}<span>{{ company.email }}</span>{% endif %}
            </div>
        {% endif %}
    </div>
{% endblock %}

{% block js %}
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            document.getElementById('anti-spam').remove();
        });

        function onTicketCreate(result){
            window.location = "{{ 'support/ticket'|url }}" + '/' + result;
        }
    </script>
{% endblock %}
