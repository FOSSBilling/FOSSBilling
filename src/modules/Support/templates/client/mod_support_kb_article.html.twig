{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}
{% set active_menu = 'kb' %}

{% block meta_title %}{{ article.title }}{% endblock %}
{% block meta_description %}{{ (article.content ?? '')|markdown_to_html|striptags|trim|truncate(160) }}{% endblock %}

{% block body_class %}kb-article{% endblock %}
{% block head %}{{ 'css/markdown.css' | public_asset_url | stylesheet_tag }}{% endblock %}
{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ 'support'|url }}">{{ 'Support'|trans }}</a></li>
<li class="breadcrumb-item">
    <a href="{{ 'support/kb'|url }}">{{ 'Knowledge Base'|trans }}</a>
</li>
<li class="breadcrumb-item">
    <a href='{{ "support/kb/#{article.category.slug}"|url }}'>{{ article.category.title }}</a>
</li>
<li class="breadcrumb-item active" aria-current="page">{{ article.title }}</li>
{% endblock %}

{% block content %}
{% set related_articles = guest.support_kb_article_get_list({ 'kb_article_category_id': article.category.id, 'per_page': 6 }).list|filter(related_article => related_article.id != article.id)|slice(0, 5) %}
{% set word_count = (article.content ?? '')|striptags|split(' ')|length %}
{% set read_minutes = max(1, (word_count / 200)|round(0, 'ceil')) %}
<div class="row g-4 justify-content-center">
    <article class="col-lg-9">
        <div class="mb-4">
            <h1 class="display-6 mt-2 mb-3">{{ article.title }}</h1>
            <div class="d-flex flex-wrap gap-3 text-muted small">
                {% if article.updated_at %}
                    <span>{{ 'Updated'|trans }} {{ '%time% ago'|trans({ '%time%': article.updated_at|timeago }) }} &middot; {{ '%count% min read'|trans({ '%count%': read_minutes }) }}</span>
                {% else %}
                    <span>{{ '%count% min read'|trans({ '%count%': read_minutes }) }}</span>
                {% endif %}
                {% if guest.support_kb_article_views_enabled %}
                    <span>{{ article.views }} {{ 'views'|trans }}</span>
                {% endif %}
            </div>
        </div>

        <div class="tn-card mb-4">
            <article class="kb-article-content markdown-body bg-transparent text-reset" style="line-height: var(--lh-relaxed);">
                {{ (article.content ?? '')|markdown_to_html }}
            </article>
        </div>

        <div class="tn-card mb-4">
            <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                <div>
                    <div class="fw-semibold mb-1">{{ 'Did this help?'|trans }}</div>
                    <p class="text-muted small mb-0">{{ 'This lets us know which articles are working — replies are not sent to support.'|trans }}</p>
                </div>
                <div class="d-flex gap-2">
                    <button type="button" class="tn-iconbtn tn-iconbtn--outline tn-iconbtn--md" id="kb-feedback-up" disabled title="{{ 'Feedback is not wired up yet'|trans }}">
                        <svg class="icon"><use href="#thumbs-up" /></svg>
                    </button>
                    <button type="button" class="tn-iconbtn tn-iconbtn--outline tn-iconbtn--md" id="kb-feedback-down" disabled title="{{ 'Feedback is not wired up yet'|trans }}">
                        <svg class="icon"><use href="#thumbs-down" /></svg>
                    </button>
                </div>
            </div>
        </div>

        <div class="tn-card">
            <div class="d-flex flex-column flex-md-row align-items-md-center justify-content-between gap-3">
                <div>
                    <div class="fw-semibold mb-1">{{ 'Still stuck?'|trans }}</div>
                    <p class="text-muted small mb-0">{{ 'Our support team can help with anything this article did not cover.'|trans }}</p>
                </div>
                <a href="{{ 'support/contact-us'|url }}" class="tn-btn tn-btn--primary tn-btn--md">{{ 'Open a ticket'|trans }}</a>
            </div>
        </div>
    </article>

    <aside class="col-lg-3">
        <div class="position-sticky" style="top: 1rem;">
            <div class="tn-card tn-card--compact mb-4">
                <div class="text-muted small mb-1">{{ 'Category'|trans }}</div>
                <a class="fw-semibold d-block mb-3 text-decoration-none" href='{{ "support/kb/#{article.category.slug}"|url }}'>{{ article.category.title }}</a>
                <a class="tn-btn tn-btn--secondary tn-btn--sm tn-btn--block" href="{{ 'support/kb'|url }}">{{ 'Knowledge Base'|trans }}</a>
            </div>

            <div class="tn-card tn-card--compact">
                <div class="tn-card__header">
                    <div class="tn-card__title">{{ 'Related articles'|trans }}</div>
                </div>
                <div class="d-flex flex-column">
                    {% if related_articles %}
                        {% for related_article in related_articles %}
                            <a class="tn-row-hover text-decoration-none px-2 py-2 d-flex align-items-center justify-content-between" href='{{ "support/kb/#{related_article.category.slug}/#{related_article.slug}"|url }}'>
                                <span>{{ related_article.title }}</span>
                                <svg class="icon text-muted"><use href="#chevron-right" /></svg>
                            </a>
                        {% endfor %}
                    {% else %}
                        <div class="text-muted px-2 py-2">{{ 'No related articles yet.'|trans }}</div>
                    {% endif %}
                </div>
            </div>
        </div>
    </aside>
</div>
{% endblock %}
