{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}
{% set active_menu = 'support' %}

{% import "macro_functions.html.twig" as mf %}
{% set is_guest_ticket = ticket.author.role|default('') == 'guest' %}
{% set can_reply = ticket.status != 'closed' or (not is_guest_ticket and ticket.helpdesk.can_reopen) %}

{% block meta_title %}{{ ticket.subject }}{% endblock %}

{% block head %}
    {{ 'css/markdown.css' | public_asset_url | stylesheet_tag }}
    {{ wysiwyg('.editor-textarea') }}
{% endblock %}

{% block body_class %}support-ticket{% endblock %}
{% block breadcrumb %}
    {% if is_guest_ticket %}
        <li class="breadcrumb-item"><a href="{{ 'support/contact-us'|url }}">{{ 'Contact Us'|trans }}</a></li>
    {% else %}
        <li class="breadcrumb-item"><a href="{{ 'support'|url }}">{{ 'Support'|trans }}</a></li>
    {% endif %}
    <li class="breadcrumb-item active" aria-current="page">#{{ ticket.id }}</li>
{% endblock %}

{% block content %}
{% set related_service_name = null %}
{% if ticket.rel_type|default('') == 'order' and ticket.rel_id %}
    {% set related_order = client.order_get({ 'id': ticket.rel_id }) %}
    {% set related_service_name = related_order.title|default('Service #' ~ ticket.rel_id) %}
{% endif %}

<div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-1">
    <div>
        <div class="d-flex align-items-center gap-2 flex-wrap">
            <h1 class="mb-1">{{ ticket.subject }}</h1>
            {{ mf.status_badge(ticket.status, 'ticket') }}
        </div>
        <span class="text-muted">
            #{{ ticket.id }} &middot; {{ ticket.helpdesk.name }}{% if related_service_name %} &middot; {{ 'relates to'|trans }} {{ related_service_name }}{% endif %}
        </span>
    </div>
    {% if ticket.status != 'closed' %}
        <button class="tn-btn tn-btn--ghost tn-btn--sm" type="button" id="ticket-close">{{ 'Close ticket'|trans }}</button>
    {% endif %}
</div>

<div class="d-flex align-items-start gap-4 flex-wrap mt-4">
    <div class="flex-grow-1" style="min-width: 320px;">
        <div class="tn-card p-0 overflow-hidden">
            <div class="d-flex flex-column gap-3 p-3">
                {% for i, message in ticket.messages %}
                    {% set is_mine = message.author.role != 'admin' %}
                    <div class="tn-chat-row {{ is_mine ? 'tn-chat-row--mine' : '' }}">
                        {{ avatar(message.author.email|default(''), 36, 'tn-chat-row__avatar tn-avatar tn-avatar--circle d-none d-md-flex' ~ (is_mine ? '' : ' tn-card--accent'), null, 'div') }}
                        <div class="tn-chat-bubble {{ is_mine ? 'tn-chat-bubble--mine' : '' }}">
                            <div class="tn-chat-bubble__head">
                                <span class="tn-chat-bubble__name">{{ message.author.name }}{% if message.author.role == 'admin' %} &middot; {{ 'Tenant Ninja'|trans }}{% endif %}</span>
                                <span class="tn-chat-bubble__time">{{ message.created_at|timeago }} {{ 'ago'|trans }}</span>
                                {% if can_reply %}
                                    <button class="tn-iconbtn tn-iconbtn--sm btn-quote-reply ms-auto"
                                            message-quote="{{ mf.markdown_quote(message.content) }}"
                                            data-bs-toggle="tooltip" data-bs-title="{{ 'Quote Reply'|trans }}">
                                        <svg class="icon"><use href="#quote" /></svg>
                                    </button>
                                {% endif %}
                            </div>
                            <article class="markdown-body bg-transparent text-reset" id="message-{{ message.id }}">
                                {{ (message.content ?? '')|markdown_to_html }}
                            </article>
                        </div>
                    </div>
                {% endfor %}
            </div>

            {% if not can_reply %}
                <div class="alert alert-secondary text-center m-3">{{ 'Ticket was closed and cannot be reopened.'|trans }}</div>
            {% else %}
                {% if ticket.status == 'closed' %}
                    <div class="alert alert-secondary text-center mx-3">{{ 'This ticket was closed, but you can still reopen it by replying.'|trans }}</div>
                {% endif %}
                <div class="border-top p-3" id="reply-to" style="background: var(--surface-2, #f8f9fa);">
                    <form id="ticket-reply-form">
                        {% if is_guest_ticket %}
                            <input type="hidden" name="hash" value="{{ ticket.hash }}">
                        {% else %}
                            <input type="hidden" name="id" value="{{ ticket.id }}">
                        {% endif %}
                        <textarea name="content" cols="5" rows="6" class="editor-textarea form-control tn-input" required="required"
                                  id="ticket-reply-text" placeholder="{{ 'Write a reply…'|trans }}"></textarea>
                        <div class="d-flex justify-content-between align-items-center mt-2">
                            <button type="button" class="tn-iconbtn tn-iconbtn--md" data-bs-toggle="tooltip" data-bs-title="{{ 'Attach a file'|trans }}">
                                <svg class="icon"><use href="#paperclip" /></svg>
                            </button>
                            <button class="tn-btn tn-btn--primary tn-btn--md" type="submit" id="post-reply-btn">
                                <svg class="icon"><use href="#send" /></svg>
                                {{ 'Post'|trans }}
                            </button>
                        </div>
                    </form>
                </div>
            {% endif %}
        </div>
    </div>

    <div style="width: 300px; flex-shrink: 0;">
        <div class="tn-card tn-card--compact mb-3">
            <div class="tn-card__header">
                <div class="tn-card__title">{{ 'Details'|trans }}</div>
            </div>
            <div class="d-flex flex-column">
                <div class="tn-kv-row">
                    <span class="tn-kv-row__key">{{ 'Department'|trans }}</span>
                    <span class="tn-kv-row__value">{{ ticket.helpdesk.name }}</span>
                </div>
                <div class="tn-kv-row">
                    <span class="tn-kv-row__key">{{ 'Opened'|trans }}</span>
                    <span class="tn-kv-row__value">{{ ticket.created_at|format_date }}</span>
                </div>
                {% if related_service_name %}
                    <div class="tn-kv-row">
                        <span class="tn-kv-row__key">{{ 'Related to'|trans }}</span>
                        <span class="tn-kv-row__value">
                            <a href='{{ "order/service/manage/#{ticket.rel_id}"|url }}'>{{ related_service_name }}</a>
                        </span>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block js %}
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const ticketReplyForm = document.getElementById('ticket-reply-form');
            const closeTicketBtn = document.getElementById('ticket-close');
            const postReplyBtn = document.getElementById('post-reply-btn');
            const replyToMessageBtn = document.querySelectorAll('.btn-quote-reply');
            const ticketReplyTextArea = document.getElementById('ticket-reply-text');
            const supportApi = FOSSBilling.api.{{ is_guest_ticket ? 'guest' : 'client' }};

            ticketReplyForm?.addEventListener('submit', (e) => {
                e.preventDefault();
                supportApi.post('support/ticket_reply', FOSSBilling.tools.serializeFormDataToObject(new FormData(ticketReplyForm)),
                    () => {
                        flashMessage({
                            message: 'Posted reply',
                            reload: true
                        });
                    },
                    (res) => FOSSBilling.message(`${res.message} (${res.code})`, 'error')
                )
            });

            closeTicketBtn?.addEventListener('click', (e) => {
                e.preventDefault();
                toggleLoader();
                supportApi.post('support/ticket_close', FOSSBilling.tools.serializeFormDataToObject(new FormData(ticketReplyForm)),
                    () => {
                        flashMessage({
                            message: 'Closed ticket #{{ ticket.id }}',
                            reload: true
                        });
                    },
                    (res) => FOSSBilling.message(`${res.message} (${res.code})`, 'error')
                )
            });

            postReplyBtn?.addEventListener('click', () => {
                if (document.getElementById('ticket-reply-text').value.length > 0) {
                    toggleLoader();
                }
            });

            replyToMessageBtn.forEach((reply) => {
                reply.addEventListener('click', (e) => {
                    e.preventDefault();
                    let quote = e.currentTarget.getAttribute('message-quote');
                    quote = quote.replace(/^\s*$(?:\r\n?|\n)/gm, '');
                    if (ticketReplyTextArea.editor) {
                        ticketReplyTextArea.editor.setData(quote);
                        ticketReplyTextArea.editor.focus();
                    } else {
                        ticketReplyTextArea.textContent = quote;
                        ticketReplyTextArea.focus();
                    }
                });
            })

            document.getElementById('reply-to-btn')?.addEventListener('click', () => {
                if (ticketReplyTextArea.editor) {
                    ticketReplyTextArea.editor.focus();
                } else {
                    ticketReplyTextArea.focus();
                }
            });

            const toggleLoader = () => {
                let loader = document.querySelector('.wait');
                if (!loader) {
                    return;
                }
                if (loader.style.display === 'none') {
                    loader.style.display = 'block';
                } else {
                    loader.style.display = 'none';
                }
            }
        });
    </script>
{% endblock %}
