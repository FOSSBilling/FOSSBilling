{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}
{% set active_menu = 'kb' %}

{% block meta_title %}{{ category.title }}{% endblock %}
{% block meta_description %}{{ category.description|default('Browse support articles in this knowledge base category.'|trans) }}{% endblock %}

{% block body_class %}kb-category{% endblock %}
{% block breadcrumb %}
<li class="breadcrumb-item"><a href="{{ 'support'|url }}">{{ 'Support'|trans }}</a></li>
<li class="breadcrumb-item"><a href="{{ 'support/kb'|url }}">{{ 'Knowledge Base'|trans }}</a></li>
<li class="breadcrumb-item active" aria-current="page">{{ category.title }}</li>
{% endblock %}

{% block content %}
<div class="mb-4">
    <h1 class="mb-1">{{ category.title }}</h1>
    {% if category.description %}<span class="text-muted">{{ category.description }}</span>{% endif %}
</div>

<div class="tn-card tn-card--compact">
    <div class="d-flex flex-column">
        {% for i, article in category.articles %}
            <a class="tn-row-hover text-decoration-none px-2 py-2 d-flex align-items-center justify-content-between" href='{{ "support/kb/#{article.category.slug}/#{article.slug}"|url }}'>
                <span class="fw-semibold text-body">{{ article.title }}</span>
                <svg class="icon text-muted"><use href="#chevron-right" /></svg>
            </a>
        {% else %}
            <div class="alert alert-info mb-0">{{ 'No articles in this category yet.'|trans }}</div>
        {% endfor %}
    </div>
</div>
{% endblock %}
