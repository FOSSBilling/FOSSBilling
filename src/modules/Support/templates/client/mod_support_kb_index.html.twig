{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}
{% set active_menu = 'kb' %}

{% block meta_title %}{{ 'Knowledge Base Categories'|trans }}{% endblock %}
{% block meta_description %}{{ 'Browse help articles, tutorials, and answers to common questions in our knowledge base.'|trans }}{% endblock %}

{% block body_class %}kb-index{% endblock %}
{% block breadcrumb %}
  <li class="breadcrumb-item">
    <a href="{{ 'support/kb'|url }}">{{ 'Knowledge Base'|trans }}</a>
  </li>
  {% if request.q %}
  	<li class="breadcrumb-item active" aria-current="page">{{ request.q }}</li>
  {% else %}
  	<li class="breadcrumb-item active" aria-current="page">{{ 'Category List'|trans }}</li>
  {% endif %}
{% endblock %}

{% block content %}
    {% if request.q %}
        {% set kbcategories = guest.support_kb_category_get_list({ "q": request.q }) %}
        {% set kbarticles = guest.support_kb_article_get_list({ "search": request.q, "per_page": 10 }) %}
    {% else %}
        {% set kbcategories = guest.support_kb_category_get_list %}
        {% set kbarticles = null %}
    {% endif %}

    <div class="row">
        <div class="col-md-12">
            <div class="card mb-4">
                <div class="card-header py-3 py-3">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <h1 class="mb-1">{{ 'Categories'|trans }}</h1>
                            <span class="small text-muted">{{ 'Explore our knowledge base categories and their associated articles below.'|trans }}</span>
                        </div>
                        <form method="get" action="" class="form-inline">
                            <div class="input-group">
                                <input class="form-control" name="q" type="text" value="{{ request.q }}" placeholder="{{ 'What are you looking for?'|trans }}">
                                <button class="btn btn-outline-secondary" type="submit">
                                    <svg class="icon"><use href="#search" /></svg>
                                </button>
                            </div>
                        </form>
                    </div>
                </div>
                <div class="card-body">
                {% if kbarticles and kbarticles.list %}
                    <h5 class="mb-3">{{ 'Matching articles'|trans }}</h5>
                    <div class="list-group mb-4">
                        {% for article in kbarticles.list %}
                            <a class="list-group-item list-group-item-action" href='{{ "support/kb/#{article.category.slug}/#{article.slug}"|url }}'>{{ article.title }}</a>
                        {% endfor %}
                    </div>
                    <h5 class="mb-3">{{ 'Matching categories'|trans }}</h5>
                {% endif %}
                {% for row in kbcategories.list|batch(3) %}
                    <div class="row mb-2">
                        {% for i, category in row %}
                            <div class="col">
                                <a href='{{ "support/kb/#{category.slug}"|url }}' class="card link-underline link-underline-opacity-0" style="min-height: 6rem;">
                                    <div class="card-body">
                                        <h5 class="card-title">{{ category.title }}</h5>
                                        <p class="card-subtitle mb-2 text-muted">{{ category.description }}</p>
                                    </div>
                                </a>
                            </div>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="alert alert-info text-center">
                        {% if request.q %}
                            {{ 'No results found for:'|trans }}&nbsp;<strong>{{ request.q }}</strong>
                        {% else %}
                            {{ 'No knowledge base categories are available yet.'|trans }}
                        {% endif %}
                    </div>
                {% endfor %}
                </div>
            </div>
        </div>
    </div>
{% endblock %}
