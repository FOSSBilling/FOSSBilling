{% set cart = guest.cart_get %}
<div class="accordion-item">
    <h3 class="accordion-header">
        <button class="accordion-button {% if not request.checkout %}collapsed{%endif%}" type="button" data-bs-toggle="collapse" data-bs-target="#checkout" aria-expanded="false" aria-controls="checkout">
            <svg class="icon me-2"><use href="#shopping-cart" /></svg>
            <span>{{ 'Cart'|trans }}</span>&nbsp;<span class="badge text-bg-success">{{ cart.items | length }}</span>
        </button>
    </h3>
    {% if cart.items %}
    {% set cart_currency = guest.cart_get_currency %}
    <div id="checkout" class="accordion-collapse collapse {% if request.checkout and client %}show{%endif%}" data-bs-parent="#orderManager">
        <div class="accordion-body">
            <div class="accordion-inner" id="checkout-inner">
                <table class="table table-striped table-bordered table-sm">
                    <thead>
                    <tr>
                        <th>{{ 'Product'|trans }}</th>
                        <th>{{ 'Price'|trans }}</th>
                        <th style="width: 3%; text-align: center"></th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for i, item in cart.items %}
                        <tr>
                            <td>
                                {{ item.title }}
                                {% if item.quantity > 1 %}
                                    x {{ item.quantity }}
                                {% endif %}

                                {% if item.period|default(false) %}
                                    ({{ item.period|period_title }})
                                {% endif %}
                            </td>
                            <td>
                                {% if item.discount_price %}
                                    <del>{{ (item.total * cart_currency.conversion_rate)|format_currency(cart_currency.code) }}</del>
                                    <strong class="text-success">{{ ((item.total - item.discount_price) * cart_currency.conversion_rate)|format_currency(cart_currency.code) }}</strong>
                                {% else %}
                                    {{ (item.total * cart_currency.conversion_rate)|format_currency(cart_currency.code) }}
                                {% endif %}
                            </td>
                            <td>
                                <a class="btn btn-dark btn-sm" title="{{ 'Remove item'|trans }}"
                                   {{ fb_api_link({href: 'cart/remove_item'|api_url(query: {id: item.id}, role: 'guest'), modal: {type: 'confirm', title: 'Are you sure?'|trans, content: 'Are you sure you want to remove this item from cart?'|trans}, reload: true}) }}>
                                    <svg class="icon"><use href="#x" /></svg>
                                </a>
                            </td>
                        </tr>

                        {% if request.show_custom_form_values %}
                            <tr>
                                <td>
                                    {% if item.form_id and guest.extension_is_on({"mod":"formbuilder"}) %}
                                        {% set form = guest.formbuilder_get({"id": item.form_id}) %}
                                        {# debug form #}
                                        <div class="well">
                                            <dl class="row">
                                                {% for field, value in item %}
                                                    {% for form_field in form.fields %}
                                                        {% if value is not empty %}
                                                            {% if form_field.name == field%}
                                                                <dt>
                                                                    {{form_field.label}}
                                                                </dt>
                                                                <dd>
                                                                    {% if form_field.type == "checkbox"%}
                                                                        {% for selection in value %}
                                                                            {% for field_key,field_value in form_field.options%}
                                                                                {% if field_value == selection %}
                                                                                    {{ field_key }}
                                                                                {% endif %}
                                                                            {% endfor %}
                                                                        {% endfor%}
                                                                    {% elseif form_field.type == "select" or form_field.type == "radio" %}
                                                                        {% for field_key,field_value in form_field.options%}
                                                                            {% if field_value == value %}
                                                                                {{ field_key }}
                                                                            {% endif %}
                                                                        {% endfor %}
                                                                    {% else %}
                                                                        {{value}}
                                                                    {% endif %}
                                                                </dd>
                                                            {% endif %}
                                                        {% endif %}
                                                    {% endfor %}
                                                {% endfor %}
                                            </dl>
                                        </div>
                                    {% endif %}
                                </td>
                                <td></td>
                            </tr>
                        {% endif %}

                        {% if item.setup_price != 0 %}
                            <tr>
                                <td>{{ item.title }} {{ 'setup'|trans }}</td>
                                <td>
                                    {% if item.discount_setup %}
                                    <del>{{ (item.setup_price * cart_currency.conversion_rate)|format_currency(cart_currency.code) }}</del>
                                    {{ ((item.setup_price - item.discount_setup) * cart_currency.conversion_rate)|format_currency(cart_currency.code) }}
                                    {% else %}
                                    {{ (item.setup_price * cart_currency.conversion_rate)|format_currency(cart_currency.code) }}</td>
                                {% endif %}
                            </tr>
                        {% endif %}

                    {% endfor %}
                    </tbody>
                </table>

                <div class="row">
                    <div class="col-md-6">
                        {% if not cart.promocode %}
                            <a href="#" id="show-promo-field">{{ 'Have a coupon code?'|trans }}</a>
                        {% endif %}

                        <form method="post" action="{{ 'cart/apply_promo'|api_url(role: 'guest') }}" {{ fb_api_form({message: 'Promo Code Applied to Order'|trans, reload: true}) }}
                            {% if not cart.promocode %}style="display:none"{% endif %} id="apply-promo">
                            <div class="control-group">
                                <div class="form-controls">
                                    <div class="input-append">
                                        <input class="span8" type="text" name="promocode" id="promocode" value="{{ request.promocode|default(cart.promocode) }}" {% if promo|default({}).required|default(false) %}required="required"{% endif %} placeholder="{{ 'Enter code'|trans }}">
                                        {% if cart.promocode %}
                                            <a class="btn btn-warning btn-sm mb-1" href="{{ 'cart/remove_promo'|api_url(role: 'guest') }}" type="button" {{ fb_api_link({reload: true}) }}>{{ 'Remove'|trans }}</a>
                                        {% else %}
                                            <button class="btn btn-primary btn-sm mb-1" type="submit">{{ 'Apply'|trans }}</button>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>

                    <div class="col-md-6">
                        <table class="table table-bordered table-striped">
                            {% if cart.discount >0 %}
                                <tr>
                                    <td><strong>{{ 'Subtotal:'|trans }}</strong></td>
                                    <td><strong>{{ (cart.subtotal * cart_currency.conversion_rate)|format_currency(cart_currency.code) }}</strong></td>
                                </tr>
                                <tr>
                                    <td><strong>{{ 'Discount:'|trans }}</strong></td>
                                    <td><strong>- {{ (cart.discount * cart_currency.conversion_rate)|format_currency(cart_currency.code) }}</strong></td>
                                </tr>
                            {% endif %}

                            {% set tax_amount = 0 %}
                            {% if client and client.client_is_taxable %}
                                {% set tax_rate = client.invoice_get_tax_rate %}
                                {% set tax_amount = cart.total * tax_rate / 100 %}
                                <tr>
                                    <td><strong>{{ 'VAT'|trans }} ({{ tax_rate }}%) :</strong></td>
                                    <td><strong>{{ (tax_amount * cart_currency.conversion_rate)|format_currency(cart_currency.code) }}</strong></td>
                                </tr>
                            {% endif %}
                            <tr>
                                <td><strong>{{ 'Total:'|trans }}</strong></td>
                                <td><strong>{{ ((cart.total + tax_amount) * cart_currency.conversion_rate)|format_currency(cart_currency.code) }}</strong></td>
                            </tr>

                        </table>

                        <form method="post" action="{{ 'cart/checkout'|api_url }}" {{ fb_api_form({callback: 'onOrderCheckout'}) }}>
                            <fieldset>
                                {% set enough_in_balance = client ? client.client_balance_get_total >= cart.total : false %}
                                {% if cart.total and not enough_in_balance %}
                                    <div class="control-group">
                                        <p class="small text-muted mb-2">{{ 'Choose a payment method to continue with your order.'|trans }}</p>
                                        <div class="d-flex flex-wrap gap-3">
                                        {% set gateway_selected = false %}
                                        {% for gtw in guest.invoice_gateways %}
                                            {% if cart.currency.code in gtw.accepted_currencies and (gtw.allow_single or (cart.subscribable|default(false) and gtw.allow_recurrent)) %}
                                                {% set gateway_input_id = 'order-gateway-' ~ gtw.id %}
                                                <div class="invoice-gateway rounded-2 p-2">
                                                    <input type="radio" class="btn-check border-0" name="gateway_id" id="{{ gateway_input_id }}" value="{{ gtw.id }}" autocomplete="off" {{ not gateway_selected ? 'checked' : '' }}/>
                                                    {% if gtw.logo.logo %}
                                                        <label class="btn" for="{{ gateway_input_id }}"
                                                            style="background: transparent url('{{ gtw.logo.logo }}') no-repeat center center; background-size: contain; height:{{ gtw.logo.height }}; width:{{ gtw.logo.width }};"
                                                            data-bs-toggle="tooltip" data-bs-title="{{ gtw.title }}"
                                                            aria-label="{{ gtw.title }}"></label>
                                                    {% else %}
                                                        <label class="btn text-nowrap" for="{{ gateway_input_id }}">{{ gtw.title }}</label>
                                                    {% endif %}
                                                </div>
                                                {% set gateway_selected = true %}
                                            {% endif %}
                                        {% endfor %}
                                        </div>
                                    </div>
                                {% endif %}
                                <div class="control-group">
                                    <div class="controls mt-3">
                                        {% if enough_in_balance %}
                                            <p>{{ 'Total amount will be deducted from account balance'|trans }}</p>
                                        {% endif %}
                                        {% if settings.checkout_tos|default('0') == 'explicit' %}
                                            <div class="form-check mb-1">
                                                <input class="form-check-input" type="checkbox" value="" id="flexCheckDefault" required>
                                                <label class="form-check-label" for="flexCheckDefault">
                                                    {# TODO: Make this translatable once support for placeholders is implemented #}
                                                    <span>I agree to the <a href="{{ 'tos'|url }}" target="_blank">{{ 'Terms of Service'|trans }}</a> and <a href="{{ 'privacy-policy'|url }}" target="_blank">{{ 'Privacy Policy'|trans }}</a>.</span>
                                                </label>
                                            </div>
                                        {% endif %}
                                        <button id="checkoutButton" class="btn btn-primary btn-large" type="submit" {% if not client %} hidden="true" {% endif %}>{{ 'Checkout'|trans }}</button>
                                        <p id="loginMessage" {% if client %} hidden="true" {% endif %}>{{ 'You must first login / create an account before you can checkout.'|trans }}</p>
                                    </div>
                                </div>
                            </fieldset>
                            {% if settings.checkout_tos|default('0') == 'implicit' %}
                                {# TODO: Make this translatable once support for placeholders is implemented #}
                                <span class="text-muted">By completing your order, you agree to our <a href="{{ 'tos'|url }}" target="_blank">{{ 'Terms of Service'|trans }}</a> and <a href="{{ 'privacy-policy'|url }}" target="_blank">{{ 'Privacy Policy'|trans }}</a>.</span>
                            {% endif %}
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
    {% endif %}
</div>
