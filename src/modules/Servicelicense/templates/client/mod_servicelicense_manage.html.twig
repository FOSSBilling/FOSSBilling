{% if order.status == 'active' %}
<div class="tn-card tn-card--compact mb-4">
    <div class="tn-card__header">
        <span class="tn-card__title">{{ 'License details'|trans }}</span>
    </div>

    <div class="tn-kv-row">
        <span class="tn-kv-row__key">{{ 'Key'|trans }}</span>
        <span class="tn-kv-row__value" style="font-family: var(--font-mono);">{{ service.license_key }}</span>
    </div>

    {% if service.validate_ip %}
        <div class="tn-kv-row">
            <span class="tn-kv-row__key">{{ 'Valid IPs'|trans }}</span>
            <span class="tn-kv-row__value">
                {% for ip in service.ips %}{{ ip }}{% if not loop.last %}, {% endif %}{% else %}{{ 'All IPs'|trans }}{% endfor %}
            </span>
        </div>
    {% endif %}

    {% if service.validate_host %}
        <div class="tn-kv-row">
            <span class="tn-kv-row__key">{{ 'Valid domains'|trans }}</span>
            <span class="tn-kv-row__value">
                {% for host in service.hosts %}{{ host }}{% if not loop.last %}, {% endif %}{% else %}{{ 'All hosts'|trans }}{% endfor %}
            </span>
        </div>
    {% endif %}

    {% if service.validate_version %}
        <div class="tn-kv-row">
            <span class="tn-kv-row__key">{{ 'Valid versions'|trans }}</span>
            <span class="tn-kv-row__value">
                {% for version in service.versions %}{{ version }}{% if not loop.last %}, {% endif %}{% else %}{{ 'All versions'|trans }}{% endfor %}
            </span>
        </div>
    {% endif %}

    {% if service.validate_path %}
        <div class="tn-kv-row">
            <span class="tn-kv-row__key">{{ 'Valid installation paths'|trans }}</span>
            <span class="tn-kv-row__value">
                {% for path in service.paths %}{{ path }}{% if not loop.last %}, {% endif %}{% else %}{{ 'All paths'|trans }}{% endfor %}
            </span>
        </div>
    {% endif %}

    <div class="mt-3">
        <p class="text-muted fs-8 mb-2">{{ 'Resetting the license clears saved validation data (IP addresses, domains, versions, installation paths). Use this after moving servers, the license will need to be activated again from the new environment.'|trans }}</p>
        <a class="tn-btn tn-btn--secondary tn-btn--sm" {{ fb_api_link({href: 'servicelicense/reset'|api_url(query: {order_id: order.id}), modal: {type: 'confirm', title: 'Are you sure?'|trans}, message: 'License was reset'|trans}) }}>{{ 'Reset license'|trans }}</a>
    </div>
</div>
{% endif %}
