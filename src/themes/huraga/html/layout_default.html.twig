<!DOCTYPE html>
{% set active_locale = guest.system_locale|default('en')|replace({'_': '-'}) %}
{% set canonical_url = guest.system_current_url|url %}
{% set current_active_menu = active_menu|default('') %}
<html lang="{{ active_locale }}" data-bs-theme="{{ settings.theme|default('light') }}">
<head>
    <meta charset="utf-8">
    <title>{{ (settings.meta_title_prefix|default('') ~ ' ' ~ block('meta_title') ~ ' ' ~ settings.meta_title_suffix|default(''))|trim }}</title>

    <meta name="description" content="{% block meta_description %}{{ settings.meta_description }}{% endblock %}">
    <meta name="keywords" content="{{ settings.meta_keywords }}">
    <meta name="robots" content="{{ settings.meta_robots }}">
    <meta name="author" content="{{ settings.meta_author }}">
    <meta name="generator" content="FOSSBilling">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="color-scheme" content="light dark">

    {% block canonical %}
        <link rel="canonical" href="{{ canonical_url }}">
    {% endblock %}

    {% block opengraph %}
        <meta property="og:title" content="{{ (settings.meta_title_prefix|default('') ~ ' ' ~ block('meta_title') ~ ' ' ~ settings.meta_title_suffix|default(''))|trim }}" />
        <meta property="og:type" content="website" />
        <meta property="og:description" content="{{ block('meta_description') }}" />
        <meta property="og:url" content="{{ canonical_url }}" />
        <meta property="og:site_name" content="{{ guest.system_company.name }}" />
    {% endblock %}

    {{ include('partials/theme_init.html.twig') }}

    <link rel="stylesheet" href="{{ 'build/css/vendor.css' | asset_url }}">
    <link rel="stylesheet" href="{{ 'build/css/huraga.css' | asset_url }}">
    <link rel="shortcut icon" href="{{ guest.system_company.favicon_url }}">

    {{ 'js/fossbilling.js' | public_asset_url | script_tag }}
    {{ 'js/api.js' | public_asset_url | script_tag }}
    <script type="module" src="{{ 'build/js/huraga.js' | asset_url }}"></script>

    {{ debug_bar_render_head() }}

    {% block head %}{% endblock %}
    {% block js %}{% endblock %}
</head>

<body class="{% block body_class %}{% endblock %}">

<div class="d-none">{{ svg_sprite() }}</div>

{{ render_widgets('client.theme.body.start') }}

{% block body %}
{% if not client and settings.require_login %}
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const publicPaths = [
                '/news',
                '/tos',
                '/privacy-policy'
                {% if guest.support_guest_tickets_enabled() %}
                ,'/support/contact-us'
                ,'/support/contact-us/conversation'
                ,'/support/ticket'
                {% endif %}
            ];
            const currentPath = window.location.pathname;

            const isAllowed = publicPaths.some(path => currentPath.startsWith(path));
            if (!isAllowed) {
                window.location.href = '{{ "login"|url }}';
            }
        });
    </script>
{% endif %}

{% if client and profile is not defined %}
    {% set profile = client.profile_get %}
{% endif %}
{% set company = guest.system_company %}
{% set guest_support_url = guest.support_guest_tickets_enabled() ? 'support/contact-us'|url : 'login'|url %}
{% set support_url = client ? 'support'|url : guest_support_url %}

<div class="container">
    <header>
        {{ render_widgets('client.theme.header.start') }}
        <nav class="navbar navbar-expand-md py-4">
            <div class="container-fluid">
                {{ include('partial_company_logo.html.twig', {
                    company: company,
                    logo_url: settings.show_company_logo ? company.logo_url : null,
                    dark_logo_url: settings.show_company_logo ? company.logo_url_dark : null,
                    link_class: 'navbar-brand',
                    image_class: 'd-none d-sm-block',
                    show_mobile_name: true
                }) }}
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                        data-bs-target="#navbarSupportedContent" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="{{ 'Toggle navigation'|trans }}">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarSupportedContent">
                    <ul class="navbar-nav me-auto mb-2 mb-lg-0 w-100 d-flex justify-content-end align-items-md-center">
                        {% set languages = guest.extension_languages(true) %}
                        {% if languages|length > 1 %}
                            <li class="nav-item">
                                <select name="lang" class="form-select js-locale-selector">
                                    {% for lang in languages %}
                                        <option value="{{ lang.locale }}" data-custom-properties="&lt;span class=&quot;fi fi-{{ lang.locale|split('_')[1]|lower }}&quot;&gt;&lt;/span&gt;"{% if lang.locale == guest.system_locale %} selected{% endif %}>{{ lang.title }}</option>
                                    {% endfor %}
                                </select>
                            </li>
                        {% endif %}

                        <li class="nav-item d-md-flex">
                            <a class="nav-link px-0 hide-theme-dark js-theme-toggler"
                               href="?theme=dark"
                               data-bs-toggle="tooltip"
                               data-bs-placement="bottom"
                               data-bs-original-title="{{ 'Enable dark mode'|trans }}">
                                <svg class="icon text-dark"><use href="#moon" /></svg>
                            </a>
                            <a class="nav-link px-0 hide-theme-light js-theme-toggler"
                               href="?theme=light"
                               data-bs-toggle="tooltip"
                               data-bs-placement="bottom"
                               data-bs-original-title="{{ 'Enable light mode'|trans }}">
                                <svg class="icon text-white"><use href="#sun" /></svg>
                            </a>
                        </li>

                        {% if settings.top_menu_dashboard %}
                            <li class="nav-item d-md-flex">
                                <a class="nav-link{% if current_active_menu == 'dashboard' %} active{% endif %}" href="{{ ''|url }}"{% if current_active_menu == 'dashboard' %} aria-current="page"{% endif %}>{{ 'Dashboard'|trans }}</a>
                            </li>
                        {% endif %}

                        {% if settings.top_menu_order %}
                            <li class="nav-item d-md-flex">
                                <a class="nav-link{% if current_active_menu == 'order' %} active{% endif %}" href="{{ 'order'|url }}"{% if current_active_menu == 'order' %} aria-current="page"{% endif %}>{{ 'Order'|trans }}</a>
                            </li>
                        {% endif %}

                        {% if settings.top_menu_profile and not client %}
                            <li class="nav-item d-md-flex">
                                <a class="nav-link{% if current_active_menu == 'login' %} active{% endif %}" href="{{ 'login'|url }}"{% if current_active_menu == 'login' %} aria-current="page"{% endif %}>{{ 'Login'|trans }}</a>
                            </li>
                        {% endif %}

                        {% if settings.top_menu_signout %}
                            <li class="nav-item d-md-flex">
                                {% if client %}
                                    <div class="dropdown client-dropdown">
                                        <button class="nav-link dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                            {% set avatar_size = 25 %}
                                            {{ avatar(profile.email, avatar_size, 'rounded-circle d-inline-block', null, 'div') }}
                                            <span class="ms-1">{% if profile.company %}{{ profile.first_name }} {{ profile.last_name }} ({{ profile.company }}){% else %}{{ profile.first_name }} {{ profile.last_name }}{% endif %}</span>
                                        </button>
                                        <ul class="dropdown-menu">
                                            <li><a class="dropdown-item"
                                                   href="{{ 'client/profile'|url }}">{{ 'Profile'|trans }}</a></li>
                                            <li><a class="dropdown-item"
                                                   href="{{ 'client/logout'|url }}">{{ 'Sign Out'|trans }}</a></li>
                                        </ul>
                                    </div>
                                {% else %}
                                    <a class="ms-2 btn btn-outline-primary d-none d-md-block"
                                       href="{{ 'signup'|url }}">{{ 'Register'|trans }}</a>
                                {% endif %}
                            </li>
                        {% endif %}

                        <li class="d-md-none list-unstyled">
                            <ul class="navbar-nav">
                                {{ include('mobile_menu.html.twig') }}
                            </ul>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
        {{ render_widgets('client.theme.header.end') }}
    </header>
    <div class="container">
        <div class="row">
        {% if client or not settings.hide_menu %}
            <div class="col-3 d-none d-md-block">
                {{ include('partial_menu.html.twig') }}
            </div>
        {% endif %}
            <div class="col-12 col-md-9{% if not client and settings.hide_menu %} mx-auto{% endif %}">
                <div id="wrapper">
                    <section role="main">
                        {% block content_before %}{% endblock %}
                        <div class="content-block" role="main">
                            {% if settings.show_breadcrumb %}
                                {% block breadcrumbs %}
                                    <nav aria-label="{{ 'breadcrumb'|trans }}">
                                        <ol class="breadcrumb d-none d-md-flex">
                                            <li class="breadcrumb-item"><a href="{{ '/'|url }}">{{ 'Home'|trans }}</a>
                                            </li>
                                            {% block breadcrumb %}
                                                <li class="active breadcrumb-item">{{ 'Dashboard'|trans }}</li>
                                            {% endblock %}
                                        </ol>
                                    </nav>
                                {% endblock %}
                            {% endif %}

                            {{ render_widgets('client.theme.content.before') }}
                            {% block content %}{% endblock %}
                            {{ render_widgets('client.theme.content.after') }}

                            {{ include('partial_message.html.twig') }}

                            {% block content_after %}{% endblock %}
                        </div>
                    </section>
                    <div id="push"></div>
                </div>

                {% if settings.footer_enabled %}
                    <footer id="footer" class="small text-muted mt-2 mb-3">
                        <div class="d-flex flex-column">
                            {{ render_widgets('client.theme.footer.start') }}
                            <div class="d-flex justify-content-center">
                                <span>&copy; {{ 'now'|date('Y') }} {{ settings.footer_signature|default(company.signature) }}
                                    {% if company.bank_info_pagebottom == 1 %}
                                        <br/>
                                        <b>{{'Payment Information'|trans}}</b> - {{'Bank Name'|trans}}: {{ company.bank_name }} | {{'BIC / SWIFT Code'|trans}}: {{ company.bic }} | {{'Account Number'|trans}}: {{ company.account_number }}
                                    {% endif %}
                                </span>
                            </div>
                            <div class="d-flex justify-content-center">
                                {% set first_link_rendered = false %}
                                {% for i in 1..5 %}
                                    {% set enabled_key = 'footer_link_' ~ i ~ '_enabled' %}
                                    {% set page_key = 'footer_link_' ~ i ~ '_page' %}
                                    {% set title_key = 'footer_link_' ~ i ~ '_title' %}
                                    {% set link_enabled = attribute(settings, enabled_key) is defined ? attribute(settings, enabled_key) : false %}
                                    {% if link_enabled %}
                                        {% if first_link_rendered %}&nbsp;&#x2022;&nbsp;{% endif %}
                                        {% set link_page = attribute(settings, page_key)|default('') %}
                                        {% set link_title = attribute(settings, title_key)|default('') %}
                                        {% if 'http://' in link_page or 'https://' in link_page %}
                                            <a class="link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover"
                                               href="{{ link_page }}">{{ link_title }}</a>
                                        {% else %}
                                            <a class="link-offset-2 link-offset-3-hover link-underline link-underline-opacity-0 link-underline-opacity-75-hover"
                                               href="{{ link_page|url }}">{{ link_title }}</a>
                                        {% endif %}
                                        {% set first_link_rendered = true %}
                                    {% endif %}
                                {% endfor %}
                            </div>
                            {{ render_widgets('client.theme.footer.end') }}
                        </div>
                    </footer>
                {% endif %}
            </div>
        </div>
    </div>
    <div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 1070;"></div>
    {% if settings.footer_to_top_enabled %}
        <a href="#top" class="position-fixed btn btn-primary bottom-0 end-0 m-3">
            <svg class="icon"><use href="#arrow-up" /></svg> {{ 'Top'|trans }}</a>
    {% endif %}
    <div class="wait" style="display:none" onclick="this.style.display='none'">
        <div class="spinner-border"
             style="width: 4rem; height: 4rem; top: 50%; left: 50%; position: fixed; z-index: 999"></div>
    </div>
    <noscript>{{ "NOTE: Many features on FOSSBilling require Javascript and cookies. You can enable both in your browser's preference settings."|trans }}</noscript>

    {% endblock %}

    {% if settings.inject_javascript %}
        {{ settings.inject_javascript|raw }}
    {% endif %}
    {{ include('partial_pending_messages.html.twig', ignore_missing: true) }}
    {% if guest.extension_is_on({ "mod": "cookieconsent" }) %}
        {{ include('mod_cookieconsent_index.html.twig', ignore_missing: true) }}
    {% endif %}
</div>
{{ render_widgets('client.theme.body.end') }}
{{ debug_bar_render() }}
</body>
</html>
