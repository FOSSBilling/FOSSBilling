{% set _auth_form_fallback %}{% block auth_form %}{% endblock %}{% endset %}
{% set auth_form = block('auth_form')|trim %}
{% set _auth_footer_note_fallback %}{% block auth_footer_note %}{% endblock %}{% endset %}
{% set auth_footer_note = block('auth_footer_note')|trim %}

<div class="page page-center">
    <div class="container-tight py-4">
        <div class="text-center mb-4">
            <a href="{{ '/'|url(area: 'client') }}">
                {% if company.logo_url %}
                    <img class="hide-theme-light" src="{{ company.logo_url_dark }}" style="height: 60px; width: auto;" alt="{{ company.name }}">
                    <img class="hide-theme-dark" src="{{ company.logo_url }}" style="height: 60px; width: auto;" alt="{{ company.name }}">
                {% else %}
                    <span class="h1">{{ company.name }}</span>
                {% endif %}
            </a>
        </div>
        <div class="card card-md">
            <div class="card-body">
                <h2 class="h2 text-center mb-4">{{ title }}</h2>
                {% if subtitle is defined and subtitle %}
                    <p class="text-muted mb-4">{{ subtitle }}</p>
                {% endif %}
                {{ auth_form|raw }}
            </div>
        </div>
        {% if auth_footer_note %}
            <div class="text-center text-muted mt-3">
                {{ auth_footer_note|raw }}
            </div>
        {% endif %}
    </div>
</div>
