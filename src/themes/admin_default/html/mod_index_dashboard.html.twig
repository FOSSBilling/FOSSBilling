{% block js %}
    <script>
        document.addEventListener('click', async function(event) {
            const link = event.target.closest('[data-dashboard-section]');
            if (!link) {
                return;
            }

            event.preventDefault();

            const section = link.dataset.dashboardSection;
            const currentCard = document.querySelector(`[data-dashboard-card="${section}"]`);
            if (!currentCard) {
                window.location.href = link.href;
                return;
            }

            const requestUrl = new URL(link.href, window.location.origin);
            requestUrl.searchParams.set('dashboard_section', section);

            currentCard.style.opacity = '0.6';

            try {
                const response = await fetch(requestUrl.toString(), {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest',
                    },
                });

                if (!response.ok) {
                    throw new Error(`Request failed with status ${response.status}`);
                }

                const html = await response.text();
                const template = document.createElement('template');
                template.innerHTML = html.trim();
                const replacement = template.content.firstElementChild;

                if (!replacement) {
                    throw new Error('Dashboard fragment response was empty.');
                }

                currentCard.replaceWith(replacement);
            } catch (error) {
                window.location.href = link.href;
            }
        });
    </script>
    {% if admin.system_is_allowed({ 'mod': 'stats' }) %}
        {% set currency = guest.currency_get %}
        <script>
            document.addEventListener('DOMContentLoaded', function() {
                const charts = [
                    ['chart-income', {{ admin.stats_get_income({ 'date_from': request.date_from, 'date_to': request.date_to })|json_encode }}, {
                        label: "{{ 'Income'|trans }}",
                        height: 112,
                        valueFormat: 'currency',
                        currency: "{{ currency.code|default('USD') }}",
                    }],
                    ['chart-orders', {{ admin.stats_get_orders({ 'date_from': request.date_from, 'date_to': request.date_to })|json_encode }}, {
                        label: "{{ 'Orders'|trans }}",
                        height: 88,
                    }],
                    ['chart-invoices', {{ admin.stats_get_invoices({ 'date_from': request.date_from, 'date_to': request.date_to })|json_encode }}, {
                        label: "{{ 'Invoices'|trans }}",
                        height: 88,
                    }],
                    ['chart-clients', {{ admin.stats_get_clients({ 'date_from': request.date_from, 'date_to': request.date_to })|json_encode }}, {
                        label: "{{ 'Clients'|trans }}",
                        height: 88,
                    }],
                    ['chart-tickets', {{ admin.stats_get_tickets({ 'date_from': request.date_from, 'date_to': request.date_to })|json_encode }}, {
                        label: "{{ 'Tickets'|trans }}",
                        height: 88,
                    }],
                ];

                charts.forEach(function([elementId, data, chartOptions]) {
                    FOSSBilling.charts.renderTimeSeriesSparkline(elementId, data, {
                        height: 140,
                        showTooltip: true,
                        ...chartOptions,
                    });
                });
            });
        </script>
    {% endif %}
{% endblock %}
