                                    <use href="#address-book" />
                                </svg>
                            </span>
                        </div>
                        <div class="col">
                            <div class="font-weight-medium">{{ stats.clients_total }} {{ 'Clients'|trans }}</div>
                            <div class="text-muted">{{ client_statuses.suspended }} {{ 'Suspended'|trans }}</div>
                        </div>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-sm-6 col-lg-3">
